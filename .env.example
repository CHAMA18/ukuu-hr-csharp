# ─────────────────────────────────────────────────────────────────────────────
# Ukuu HR — Environment Variables Reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (local dev) or set these in your Render/Heroku/
# Docker host environment. The .env file is gitignored — never commit real
# credentials.

# ── Production: Prisma Postgres (managed PostgreSQL) ──
# Get this from the Prisma Console → your database → Connection tab.
# Format: Host=db.prisma.io;Port=5432;Database=postgres;Username=<API_KEY_ID>;Password=<API_KEY_SECRET>;SSL Mode=Require;TrustServerCertificate=true;Timeout=30;CommandTimeout=60
POSTGRES_CONNECTION_STRING=

# ── Alternative: any external PostgreSQL via DATABASE_URL ──
# Render-style postgres:// URL. Auto-converted to Npgsql format by Program.cs.
# Lower priority than POSTGRES_CONNECTION_STRING if both set.
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# ── Local dev fallback: SQLite (used only when both above are unset) ──
# Defaults to "ukuuhr.db" in the project root. Override if you want a custom path.
# ConnectionString__SqlitePath=ukuuhr.db

# ── App settings ──
ASPNETCORE_ENVIRONMENT=Production
DOTNET_SYSTEM_GLOBALIZATION_INVARIANT=false

# ── Optional: keep-alive self-ping (Render free-tier spin-down prevention) ──
# Defaults to the app's own /health endpoint every 5 minutes.
# KeepAlive__TargetUrl=https://your-app.onrender.com/health
