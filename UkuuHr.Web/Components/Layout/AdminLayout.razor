@inject NavigationManager Nav
@inject IHttpContextAccessor HttpAccessor
@inject CurrentUserService CurrentUser
@inject IJSRuntime JS
@implements IDisposable

@code {
    [Parameter] public RenderFragment? Body { get; set; }
    private bool _collapsed = false;
    private bool _mobileOpen = false;
    private string _currentUrl = string.Empty;
    private string _userName = "Administrator";
    private string _userRole = "Admin";
    private string _userInitials = "A";
    private bool _isDark = true;

    protected override void OnInitialized()
    {
        _currentUrl = Nav.ToBaseRelativePath(Nav.Uri);
        Nav.LocationChanged += OnLocationChanged;

        // Read theme from HttpContext (SSR) — this persists across page navigations
        // because the cookie/localStorage value is read server-side on every request.
        try
        {
            var httpCtx = HttpAccessor.HttpContext;
            if (httpCtx?.Request?.Cookies != null)
            {
                var themeCookie = httpCtx.Request.Cookies["ukuu-theme"];
                if (!string.IsNullOrEmpty(themeCookie))
                    _isDark = themeCookie == "dark";
            }
        }
        catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Also try reading from JS localStorage (covers cases where cookie isn't set yet)
            try
            {
                var theme = await JS.InvokeAsync<string>("ukuuGetTheme");
                _isDark = theme == "dark";
            }
            catch { }

            // Resolve the actual signed-in user's display name from the auth cookie.
            try
            {
                var httpCtx = HttpAccessor.HttpContext;
                var nameClaim = httpCtx?.User?.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value;
                if (!string.IsNullOrWhiteSpace(nameClaim))
                {
                    _userName = nameClaim;
                    _userInitials = GetInitials(nameClaim);
                }
                var roleClaim = httpCtx?.User?.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                if (!string.IsNullOrWhiteSpace(roleClaim))
                {
                    _userRole = RoleDisplayName(roleClaim);
                }
            }
            catch { }

            StateHasChanged();
        }
    }

    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "U";
        if (parts.Length == 1) return parts[0][..1].ToUpper();
        return $"{parts[0][..1]}{parts[^1][..1]}".ToUpper();
    }

    private static string RoleDisplayName(string role) => role switch
    {
        "super_admin" => "Super Admin",
        "hr_admin" => "HR Admin",
        "finance_payroll_admin" => "Finance & Payroll Admin",
        "hr_operator" => "HR Operator",
        "finance_payroll" => "Finance & Payroll",
        "employee" => "Employee",
        _ => role
    };

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _currentUrl = Nav.ToBaseRelativePath(e.Location);
        _mobileOpen = false;
        StateHasChanged();
    }

    private bool IsActive(string url)
    {
        if (string.IsNullOrEmpty(url)) return false;
        var current = _currentUrl.Split('?')[0].Split('#')[0];
        if (url == "dashboard" && (string.IsNullOrEmpty(current) || current == "")) return true;
        return current.StartsWith(url, StringComparison.OrdinalIgnoreCase);
    }

    private void ToggleSidebar() { _collapsed = !_collapsed; }
    private void ToggleMobile() { _mobileOpen = !_mobileOpen; }
    private void CloseMobile() { _mobileOpen = false; }

    private async Task ToggleTheme()
    {
        try
        {
            var newTheme = await JS.InvokeAsync<string>("ukuuToggleTheme");
            _isDark = newTheme == "dark";
        }
        catch { }
    }

    private void Logout()
    {
        Nav.NavigateTo("/logout", forceLoad: true);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="bk-admin-body">
    <div class="bk-admin-sidebar @(_collapsed ? "collapsed" : "") @(_mobileOpen ? "mobile-open" : "")">
        <a href="/dashboard" class="bk-admin-sidebar-brand">
            <div class="bk-admin-sidebar-brand-logo">U</div>
            @if (!_collapsed)
            {
                <div>
                    <div class="bk-admin-sidebar-brand-name">UKUU HR</div>
                    <div class="bk-admin-sidebar-brand-tag">HRMS Platform</div>
                </div>
            }
        </a>

        <nav class="bk-admin-sidebar-nav">
            @if (!_collapsed)
            {
                <div class="bk-admin-sidebar-section-label">Workspace</div>
            }

            <a href="/dashboard" class="bk-admin-sidebar-item @(IsActive("dashboard") ? "active" : "")">
                <span class="bk-admin-sidebar-item-icon"><span class="material-icons-round" style="font-size:20px;">dashboard</span></span>
                @if (!_collapsed) { <span class="bk-admin-sidebar-item-text">Dashboard</span> }
            </a>
            <a href="/employees" class="bk-admin-sidebar-item @(IsActive("employees") ? "active" : "")">
                <span class="bk-admin-sidebar-item-icon"><span class="material-icons-round" style="font-size:20px;">groups</span></span>
                @if (!_collapsed) { <span class="bk-admin-sidebar-item-text">Employees</span> }
            </a>
            <a href="/attendance-logs" class="bk-admin-sidebar-item @(IsActive("attendance-logs") || IsActive("attendance") || IsActive("attendance/search") ? "active" : "")">
                <span class="bk-admin-sidebar-item-icon"><span class="material-icons-round" style="font-size:20px;">schedule</span></span>
                @if (!_collapsed) { <span class="bk-admin-sidebar-item-text">Attendance</span> }
            </a>
            <a href="/leave" class="bk-admin-sidebar-item @(IsActive("leave") ? "active" : "")">
                <span class="bk-admin-sidebar-item-icon"><span class="material-icons-round" style="font-size:20px;">event_available</span></span>
                @if (!_collapsed) { <span class="bk-admin-sidebar-item-text">Leave</span> }
            </a>
            <a href="/overtime" class="bk-admin-sidebar-item @(IsActive("overtime") ? "active" : "")">
                <span class="bk-admin-sidebar-item-icon"><span class="material-icons-round" style="font-size:20px;">more_time</span></span>
                @if (!_collapsed) { <span class="bk-admin-sidebar-item-text">Overtime</span> }
            </a>
            <a href="/holidays" class="bk-admin-sidebar-item @(IsActive("holidays") ? "active" : "")">
                <span class="bk-admin-sidebar-item-icon"><span class="material-icons-round" style="font-size:20px;">event</span></span>
                @if (!_collapsed) { <span class="bk-admin-sidebar-item-text">Holidays</span> }
            </a>
            <a href="/shifts" class="bk-admin-sidebar-item @(IsActive("shifts") && !IsActive("shifts/assignments") && !IsActive("shifts/tolerance") && !IsActive("shifts/coverage") ? "active" : "")">
                <span class="bk-admin-sidebar-item-icon"><span class="material-icons-round" style="font-size:20px;">calendar_month</span></span>
                @if (!_collapsed) { <span class="bk-admin-sidebar-item-text">Shifts</span> }
            </a>
            <a href="/devices" class="bk-admin-sidebar-item @(IsActive("devices") && !IsActive("devices/add") && !IsActive("hikvision") ? "active" : "")">
                <span class="bk-admin-sidebar-item-icon"><span class="material-icons-round" style="font-size:20px;">fingerprint</span></span>
                @if (!_collapsed) { <span class="bk-admin-sidebar-item-text">Devices</span> }
            </a>

            @if (!_collapsed)
            {
                <div class="bk-admin-sidebar-section-label">Administration</div>
            }

            <a href="/settings" class="bk-admin-sidebar-item @(IsActive("settings") && !IsActive("settings/organization") && !IsActive("settings/leave-types") && !IsActive("settings/notifications") && !IsActive("settings/user-management") ? "active" : "")">
                <span class="bk-admin-sidebar-item-icon"><span class="material-icons-round" style="font-size:20px;">settings</span></span>
                @if (!_collapsed) { <span class="bk-admin-sidebar-item-text">Settings</span> }
            </a>
            <a href="/security" class="bk-admin-sidebar-item @(IsActive("security") ? "active" : "")">
                <span class="bk-admin-sidebar-item-icon"><span class="material-icons-round" style="font-size:20px;">shield</span></span>
                @if (!_collapsed) { <span class="bk-admin-sidebar-item-text">Security & Audit</span> }
            </a>
            <a href="/billing" class="bk-admin-sidebar-item @(IsActive("billing") ? "active" : "")">
                <span class="bk-admin-sidebar-item-icon"><span class="material-icons-round" style="font-size:20px;">receipt_long</span></span>
                @if (!_collapsed) { <span class="bk-admin-sidebar-item-text">Billing</span> }
            </a>
        </nav>

        <div class="bk-admin-sidebar-footer">
            @if (!_collapsed)
            {
                <button class="bk-theme-toggle @(_isDark ? "dark" : "")" onclick="ukuuToggleThemeAndUpdate(this); return false;" data-is-dark="@_isDark">
                    <span class="bk-theme-toggle-icon">
                        <span class="material-icons-round" style="font-size:20px;" id="ukuu-theme-icon">@(_isDark ? "dark_mode" : "light_mode")</span>
                    </span>
                    <span class="bk-theme-toggle-text" id="ukuu-theme-label">@(_isDark ? "Dark Mode" : "Light Mode")</span>
                    <span class="bk-theme-toggle-switch"></span>
                </button>
            }
            else
            {
                <button class="bk-theme-toggle" onclick="ukuuToggleThemeAndUpdate(this); return false;" data-is-dark="@_isDark" style="justify-content:center;padding:10px;">
                    <span class="bk-theme-toggle-icon">
                        <span class="material-icons-round" style="font-size:20px;" id="ukuu-theme-icon">@(_isDark ? "dark_mode" : "light_mode")</span>
                    </span>
                </button>
            }

            <a href="/settings" class="bk-admin-sidebar-user" style="margin-bottom:4px;">
                <div class="bk-admin-sidebar-user-avatar">@_userInitials</div>
                @if (!_collapsed)
                {
                    <div style="overflow:hidden;flex:1;min-width:0;">
                        <div class="bk-admin-sidebar-user-name">@_userName</div>
                        <div class="bk-admin-sidebar-user-role">@_userRole</div>
                    </div>
                }
            </a>

            @if (!_collapsed)
            {
                <a href="/logout" class="bk-logout-btn">
                    <span class="bk-logout-btn-icon">
                        <span class="material-icons-round" style="font-size:20px;">logout</span>
                    </span>
                    <span>Sign Out</span>
                </a>
            }
            else
            {
                <a href="/logout" class="bk-logout-btn" style="justify-content:center;padding:10px;" title="Sign Out">
                    <span class="bk-logout-btn-icon">
                        <span class="material-icons-round" style="font-size:20px;">logout</span>
                    </span>
                </a>
            }
        </div>
    </div>

    <div class="bk-admin-main @(_collapsed ? "collapsed" : "")">
        <header class="bk-admin-topbar">
            <button class="bk-admin-topbar-toggle" onclick="ukuuToggleSidebar()" aria-label="Open menu">
                <span class="material-icons-round" style="font-size:22px;">menu</span>
            </button>

            @* Mobile brand (visible < 1024px) — replaces the desktop search bar *@
            <a href="/dashboard" class="bk-admin-topbar-mobile-brand bk-mobile-only">
                <div class="bk-admin-topbar-mobile-brand-logo">U</div>
                <span>UKUU HR</span>
            </a>

            <div class="bk-admin-topbar-search bk-desktop-only">
                <span class="bk-admin-topbar-search-icon">
                    <span class="material-icons-round" style="font-size:20px;">search</span>
                </span>
                <input type="text" placeholder="Search employees, payroll, leave..." />
            </div>

            <div style="flex:1"></div>

            <a href="/health" class="bk-admin-topbar-icon-btn" title="System status" aria-label="System status">
                <span class="material-icons-round" style="font-size:18px;">cloud_done</span>
            </a>
            <button class="bk-admin-topbar-icon-btn" title="Notifications" aria-label="Notifications">
                <span class="material-icons-round" style="font-size:18px;">notifications</span>
                <span class="bk-dot"></span>
            </button>
            <a href="/settings" class="bk-admin-topbar-icon-btn bk-desktop-only" title="Help" aria-label="Help">
                <span class="material-icons-round" style="font-size:18px;">help_outline</span>
            </a>
            <a href="/settings" class="bk-admin-topbar-avatar" aria-label="Profile">@_userInitials</a>
        </header>

        @if (_mobileOpen)
        {
            <div onclick="ukuuCloseMobile()" style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:99;backdrop-filter:blur(2px);-webkit-backdrop-filter:blur(2px);cursor:pointer;"></div>
        }

        <main class="bk-admin-content bk-admin-fade-in">
            @Body
        </main>
    </div>

    @* ───── Mobile bottom navigation (thumb-friendly zone) ───── *@
    <nav class="bk-mobile-bottomnav" aria-label="Primary navigation">
        <div class="bk-mobile-bottomnav-items">
            <a href="/dashboard" class="bk-mobile-bottomnav-item @(IsActive("dashboard") ? "active" : "")" aria-label="Dashboard">
                <span class="material-icons-round">dashboard</span>
                <span>Home</span>
            </a>
            <a href="/employees" class="bk-mobile-bottomnav-item @(IsActive("employees") ? "active" : "")" aria-label="Employees">
                <span class="material-icons-round">groups</span>
                <span>Team</span>
            </a>
            <a href="/attendance-logs" class="bk-mobile-bottomnav-item @(IsActive("attendance-logs") || IsActive("attendance") || IsActive("attendance/search") ? "active" : "")" aria-label="Attendance">
                <span class="material-icons-round">schedule</span>
                <span>Attendance</span>
            </a>
            <a href="/leave" class="bk-mobile-bottomnav-item @(IsActive("leave") ? "active" : "")" aria-label="Leave">
                <span class="material-icons-round">event_available</span>
                <span>Leave</span>
            </a>

        </div>
    </nav>
</div>
