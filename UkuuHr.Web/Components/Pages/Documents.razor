@page "/documents"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@inject UkuuHrDbContext Db

<div class="bk-admin-fade-in">
    <div class="bk-admin-section-header">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">HR Documents · @_docs.Count files</div>
            <h1 class="bk-admin-h1">HR Documents</h1>
            <p class="bk-admin-sub">Manage employee files, contracts, payslips, and HR policies.</p>
        </div>
        <div class="bk-admin-actions">
            <button class="bk-btn bk-btn-secondary">
                <span class="material-icons-round" style="font-size:16px;">download</span>
                Export
            </button>
            <button class="bk-btn bk-btn-primary">
                <span class="material-icons-round" style="font-size:16px;">upload_file</span>
                Upload Document
            </button>
        </div>
    </div>

    <!-- Categories -->
    <div class="bk-admin-kpi-grid" style="grid-template-columns:repeat(auto-fit,minmax(180px,1fr));margin-bottom:24px;">
        @foreach (var cat in _categories)
        {
            <div class="bk-admin-kpi-card" style="padding:20px;cursor:pointer;">
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;">
                    <div class="bk-admin-kpi-icon @cat.Color" style="width:40px;height:40px;">
                        <span class="material-icons-round">@cat.Icon</span>
                    </div>
                    <div style="flex:1;">
                        <div style="font-size:13px;font-weight:700;color:var(--bk-ink);">@cat.Name</div>
                        <div style="font-size:11px;color:var(--bk-ink-3);">@cat.Count documents</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Documents table -->
    <div class="bk-admin-card" style="overflow:hidden;margin-bottom:24px;">
        <div class="bk-admin-card-header" style="display:flex;justify-content:space-between;align-items:center;">
            <div>
                <h3>All Documents</h3>
                <p>Recently uploaded files</p>
            </div>
            <div style="position:relative;">
                <input type="text" @bind="_search" placeholder="Search documents..." style="height:36px;border:1px solid var(--bk-line);border-radius:999px;background:rgba(255,255,255,0.74);padding:0 12px 0 36px;font-family:inherit;font-size:13px;outline:none;width:280px;" />
                <span class="material-icons-round" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--bk-ink-3);font-size:18px;">search</span>
            </div>
        </div>
        <table class="bk-admin-table">
            <thead>
                <tr>
                    <th>Document</th>
                    <th>Employee</th>
                    <th>Category</th>
                    <th>Size</th>
                    <th>Uploaded By</th>
                    <th>Date</th>
                    <th style="text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in _filteredDocs)
                {
                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:10px;">
                                <div style="width:32px;height:32px;border-radius:8px;background:rgba(232,93,117,0.12);color:var(--bk-accent-4);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;">@(d.Type == DocumentType.Pdf ? "PDF" : d.Type == DocumentType.Image ? "IMG" : d.Type == DocumentType.Excel ? "XLS" : d.Type == DocumentType.Word ? "DOC" : "FILE")</div>
                                <div>
                                    <div style="font-weight:600;font-size:13px;">@d.Name</div>
                                    <div style="font-size:11px;color:var(--bk-ink-3);">@d.Type</div>
                                </div>
                            </div>
                        </td>
                        <td>@GetEmployee(d.EmployeeId)</td>
                        <td><span class="bk-admin-pill pending" style="background:rgba(108,99,255,0.12);color:var(--bk-accent-2);">@d.Category</span></td>
                        <td style="font-family:'JetBrains Mono',monospace;font-size:12px;">@d.FormattedSize</td>
                        <td style="font-size:12px;">@(d.UploadedByName ?? "—")</td>
                        <td style="font-size:12px;color:var(--bk-ink-3);">@d.UploadedAt.ToString("dd MMM yyyy")</td>
                        <td style="text-align:right;">
                            <button class="bk-admin-topbar-icon-btn" style="width:32px;height:32px;border-radius:8px;display:inline-flex;" title="Download">
                                <span class="material-icons-round" style="font-size:16px;">download</span>
                            </button>
                            <button class="bk-admin-topbar-icon-btn" style="width:32px;height:32px;border-radius:8px;display:inline-flex;margin-left:4px;color:var(--bk-accent-4);border-color:var(--bk-accent-4);" title="Delete">
                                <span class="material-icons-round" style="font-size:16px;">delete</span>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!_filteredDocs.Any())
        {
            <div style="padding:48px 24px;text-align:center;color:var(--bk-ink-3);">
                <div style="width:64px;height:64px;margin:0 auto 16px;background:var(--bk-muted);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                    <span class="material-icons-round" style="font-size:32px;color:var(--bk-ink-3);">folder_off</span>
                </div>
                <p style="font-size:13px;">No documents uploaded yet.</p>
            </div>
        }
    </div>

    <!-- Policies -->
    <div class="bk-admin-card" style="overflow:hidden;">
        <div class="bk-admin-card-header">
            <div>
                <h3>Organization Policies</h3>
                <p>HR-wide policy documents available to all employees</p>
            </div>
        </div>
        <div class="bk-admin-card-content" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:12px;">
            @foreach (var policy in _policies)
            {
                <div style="display:flex;align-items:center;gap:12px;padding:14px;border:1px solid var(--bk-line);border-radius:10px;">
                    <div class="bk-admin-avatar" style="width:36px;height:36px;font-size:14px;">
                        <span class="material-icons-round" style="font-size:18px;">description</span>
                    </div>
                    <div style="flex:1;min-width:0;">
                        <div style="font-weight:600;font-size:13px;color:var(--bk-ink);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@policy.Title</div>
                        <div style="font-size:11px;color:var(--bk-ink-3);">@(policy.Description?.Length > 60 ? policy.Description[..60] + "..." : policy.Description)</div>
                    </div>
                    <button class="bk-admin-topbar-icon-btn" style="width:32px;height:32px;border-radius:8px;" title="Download">
                        <span class="material-icons-round" style="font-size:16px;">download</span>
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<EmployeeDocument> _docs = new();
    private List<HrPolicy> _policies = new();
    private List<Employee> _employees = new();
    private string _search = string.Empty;
    private int _orgId;

    private IEnumerable<EmployeeDocument> _filteredDocs => _docs.Where(d =>
        string.IsNullOrWhiteSpace(_search) || d.Name.Contains(_search, StringComparison.OrdinalIgnoreCase));

    private List<(string Name, string Icon, string Color, int Count)> _categories = new();

    protected override async Task OnInitializedAsync()
    {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        _orgId = org.Id;
        _docs = await Db.EmployeeDocuments.Where(d => d.OrganizationId == _orgId).OrderByDescending(d => d.UploadedAt).ToListAsync();
        _policies = await Db.HrPolicies.Where(p => p.OrganizationId == _orgId).OrderByDescending(p => p.PublishedAt).ToListAsync();
        _employees = await Db.Employees.Where(e => e.OrganizationId == _orgId).ToListAsync();
        _categories = new()
        {
            ("Contracts", "description", "ink", _docs.Count(d => d.Category == DocumentCategory.Contract)),
            ("Payslips", "receipt_long", "green", _docs.Count(d => d.Category == DocumentCategory.Payslip)),
            ("Identity", "badge", "blue", _docs.Count(d => d.Category == DocumentCategory.Identity)),
            ("Compliance", "verified_user", "gold", _docs.Count(d => d.Category == DocumentCategory.Compliance)),
            ("Policies", "gavel", "purple", _docs.Count(d => d.Category == DocumentCategory.Policy)),
            ("Other", "folder", "pink", _docs.Count(d => d.Category == DocumentCategory.Other))
        };
    }

    private string GetEmployee(int id) => _employees.FirstOrDefault(e => e.Id == id)?.FullName ?? "—";
}
