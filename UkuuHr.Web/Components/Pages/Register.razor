@page "/register"
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@layout UkuuHr.Components.Layout.PublicLayout
@attribute [AllowAnonymous]

<div class="bk-auth">
    @* ─────────── LEFT: Visual panel ─────────── *@
    <aside class="bk-auth-visual">
        <a href="/landing" class="bk-auth-brand" style="text-decoration:none;color:inherit;">
            <div class="bk-auth-brand-logo">U</div>
            <div>
                <div class="bk-auth-brand-name">UKUU HR</div>
                <div class="bk-auth-brand-tag">HRMS Platform</div>
            </div>
        </a>

        <div class="bk-auth-visual-mid">
            <span class="bk-auth-visual-eyebrow">Request access · 24h turnaround</span>
            <h1>Modernize your <span class="bk-word-outline">HR</span> operations end-to-end.</h1>
            <p class="bk-auth-visual-lead">Submit your details and our team will review and activate your workspace within 24 hours. Get employees, attendance, leave, payroll and statutory compliance — all in one platform.</p>
        </div>

        <div class="bk-auth-visual-foot">
            <div class="bk-auth-quote">
                <p>"The onboarding wizard alone saved us a week. New hires are added with banking and statutory details in 4 steps — payroll preview included."</p>
                <div class="bk-auth-quote-foot">
                    <div class="bk-auth-quote-avatar">U</div>
                    <div>
                        <strong>Ukuu HR</strong>
                        <div>HRMS Platform</div>
                    </div>
                </div>
            </div>

            <div class="bk-auth-visual-stats">
                <div><strong>4</strong><span>Step onboarding wizard</span></div>
                <div><strong>3</strong><span>Country payrolls</span></div>
                <div><strong>13</strong><span>FRS modules</span></div>
            </div>
        </div>
    </aside>

    @* ─────────── RIGHT: Form panel ─────────── *@
    <main class="bk-auth-form-side">
        <a href="/landing" class="bk-auth-back">
            <span class="material-icons-round" style="font-size:14px;">arrow_back</span>
            Back to home
        </a>

        <div class="bk-auth-card bk-fade-in" style="max-width:520px;">
            @* Mobile brand *@
            <a href="/landing" class="bk-auth-mobile-brand">
                <div class="bk-auth-brand-logo">U</div>
                <div>
                    <div class="bk-auth-brand-name" style="color:var(--bk-ink);">UKUU HR</div>
                    <div class="bk-auth-brand-tag">HRMS Platform</div>
                </div>
            </a>

            <div class="bk-auth-header">
                <span class="bk-auth-eyebrow">Request access</span>
                <h1 class="bk-auth-h1">Get your workspace</h1>
                <p class="bk-auth-sub">Submit your details — our team will review and activate your workspace within 24 hours.</p>
            </div>

            <form method="post" action="/auth/register" class="bk-form">
                <div class="bk-form-grid-2">
                    <div class="bk-field">
                        <label class="bk-label">First name</label>
                        <div class="bk-input-wrap">
                            <span class="material-icons-round bk-input-icon">person_outline</span>
                            <input type="text" name="FormData.FirstName" value="@FormData?.FirstName" class="bk-input" placeholder="First name" />
                        </div>
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Last name</label>
                        <div class="bk-input-wrap">
                            <span class="material-icons-round bk-input-icon">person_outline</span>
                            <input type="text" name="FormData.LastName" value="@FormData?.LastName" class="bk-input" placeholder="Chama" />
                        </div>
                    </div>
                </div>

                <div class="bk-field">
                    <label class="bk-label">Work email</label>
                    <div class="bk-input-wrap">
                        <span class="material-icons-round bk-input-icon">mail_outline</span>
                        <input type="email" name="FormData.Email" value="@FormData?.Email" class="bk-input" placeholder="you@company.com" />
                    </div>
                </div>

                <div class="bk-field">
                    <label class="bk-label">Phone number</label>
                    <div class="bk-input-wrap">
                        <span class="material-icons-round bk-input-icon">phone</span>
                        <input type="tel" name="FormData.Phone" value="@FormData?.Phone" class="bk-input" placeholder="+260 97 123 4567" />
                    </div>
                </div>

                <div class="bk-field">
                    <label class="bk-label">Organization name</label>
                    <div class="bk-input-wrap">
                        <span class="material-icons-round bk-input-icon">business</span>
                        <input type="text" name="FormData.Organization" value="@FormData?.Organization" class="bk-input" placeholder="Acme Ltd" />
                    </div>
                </div>

                <div class="bk-form-grid-2">
                    <div class="bk-field">
                        <label class="bk-label">Country</label>
                        <div class="bk-input-wrap">
                            <span class="material-icons-round bk-input-icon">public</span>
                            <select name="FormData.Country" class="bk-input">
                                <option value="Zambia" selected="@(FormData?.Country == "Zambia")">Zambia</option>
                                <option value="Tanzania" selected="@(FormData?.Country == "Tanzania")">Tanzania</option>
                                <option value="Malawi" selected="@(FormData?.Country == "Malawi")">Malawi</option>
                                <option value="Kenya" selected="@(FormData?.Country == "Kenya")">Kenya</option>
                                <option value="South Africa" selected="@(FormData?.Country == "South Africa")">South Africa</option>
                            </select>
                        </div>
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Industry</label>
                        <div class="bk-input-wrap">
                            <span class="material-icons-round bk-input-icon">factory</span>
                            <select name="FormData.Industry" class="bk-input">
                                <option value="">Select...</option>
                                <option value="Technology" selected="@(FormData?.Industry == "Technology")">Technology</option>
                                <option value="Finance" selected="@(FormData?.Industry == "Finance")">Finance</option>
                                <option value="Healthcare" selected="@(FormData?.Industry == "Healthcare")">Healthcare</option>
                                <option value="Education" selected="@(FormData?.Industry == "Education")">Education</option>
                                <option value="Manufacturing" selected="@(FormData?.Industry == "Manufacturing")">Manufacturing</option>
                                <option value="Other" selected="@(FormData?.Industry == "Other")">Other</option>
                            </select>
                        </div>
                    </div>
                </div>

                <label class="bk-check-row">
                    <input type="checkbox" name="_agree" value="true" class="bk-check" />
                    <span class="bk-check-label">I agree to the <a href="#" class="bk-auth-link">Terms of Service</a> and <a href="#" class="bk-auth-link">Privacy Policy</a>.</span>
                </label>

                <button type="submit" class="bk-auth-submit" id="bk-register-submit" disabled>
                    <span>Submit request</span>
                    <span class="material-icons-round" style="font-size:18px;">arrow_forward</span>
                </button>
            </form>

<script>
    // Enable submit button only when terms checkbox is checked
    (function() {
        var checkbox = document.querySelector('input[name="_agree"]');
        var submit = document.getElementById('bk-register-submit');
        if (checkbox && submit) {
            checkbox.addEventListener('change', function() {
                submit.disabled = !checkbox.checked;
            });
        }
    })();
</script>

            <div class="bk-auth-footer">
                Already have an account? <a href="/login">Sign in</a>
            </div>
        </div>
    </main>
</div>

@code {
    [SupplyParameterFromForm(FormName = "register")]
    public RegisterModel? FormData { get; set; }

    protected override void OnInitialized()
    {
        FormData ??= new RegisterModel();
    }

    private void Submit()
    {
        Snackbar.Add("Request submitted! Our team will contact you within 24 hours.", Severity.Success);
        Nav.NavigateTo("/login", forceLoad: true);
    }

    public class RegisterModel
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Phone { get; set; } = "";
        public string Organization { get; set; } = "";
        public string Country { get; set; } = "Zambia";
        public string Industry { get; set; } = "";
    }
}
