@page "/scheduling"
@using Microsoft.EntityFrameworkCore
@inject UkuuHrDbContext Db

<div class="bk-admin-fade-in">
    <div class="bk-admin-section-header">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">Shift Scheduling · @_shifts.Count active shifts</div>
            <h1 class="bk-admin-h1">Shift Scheduling</h1>
            <p class="bk-admin-sub">Assign shifts by department and configure rotation patterns.</p>
        </div>
        <div class="bk-admin-actions">
            <button class="bk-btn bk-btn-primary">
                <span class="material-icons-round" style="font-size:16px;">add</span>
                Assign Shift
            </button>
        </div>
    </div>

    <div class="bk-admin-kpi-grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));">
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon gold"><span class="material-icons-round">wb_sunny</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_shifts.Count(s => s.Shift == ShiftType.Morning)</div>
            <div class="bk-admin-kpi-label">Morning Shifts</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon purple"><span class="material-icons-round">brightness_4</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_shifts.Count(s => s.Shift == ShiftType.Night)</div>
            <div class="bk-admin-kpi-label">Night Shifts</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon blue"><span class="material-icons-round">brightness_5</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_shifts.Count(s => s.Shift == ShiftType.Mid)</div>
            <div class="bk-admin-kpi-label">Mid Shifts</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon green"><span class="material-icons-round">autorenew</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_shifts.Count(s => s.Schedule == ShiftSchedule.Rotating)</div>
            <div class="bk-admin-kpi-label">Rotating Schedules</div>
        </div>
    </div>

    <div class="bk-admin-kpi-grid" style="grid-template-columns:repeat(auto-fit,minmax(320px,1fr));">
        @foreach (var shift in _shifts)
        {
            <div class="bk-admin-card">
                <div class="bk-admin-card-header" style="display:flex;justify-content:space-between;align-items:center;">
                    <div>
                        <h3>@shift.Department</h3>
                        <p>@shift.ScheduleDisplay · @shift.TimeWindow</p>
                    </div>
                    <span class="bk-admin-pill @(shift.Shift == ShiftType.Morning ? "pending" : shift.Shift == ShiftType.Night ? "rejected" : "approved")" style="background:@(shift.Shift == ShiftType.Morning ? "rgba(216,156,17,0.12)" : shift.Shift == ShiftType.Night ? "rgba(108,99,255,0.12)" : "rgba(20,163,127,0.12)");color:@(shift.Shift == ShiftType.Morning ? "var(--bk-accent)" : shift.Shift == ShiftType.Night ? "var(--bk-accent-2)" : "var(--bk-accent-3)");">
                            @shift.ShiftDisplay
                        </span>
                </div>
                <div class="bk-admin-card-content">
                    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--bk-line);">
                        <span style="font-size:12px;color:var(--bk-ink-3);">Schedule</span>
                        <span style="font-size:13px;font-weight:600;">@shift.ScheduleDisplay</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--bk-line);">
                        <span style="font-size:12px;color:var(--bk-ink-3);">Time Window</span>
                        <span style="font-size:13px;font-weight:600;">@shift.TimeWindow</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--bk-line);">
                        <span style="font-size:12px;color:var(--bk-ink-3);">Days</span>
                        <span style="font-size:13px;font-weight:600;">@(GetDaysDisplay(shift.DaysOfWeekMask))</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:8px 0;">
                        <span style="font-size:12px;color:var(--bk-ink-3);">Assigned Employee</span>
                        <span style="font-size:13px;font-weight:600;color:var(--bk-accent);">@(GetEmployee(shift.EmployeeId) ?? "Department-wide")</span>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Weekly coverage matrix -->
    <div class="bk-admin-card" style="margin-top:24px;overflow:hidden;">
        <div class="bk-admin-card-header">
            <div>
                <h3>Weekly Coverage</h3>
                <p>Department × day-of-week shift matrix</p>
            </div>
        </div>
        <div style="overflow-x:auto;">
            <table class="bk-admin-table">
                <thead>
                    <tr>
                        <th>Department</th>
                        @foreach (var day in new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" })
                        {
                            <th style="text-align:center;">@day</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @{
                        var depts = _shifts.Select(s => s.Department).Distinct().OrderBy(d => d);
                    }
                    @foreach (var dept in depts)
                    {
                        <tr>
                            <td style="font-weight:600;">@dept</td>
                            @for (int d = 0; d < 7; d++)
                            {
                                var shifts = _shifts.Where(s => s.Department == dept && (s.DaysOfWeekMask & (1 << d)) != 0).ToList();
                                <td style="text-align:center;padding:8px;">
                                    @if (shifts.Any())
                                    {
                                        <div style="display:flex;flex-direction:column;gap:2px;align-items:center;">
                                            @foreach (var s in shifts)
                                            {
                                                <span style="display:inline-block;padding:2px 6px;border-radius:4px;font-size:10px;font-weight:700;background:@(s.Shift == ShiftType.Morning ? "rgba(216,156,17,0.12)" : s.Shift == ShiftType.Night ? "rgba(108,99,255,0.12)" : "rgba(20,163,127,0.12)");color:@(s.Shift == ShiftType.Morning ? "var(--bk-accent)" : s.Shift == ShiftType.Night ? "var(--bk-accent-2)" : "var(--bk-accent-3)");">@s.ShiftDisplay[..1]</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span style="color:var(--bk-ink-3);font-size:10px;">—</span>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<DepartmentShiftAssignment> _shifts = new();
    private List<Employee> _employees = new();
    private int _orgId;

    protected override async Task OnInitializedAsync()
    {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        _orgId = org.Id;
        _shifts = await Db.DepartmentShifts.Where(s => s.OrganizationId == _orgId).OrderBy(s => s.Department).ToListAsync();
        _employees = await Db.Employees.Where(e => e.OrganizationId == _orgId).ToListAsync();
    }

    private string GetEmployee(int? id) => id.HasValue ? _employees.FirstOrDefault(e => e.Id == id.Value)?.FullName ?? "—" : null;

    private string GetDaysDisplay(int mask)
    {
        var days = new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" };
        var active = new List<string>();
        for (int i = 0; i < 7; i++) if ((mask & (1 << i)) != 0) active.Add(days[i]);
        return string.Join(", ", active);
    }
}
