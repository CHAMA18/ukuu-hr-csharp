@page "/scheduling"
@using Microsoft.EntityFrameworkCore
@inject UkuuHrDbContext Db

<div class="ukuu-fade-in">
    <div class="ukuu-section-header" style="display:flex;justify-content:space-between;align-items:flex-end;">
        <div>
            <h1>Shift Scheduling</h1>
            <p>Assign shifts by department and configure rotation patterns.</p>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Style="background:linear-gradient(135deg,#25163F 0%,#4A3C68 100%) !important;">Assign Shift</MudButton>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:20px;">
        @foreach (var shift in _shifts)
        {
            <div class="mud-card ukuu-card-hover">
                <div class="mud-card-header" style="display:flex;justify-content:space-between;align-items:center;">
                    <div>
                        <h3 style="font-size:16px;font-weight:700;margin-bottom:4px;">@shift.Department</h3>
                        <span class="ukuu-status-pill ukuu-status-active" style="background:@(shift.Shift == ShiftType.Morning ? "var(--ukuu-warning-bg)" : shift.Shift == ShiftType.Night ? "#1A0F30" : "var(--ukuu-info-bg)");color:@(shift.Shift == ShiftType.Morning ? "var(--ukuu-warning)" : shift.Shift == ShiftType.Night ? "#FCFBFF" : "var(--ukuu-info)");">
                            @shift.ShiftDisplay Shift
                        </span>
                    </div>
                    <MudIconButton Icon="@Icons.Material.Filled.MoreVert" />
                </div>
                <div class="mud-card-content">
                    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--ukuu-divider);">
                        <span style="font-size:12px;color:var(--ukuu-text-muted);">Schedule</span>
                        <span style="font-size:13px;font-weight:600;">@shift.ScheduleDisplay</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--ukuu-divider);">
                        <span style="font-size:12px;color:var(--ukuu-text-muted);">Time Window</span>
                        <span style="font-size:13px;font-weight:600;">@shift.TimeWindow</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--ukuu-divider);">
                        <span style="font-size:12px;color:var(--ukuu-text-muted);">Days</span>
                        <span style="font-size:13px;font-weight:600;">@(GetDaysDisplay(shift.DaysOfWeekMask))</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:8px 0;">
                        <span style="font-size:12px;color:var(--ukuu-text-muted);">Assigned Employee</span>
                        <span style="font-size:13px;font-weight:600;color:var(--ukuu-ink);">@(GetEmployee(shift.EmployeeId) ?? "Department-wide")</span>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Weekly schedule visual -->
    <div class="mud-card" style="margin-top:24px;overflow:hidden;">
        <div class="mud-card-header">
            <h3 style="font-size:16px;font-weight:700;margin-bottom:2px;">Weekly Coverage</h3>
            <p style="font-size:12px;color:var(--ukuu-text-muted);margin:0;">Department × day-of-week shift matrix</p>
        </div>
        <div class="mud-card-content" style="overflow-x:auto;padding:0 !important;">
            <table style="width:100%;border-collapse:collapse;font-size:12px;">
                <thead>
                    <tr style="background:var(--ukuu-surface-alt);">
                        <th style="text-align:left;padding:12px 20px;font-weight:600;text-transform:uppercase;font-size:11px;color:var(--ukuu-text-muted);">Department</th>
                        @foreach (var day in new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" })
                        {
                            <th style="padding:12px;font-weight:600;text-transform:uppercase;font-size:11px;color:var(--ukuu-text-muted);">@day</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @{
                        var depts = _shifts.Select(s => s.Department).Distinct().OrderBy(d => d);
                    }
                    @foreach (var dept in depts)
                    {
                        <tr style="border-bottom:1px solid var(--ukuu-divider);">
                            <td style="padding:14px 20px;font-weight:600;">@dept</td>
                            @for (int d = 0; d < 7; d++)
                            {
                                var shifts = _shifts.Where(s => s.Department == dept && (s.DaysOfWeekMask & (1 << d)) != 0).ToList();
                                <td style="padding:8px;text-align:center;">
                                    @if (shifts.Any())
                                    {
                                        <div style="display:flex;flex-direction:column;gap:2px;">
                                            @foreach (var s in shifts)
                                            {
                                                <span style="display:inline-block;padding:2px 6px;border-radius:6px;font-size:10px;font-weight:700;background:@(s.Shift == ShiftType.Morning ? "var(--ukuu-warning-bg)" : s.Shift == ShiftType.Night ? "#1A0F30" : "var(--ukuu-info-bg)");color:@(s.Shift == ShiftType.Morning ? "var(--ukuu-warning)" : s.Shift == ShiftType.Night ? "#FCFBFF" : "var(--ukuu-info)");">@s.ShiftDisplay[..1]</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span style="color:var(--ukuu-text-subtle);font-size:10px;">—</span>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<DepartmentShiftAssignment> _shifts = new();
    private List<Employee> _employees = new();
    private int _orgId;

    protected override async Task OnInitializedAsync()
    {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        _orgId = org.Id;
        _shifts = await Db.DepartmentShifts.Where(s => s.OrganizationId == _orgId).OrderBy(s => s.Department).ToListAsync();
        _employees = await Db.Employees.Where(e => e.OrganizationId == _orgId).ToListAsync();
    }

    private string GetEmployee(int? id) => id.HasValue ? _employees.FirstOrDefault(e => e.Id == id.Value)?.FullName ?? "—" : null;

    private string GetDaysDisplay(int mask)
    {
        var days = new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" };
        var active = new List<string>();
        for (int i = 0; i < 7; i++) if ((mask & (1 << i)) != 0) active.Add(days[i]);
        return string.Join(", ", active);
    }
}
