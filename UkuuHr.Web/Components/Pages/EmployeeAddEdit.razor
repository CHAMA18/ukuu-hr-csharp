                    <div class="bk-field">
                        <label class="bk-label">Department *</label>
                        <InputText class="bk-input" @bind-Value="_model.Department" placeholder="e.g. Engineering" />
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Employment Status</label>                            <InputSelect class="bk-input" @bind-Value="_model.Status">
                                <option value="@EmploymentStatus.Active">Active</option>
                                <option value="@EmploymentStatus.Probation">Probation</option>
                                <option value="@EmploymentStatus.Inactive">Inactive</option>
                                <option value="@EmploymentStatus.Terminated">Terminated</option>
                            </InputSelect>
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Contract Type</label>                            <InputSelect class="bk-input" @bind-Value="_model.ContractType">
                                <option value="Permanent">Permanent</option>
                                <option value="Fixed Term">Fixed Term</option>
                                <option value="Contract">Contract</option>
                            </InputSelect>
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Joining Date *</label>                            <InputDate class="bk-input" @bind-Value="_model.JoiningDate" />
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Contract End Date</label>                            <InputDate class="bk-input" @bind-Value="_model.ContractEndDate" />
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Reporting Manager</label>
                        <InputText class="bk-input" @bind-Value="_model.ReportingManagerName" placeholder="Manager's name" />
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Manager's Title</label>
                        <InputText class="bk-input" @bind-Value="_model.ReportingManagerTitle" placeholder="e.g. Head of Engineering" />
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Place of Work</label>
                        <InputText class="bk-input" @bind-Value="_model.PlaceOfWork" placeholder="e.g. Head Office, Lusaka" />
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Work Hours / Week</label>
                        <InputNumber class="bk-input" @bind-Value="_model.WorkHoursPerWeek" step="1" />
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Holiday Entitlement (days)</label>
                        <InputNumber class="bk-input" @bind-Value="_model.HolidayEntitlementDays" step="1" />
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Probation (months)</label>
                        <InputNumber class="bk-input" @bind-Value="_model.ProbationaryPeriodMonths" step="1" />
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Notice Period</label>
                        <InputText class="bk-input" @bind-Value="_model.TerminationNoticePeriod" placeholder="e.g. 1 month" />
                    </div>
                </div>
                <div class="bk-field" style="margin-top:16px;">
                    <label class="bk-label">Job Description Summary</label>
                    <InputTextArea class="bk-input" @bind-Value="_model.JobDescription" style="min-height:80px;" placeholder="Brief job description..." />
                </div>
            </div>
        </div>
    }

    @* ──────────────────────────────── Step 2: Banking & Pay ──────────────────────────────── *@
    @if (_currentStep == 2)
    {
        <div class="bk-admin-card">
            <div class="bk-admin-card-header">
                <h3>Compensation</h3>
                <p>Salary, allowances, and payment details.</p>
            </div>
            <div class="bk-admin-card-content">
                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:18px;">
                    <div class="bk-field">
                        <label class="bk-label">Basic Salary (monthly) *</label>
                        <div class="bk-input-wrap">
                            <span class="material-icons-round bk-input-icon">payments</span>
                            <InputNumber class="bk-input" style="padding-left:36px;" @bind-Value="_model.BasicSalary" step="100" />
                        </div>
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Hourly Rate</label>
                        <InputNumber class="bk-input" @bind-Value="_model.HourlyRate" step="0.5" />
                        <small style="color:var(--bk-ink-3);font-size:11px;">Auto-calculated if blank</small>
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Currency</label>                            <InputSelect class="bk-input" @bind-Value="_model.Currency">
                                <option value="ZMW">ZMW — Zambian Kwacha</option>
                                <option value="USD">USD — US Dollar</option>
                                <option value="TZS">TZS — Tanzanian Shilling</option>
                                <option value="MWK">MWK — Malawian Kwacha</option>
                            </InputSelect>
                    </div>
                </div>

                @* Allowances *@
                <div style="display:flex;justify-content:space-between;align-items:center;margin-top:24px;padding-top:20px;border-top:1px solid var(--bk-line);">
                    <div>
                        <h4 style="font-size:14px;font-weight:700;margin:0;">Allowances</h4>
                        <p style="font-size:12px;color:var(--bk-ink-3);margin:2px 0 0;">Housing, transport, and other recurring allowances.</p>
                    </div>
                    <button type="button" class="bk-btn bk-btn-secondary" style="font-size:12px;padding:6px 14px;" @onclick="AddAllowance">
                        <span class="material-icons-round" style="font-size:14px;">add</span>
                        Add Allowance
                    </button>
                </div>

                @if (!_model.Allowances.Any())
                {
                    <div style="padding:24px;text-align:center;color:var(--bk-ink-3);font-size:13px;">
                        <span class="material-icons-round" style="font-size:24px;vertical-align:middle;margin-right:6px;">add_card</span>
                        No allowances added yet.
                    </div>
                }
                else
                {
                    <div style="margin-top:12px;">
                        @foreach (var allowance in _model.Allowances)
                        {
                            <div style="display:grid;grid-template-columns:1fr 100px 120px 80px 40px;gap:8px;align-items:end;margin-bottom:10px;padding:12px;border:1px solid var(--bk-line);border-radius:8px;background:var(--bk-card-bg);">
                                <div class="bk-field" style="margin:0;">
                                    <label class="bk-label" style="font-size:10px;">Name</label>
                                    <InputText class="bk-input" @bind-Value="allowance.Name" placeholder="e.g. Housing" />
                                </div>
                                <div class="bk-field" style="margin:0;">
                                    <label class="bk-label" style="font-size:10px;">Amount</label>
                                    <InputNumber class="bk-input" @bind-Value="allowance.Amount" step="100" />
                                </div>
                                <div class="bk-field" style="margin:0;">
                                    <label class="bk-label" style="font-size:10px;">Type</label>
                                    <InputSelect class="bk-input" @bind-Value="allowance.Type">
                                        <option value="@AllowanceType.Fixed">Fixed</option>
                                        <option value="@AllowanceType.Percentage">%</option>
                                    </InputSelect>
                                </div>
                                <div class="bk-field" style="margin:0;">
                                    <label class="bk-label" style="font-size:10px;">Taxable</label>
                                    <div style="display:flex;align-items:center;justify-content:center;height:42px;">
                                        <input type="checkbox" checked="@allowance.Taxable" @onchange="e => { if (e.Value is bool b) allowance.Taxable = b; }" style="width:18px;height:18px;accent-color:var(--bk-accent);" />
                                    </div>
                                </div>
                                <button type="button" class="bk-btn bk-btn-secondary" style="padding:4px 8px;font-size:11px;color:var(--bk-error);margin-bottom:2px;" @onclick="() => _model.Allowances.Remove(allowance)">
                                    <span class="material-icons-round" style="font-size:14px;">delete</span>
                                </button>
                            </div>
                        }
                        <div style="display:flex;justify-content:space-between;padding:12px 0;margin-top:8px;border-top:1px solid var(--bk-line);font-weight:600;font-size:14px;">
                            <span>Total Allowances</span>
                            <span>@_model.DisplayCurrency @_model.TotalAllowances.ToString("N0")</span>
                        </div>
                        <div style="display:flex;justify-content:space-between;padding:8px 0;font-weight:800;font-size:16px;color:var(--bk-ink);">
                            <span>Gross Salary</span>
                            <span>@_model.DisplayCurrency @_model.GrossSalary.ToString("N0")</span>
                        </div>
                    </div>
                }

                @* Bank Account *@
                <div style="margin-top:24px;padding-top:20px;border-top:1px solid var(--bk-line);">
                    <h4 style="font-size:14px;font-weight:700;margin:0 0 4px;">Bank Account Details</h4>
                    <p style="font-size:12px;color:var(--bk-ink-3);margin:0 0 16px;">For salary disbursement.</p>
                    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:18px;">
                        <div class="bk-field">
                            <label class="bk-label">Beneficiary Name</label>
                            <InputText class="bk-input" @bind-Value="_model.BeneficiaryName" placeholder="Account holder name" />
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Bank Name</label>
                            <InputText class="bk-input" @bind-Value="_model.BankName" placeholder="e.g. Standard Chartered" />
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Branch</label>
                            <InputText class="bk-input" @bind-Value="_model.Branch" placeholder="Branch name" />
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Account Number</label>
                            <InputText class="bk-input" @bind-Value="_model.AccountNumber" placeholder="Account number" />
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">IBAN</label>
                            <InputText class="bk-input" @bind-Value="_model.IbanNumber" placeholder="IBAN" />
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">SWIFT/BIC</label>
                            <InputText class="bk-input" @bind-Value="_model.SwiftCode" placeholder="SWIFT code" />
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Routing Number</label>
                            <InputText class="bk-input" @bind-Value="_model.RoutingNumbers" placeholder="Routing number" />
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Mobile Money</label>
                            <InputText class="bk-input" @bind-Value="_model.MobileMoney" placeholder="Mobile money number" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ──────────────────────────────── Step 3: Tax & Statutory ──────────────────────────────── *@
    @if (_currentStep == 3)
    {
        <div class="bk-admin-card">
            <div class="bk-admin-card-header">
                <h3>Tax & Statutory</h3>
                <p>Compliance with local tax authorities (ZRA / NAPSA / NHIMA).</p>
            </div>
            <div class="bk-admin-card-content">
                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:18px;">
                    <div class="bk-field">
                        <label class="bk-label">TPIN (Taxpayer Identification)</label>
                        <InputText class="bk-input" @bind-Value="_model.Tpin" placeholder="e.g. 1001234567" />
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">NAPSA Number</label>
                        <InputText class="bk-input" @bind-Value="_model.NapsaNumber" placeholder="NAPSA contribution number" />
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">NHIMA / Health Insurance No.</label>
                        <InputText class="bk-input" @bind-Value="_model.HealthInsuranceNumber" placeholder="Health insurance number" />
                    </div>
                </div>
            </div>
        </div>

        @* ───── Live payroll preview ───── *@
        <div class="bk-admin-card" style="margin-top:20px;">
            <div class="bk-admin-card-header">
                <h3>Live Payroll Preview</h3>
                <p>Based on @(!string.IsNullOrEmpty(_model.Country) ? _model.Country : "Zambia") PAYE bands and statutory rates.</p>
            </div>
            <div class="bk-admin-card-content">
                @if (_preview != null)
                {
                    <div class="bk-admin-kpi-grid" style="grid-template-columns:repeat(auto-fit,minmax(140px,1fr));">
                        <div class="bk-admin-kpi-card">
                            <div class="bk-admin-kpi-value">@_preview.Gross.ToString("N0")</div>
                            <div class="bk-admin-kpi-label">Gross</div>
                        </div>
                        <div class="bk-admin-kpi-card">
                            <div class="bk-admin-kpi-value" style="color:var(--bk-warning);">@_preview.Napsa.ToString("N0")</div>
                            <div class="bk-admin-kpi-label">NAPSA</div>
                        </div>
                        <div class="bk-admin-kpi-card">
                            <div class="bk-admin-kpi-value" style="color:var(--bk-warning);">@_preview.Nhima.ToString("N0")</div>
                            <div class="bk-admin-kpi-label">NHIMA</div>
                        </div>
                        <div class="bk-admin-kpi-card">
                            <div class="bk-admin-kpi-value" style="color:var(--bk-error);">@_preview.Paye.ToString("N0")</div>
                            <div class="bk-admin-kpi-label">PAYE</div>
                        </div>
                        <div class="bk-admin-kpi-card" style="background:linear-gradient(135deg,#25163F 0%,#4A3C68 100%);color:#FCFBFF;">
                            <div class="bk-admin-kpi-value" style="color:#FCFBFF;">@_preview.Net.ToString("N0")</div>
                            <div class="bk-admin-kpi-label" style="color:rgba(252,251,255,0.6);">Net Pay</div>
                        </div>
                    </div>
                }
                else
                {
                    <div style="padding:20px;text-align:center;color:var(--bk-ink-3);font-size:13px;">
                        <span class="material-icons-round" style="font-size:24px;vertical-align:middle;margin-right:6px;">calculate</span>
                        Enter a basic salary in the Banking & Pay step to see a preview.
                    </div>
                }
            </div>
        </div>
    }

    @* ───── Navigation buttons ───── *@
    <div style="display:flex;justify-content:space-between;align-items:center;margin-top:24px;padding-top:16px;border-top:1px solid var(--bk-line);">
        <div>
            <a href="/employees" class="bk-btn bk-btn-secondary" style="text-decoration:none;">
                <span class="material-icons-round" style="font-size:16px;">close</span>
                Cancel
            </a>
        </div>
        <div style="display:flex;gap:8px;">
            @if (_currentStep > 0)
            {
                <a href="?step=@(_currentStep - 1)" class="bk-btn bk-btn-secondary">
                    <span class="material-icons-round" style="font-size:16px;">arrow_back</span>
                    Previous
                </a>
            }
            @if (_currentStep < _steps.Length - 1)
            {
                <a href="?step=@(_currentStep + 1)" class="bk-btn bk-btn-primary">
                    <span class="material-icons-round" style="font-size:16px;">arrow_forward</span>
                    Next: @_steps[_currentStep + 1]
                </a>
            }
            else
            {
                <button type="button" class="bk-btn bk-btn-primary" style="background:linear-gradient(135deg,var(--bk-success),#16A34A);" onclick="ukuuSaveEmployee(this, @(_isEdit ? "true" : "false"), @(_isEdit ? Id.ToString() : "0"));">
                    <span class="material-icons-round" style="font-size:16px;">check</span>
                    @(_isEdit ? "Save Changes" : "Create Employee")
                </button>
            }
        </div>
    </div>
    </EditForm>
</div>

@code {
    [Parameter] public int? Id { get; set; }
    private bool _isEdit => Id.HasValue && Id.Value > 0;
    private Employee _model = new();
    private int _currentStep = 0;
    private bool _isSaving;
    private string[] _steps = { "Personal Info", "Employment", "Banking & Pay", "Tax & Statutory" };
    private PayrollCalculation? _preview;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Read step from query string (?step=1) — works without Blazor circuit
            try
            {
                var uri = Nav.ToAbsoluteUri(Nav.Uri);
                var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
                var stepStr = query["step"];
                if (int.TryParse(stepStr, out var s) && s >= 0 && s < _steps.Length)
                    _currentStep = s;
            }
            catch { }

            var org = await Db.Organizations.FirstOrDefaultAsync();
            if (org == null) return;

            if (_isEdit)
            {
                var existing = await EmployeeSvc.GetAsync(org.Id, Id!.Value);
                if (existing != null)
                {
                    _model = existing;
                    RecomputePreview();
                }
            }
            else
            {
                _model.OrganizationId = org.Id;
                _model.Country = "Zambia";
                _model.Currency = "ZMW";
                _model.Status = EmploymentStatus.Active;
                _model.ContractType = "Permanent";
                _model.WorkHoursPerWeek = 40;
                _model.Allowances = new List<Allowance>();
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[EmployeeAddEdit] Failed to load: {ex.Message}");
            Snackbar.Add("Failed to load employee data.", Severity.Error);
        }
    }

    private void NextStep()
    {
        if (_currentStep < _steps.Length - 1)
        {
            _currentStep++;
            RecomputePreview();
        }
    }

    private void PreviousStep()
    {
        if (_currentStep > 0)
        {
            _currentStep--;
        }
    }

    private void GoToStep(int idx)
    {
        if (idx >= 0 && idx < _steps.Length)
        {
            _currentStep = idx;
            RecomputePreview();
        }
    }

    private void AddAllowance()
    {
        _model.Allowances.Add(new Allowance { Name = "", Amount = 0, Type = AllowanceType.Fixed, Taxable = true });
        RecomputePreview();
    }

    private void RecomputePreview()
    {
        if (_model.BasicSalary <= 0) { _preview = null; return; }
        var allowances = _model.Allowances.Select(a => new AllowanceInput
        {
            Name = a.Name, Amount = a.Amount,
            Type = a.Type == AllowanceType.Percentage ? AllowanceTypeInput.Percentage : AllowanceTypeInput.Fixed,
            Taxable = a.Taxable
        }).ToList();
        _preview = PayrollCalculator.Calculate(_model.BasicSalary, allowances, countryConfig: PayrollCountryConfig.Zambia());
    }

    private async Task Save()
    {
        try
        {
            _isSaving = true;
            RecomputePreview();
            var org = await Db.Organizations.FirstOrDefaultAsync();
            if (org == null) return;
            _model.OrganizationId = org.Id;

            if (_isEdit)
            {
                await EmployeeSvc.UpdateAsync(_model);
                Snackbar.Add("Employee updated successfully!", Severity.Success);
            }
            else
            {
                _model.CreatedAt = DateTime.UtcNow;
                await EmployeeSvc.CreateAsync(_model);
                Snackbar.Add($"{_model.FullName} added successfully!", Severity.Success);
            }
            Nav.NavigateTo("/employees");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }
}
