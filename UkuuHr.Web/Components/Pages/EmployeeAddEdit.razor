@page "/employees/add"
@attribute [Authorize]
@page "/employees/{Id:int}/edit"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using System.ComponentModel.DataAnnotations
@inject EmployeeService EmployeeSvc
@inject UkuuHrDbContext Db
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<div class="bk-admin-fade-in">
    <div class="bk-admin-section-header">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">Employees · @(_isEdit ? "Edit" : "Add New") Employee</div>
            <h1 class="bk-admin-h1">@(_isEdit ? "Edit Employee" : "Add New Employee")</h1>
            <p class="bk-admin-sub">
                Complete the four steps below to @(_isEdit ? "update the" : "onboard a new") employee.
                Fields marked with * are required.
            </p>
        </div>
        <div class="bk-admin-actions">
            <a href="/employees" class="bk-btn bk-btn-secondary">
                <span class="material-icons-round" style="font-size:16px;">arrow_back</span>
                All Employees
            </a>
        </div>
    </div>


    <form id="employee-form" method="post" action="/api/employees/save">

    @* ──────────────────────────────── Personal Info ──────────────────────────────── *@
            <div class="bk-admin-card">
                <div class="bk-admin-card-header">
                    <h3>Personal Information</h3>
                    <p>Employee identity and shift assignment.</p>
                </div>
                <div class="bk-admin-card-content">
                    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:18px;">
                        @* First Name *@
                        <div class="bk-field">
                            <label class="bk-label">First Name *</label>
                            <div class="bk-input-wrap">
                                <span class="material-icons-round bk-input-icon">person</span>
                                <input type="text" class="bk-input" style="padding-left:36px;" name="FirstName" value="@(_model.FirstName)" placeholder="First name"  />
                            </div>
                            
                        </div>

                        @* Last Name *@
                        <div class="bk-field">
                            <label class="bk-label">Last Name *</label>
                            <div class="bk-input-wrap">
                                <span class="material-icons-round bk-input-icon">person</span>
                                <input type="text" class="bk-input" style="padding-left:36px;" name="Surname" value="@(_model.Surname)" placeholder="Last name"  />
                            </div>
                            
                        </div>

                        @* Other Names *@
                        <div class="bk-field">
                            <label class="bk-label">Other Names</label>
                            <input type="text" class="bk-input" name="MiddleNames" value="@(_model.MiddleNames)" placeholder="Other / middle names"  />
                        </div>

                        @* Gender *@
                        <div class="bk-field">
                            <label class="bk-label">Gender</label>
                            <select class="bk-input" name="Gender">
                                <option value="">Select gender</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                                <option value="Prefer not to say">Prefer not to say</option>
                            </select>
                        </div>

                        @* Employee ID *@
                        <div class="bk-field">
                            <label class="bk-label">Employee ID *</label>
                            <div class="bk-input-wrap">
                                <span class="material-icons-round bk-input-icon">badge</span>
                                <input type="text" class="bk-input" style="padding-left:36px;" name="EmployeeCode" value="@(_model.EmployeeCode)" placeholder="e.g. EMP-001"  />
                            </div>
                        </div>

                        @* Payroll ID *@
                        <div class="bk-field">
                            <label class="bk-label">Payroll ID</label>
                            <div class="bk-input-wrap">
                                <span class="material-icons-round bk-input-icon">payments</span>
                                <input type="text" class="bk-input" style="padding-left:36px;" name="PayrollId" value="@(_model.PayrollId)" placeholder="e.g. PAY-001"  />
                            </div>
                        </div>

                        @* Assign to Shift *@
                        <div class="bk-field">
                            <label class="bk-label">Assign to Shift</label>
                            <select class="bk-input" name="ShiftId">
                                <option value="">No shift assigned</option>
                                @foreach (var shift in _availableShifts)
                                {
                                    <option value="@shift.Id">@shift.Name (@shift.StartTime.ToString(@"hh\:mm")–@shift.EndTime.ToString(@"hh\:mm"))</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            @* ───── Contact Details (optional) ───── *@
            <div class="bk-admin-card" style="margin-top:20px;">
                <div class="bk-admin-card-header">
                    <h3>Contact Details</h3>
                    <p>Phone and email for this employee.</p>
                </div>
                <div class="bk-admin-card-content">
                    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:18px;">
                        <div class="bk-field">
                            <label class="bk-label">Phone Number</label>
                            <div class="bk-input-wrap">
                                <span class="material-icons-round bk-input-icon">phone</span>
                                <input type="text" class="bk-input" style="padding-left:36px;" name="Phone" value="@(_model.Phone)" placeholder="+260 97 123 4567"  />
                            </div>
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Email Address</label>
                            <div class="bk-input-wrap">
                                <span class="material-icons-round bk-input-icon">mail</span>
                                <input type="text" class="bk-input" style="padding-left:36px;" name="Email" value="@(_model.Email)" placeholder="employee@company.com"  />
                            </div>
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Department</label>
                            <input type="text" class="bk-input" name="Department" value="@(_model.Department)" placeholder="e.g. Engineering"  />
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Job Title</label>
                            <input type="text" class="bk-input" name="JobTitle" value="@(_model.JobTitle)" placeholder="e.g. Software Engineer"  />
                        </div>
                    </div>
                </div>
            </div>


    @* ───── Navigation buttons ───── *
    <div style="display:flex;justify-content:space-between;align-items:center;margin-top:24px;padding-top:16px;border-top:1px solid var(--bk-line);">
        <div>
            <a href="/employees" class="bk-btn bk-btn-secondary" style="text-decoration:none;">
                <span class="material-icons-round" style="font-size:16px;">close</span>
                Cancel
            </a>
        </div>
        <div style="display:flex;gap:8px;">
            <button type="button" class="bk-btn bk-btn-primary" style="background:linear-gradient(135deg,var(--bk-success),#16A34A);" onclick="ukuuSaveEmployee(this, @(_isEdit ? "true" : "false"), @(_isEdit ? Id.ToString() : "0"));">
                <span class="material-icons-round" style="font-size:16px;">check</span>
                @(_isEdit ? "Save Changes" : "Create Employee")
            </button>
        </div>
    </div>
    </form>
</div>

@code {
    [Parameter] public int? Id { get; set; }
    private bool _isEdit => Id.HasValue && Id.Value > 0;
    private Employee _model = new();
    private int _currentStep = 0;
    private bool _isSaving;
    private string[] _steps = { "Personal Info" };

    private static string FormatDate(DateTime? date) => date?.ToString("yyyy-MM-dd") ?? "";
    private PayrollCalculation? _preview;
    private List<Shift> _availableShifts = new();
    private int? _selectedShiftId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Read step from query string (?step=1) — works without Blazor circuit
            try
            {
                var uri = Nav.ToAbsoluteUri(Nav.Uri);
                var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
                var stepStr = query["step"];
                if (int.TryParse(stepStr, out var s) && s >= 0 && s < _steps.Length)
                    _currentStep = s;
            }
            catch { }

            var org = await Db.Organizations.FirstOrDefaultAsync();
            if (org == null) return;

            // Load available shifts for the dropdown
            _availableShifts = await Db.Shifts
                .Where(s => s.OrganizationId == org.Id && s.IsActive)
                .OrderBy(s => s.Name)
                .ToListAsync();

            if (_isEdit)
            {
                var existing = await EmployeeSvc.GetAsync(org.Id, Id!.Value);
                if (existing != null)
                {
                    _model = existing;
                    RecomputePreview();
                    // Load existing shift assignment
                    var existingAssignment = await Db.EmployeeShiftAssignments
                        .Where(a => a.EmployeeId == existing.Id && a.IsActive)
                        .FirstOrDefaultAsync();
                    _selectedShiftId = existingAssignment?.ShiftId;
                }
            }
            else
            {
                _model.OrganizationId = org.Id;
                _model.Country = "Zambia";
                _model.Currency = "ZMW";
                _model.Status = EmploymentStatus.Active;
                _model.ContractType = "Permanent";
                _model.WorkHoursPerWeek = 40;
                _model.Allowances = new List<Allowance>();
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[EmployeeAddEdit] Failed to load: {ex.Message}");
            Snackbar.Add("Failed to load employee data.", Severity.Error);
        }
    }

    private void NextStep()
    {
        if (_currentStep < _steps.Length - 1)
        {
            _currentStep++;
            RecomputePreview();
        }
    }

    private void PreviousStep()
    {
        if (_currentStep > 0)
        {
            _currentStep--;
        }
    }

    private void GoToStep(int idx)
    {
        if (idx >= 0 && idx < _steps.Length)
        {
            _currentStep = idx;
            RecomputePreview();
        }
    }

    private void AddAllowance()
    {
        _model.Allowances.Add(new Allowance { Name = "", Amount = 0, Type = AllowanceType.Fixed, Taxable = true });
        RecomputePreview();
    }

    private void RecomputePreview()
    {
        if (_model.BasicSalary <= 0) { _preview = null; return; }
        var allowances = _model.Allowances.Select(a => new AllowanceInput
        {
            Name = a.Name, Amount = a.Amount,
            Type = a.Type == AllowanceType.Percentage ? AllowanceTypeInput.Percentage : AllowanceTypeInput.Fixed,
            Taxable = a.Taxable
        }).ToList();
        _preview = PayrollCalculator.Calculate(_model.BasicSalary, allowances, countryConfig: PayrollCountryConfig.Zambia());
    }

    private async Task Save()
    {
        try
        {
            _isSaving = true;
            RecomputePreview();
            var org = await Db.Organizations.FirstOrDefaultAsync();
            if (org == null) return;
            _model.OrganizationId = org.Id;

            if (_isEdit)
            {
                await EmployeeSvc.UpdateAsync(_model);
                await SaveShiftAssignment(_model.Id);
                Snackbar.Add("Employee updated successfully!", Severity.Success);
            }
            else
            {
                _model.CreatedAt = DateTime.UtcNow;
                var created = await EmployeeSvc.CreateAsync(_model);
                await SaveShiftAssignment(created.Id);
                Snackbar.Add($"{_model.FullName} added successfully!", Severity.Success);
            }
            Nav.NavigateTo("/employees");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    /// <summary>Persist the selected shift assignment for this employee.</summary>
    private async Task SaveShiftAssignment(int employeeId)
    {
        if (_selectedShiftId is not int shiftId) return;

        // Deactivate any existing active assignment
        var existing = await Db.EmployeeShiftAssignments
            .Where(a => a.EmployeeId == employeeId && a.IsActive)
            .ToListAsync();
        foreach (var a in existing)
        {
            a.IsActive = false;
            a.EffectiveTo = DateTime.Today;
        }

        // Create new assignment
        Db.EmployeeShiftAssignments.Add(new EmployeeShiftAssignment
        {
            OrganizationId = _model.OrganizationId,
            EmployeeId = employeeId,
            ShiftId = shiftId,
            EffectiveFrom = DateTime.Today,
            IsPrimary = true,
            IsActive = true,
            CreatedAt = DateTime.UtcNow
        });
        await Db.SaveChangesAsync();
    }
}
