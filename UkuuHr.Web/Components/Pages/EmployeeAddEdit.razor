@page "/employees/add"
@page "/employees/{Id:int}/edit"
@using Microsoft.EntityFrameworkCore
@inject EmployeeService EmployeeSvc
@inject UkuuHrDbContext Db

<div class="ukuu-fade-in">
    <div class="ukuu-section-header" style="display:flex;justify-content:space-between;align-items:flex-end;">
        <div>
            <div style="margin-bottom:6px;">
                <a href="/employees" style="color:var(--ukuu-text-muted);text-decoration:none;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">← Back to Employees</a>
            </div>
            <h1>@(_isEdit ? "Edit Employee" : "Add New Employee")</h1>
            <p>Complete the four steps below to @(_isEdit ? "update the" : "onboard a new") employee.</p>
        </div>
    </div>

    <!-- Stepper -->
    <div class="mud-card" style="margin-bottom:24px;overflow:hidden;">
        <div style="display:flex;padding:24px 32px;gap:8px;">
            @for (var i = 0; i < _steps.Length; i++)
            {
                var idx = i;
                var stepNum = idx + 1;
                <div style="flex:1;display:flex;align-items:center;gap:12px;cursor:pointer;" @onclick="() => GoToStep(idx)">
                    <div style="width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;
                                background:@(_currentStep > idx ? "var(--ukuu-success)" : _currentStep == idx ? "var(--ukuu-ink)" : "var(--ukuu-surface-alt)");
                                color:@(_currentStep >= idx ? "white" : "var(--ukuu-text-muted)");">
                        @if (_currentStep > idx)
                        {
                            <span class="material-icons-round" style="font-size:18px;">check</span>
                        }
                        else
                        {
                            @stepNum
                        }
                    </div>
                    <div>
                        <div style="font-size:11px;color:var(--ukuu-text-subtle);text-transform:uppercase;letter-spacing:0.05em;font-weight:600;">Step @stepNum</div>
                        <div style="font-size:13px;font-weight:600;color:@(_currentStep == idx ? "var(--ukuu-ink)" : "var(--ukuu-text-muted)");">@_steps[idx]</div>
                    </div>
                </div>
                @if (idx < _steps.Length - 1)
                {
                    <div style="flex:0 0 24px;height:2px;background:var(--ukuu-divider);align-self:center;margin-top:18px;"></div>
                }
            }
        </div>
    </div>

    <EditForm Model="@_model" OnValidSubmit="@Save">
        <DataAnnotationsValidator />

        @if (_currentStep == 0)
        {
            <div class="mud-card">
                <div class="mud-card-header">
                    <h3 style="font-size:18px;font-weight:700;margin-bottom:2px;">Personal Information</h3>
                    <p style="font-size:13px;color:var(--ukuu-text-muted);margin:0;">Employee's identity and contact details.</p>
                </div>
                <div class="mud-card-content" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;">
                    <MudSelect @bind-Value="_model.Title" Label="Title" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Mr.")">Mr.</MudSelectItem>
                        <MudSelectItem Value="@("Ms.")">Ms.</MudSelectItem>
                        <MudSelectItem Value="@("Mrs.")">Mrs.</MudSelectItem>
                        <MudSelectItem Value="@("Dr.")">Dr.</MudSelectItem>
                        <MudSelectItem Value="@("Prof.")">Prof.</MudSelectItem>
                    </MudSelect>
                    <MudTextField @bind-Value="_model.FirstName" Label="First Name" Variant="Variant.Outlined" Required />
                    <MudTextField @bind-Value="_model.MiddleNames" Label="Middle Names" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.Surname" Label="Surname" Variant="Variant.Outlined" Required />
                    <MudSelect @bind-Value="_model.Gender" Label="Gender" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Male")">Male</MudSelectItem>
                        <MudSelectItem Value="@("Female")">Female</MudSelectItem>
                        <MudSelectItem Value="@("Other")">Other</MudSelectItem>
                    </MudSelect>
                    <MudSelect @bind-Value="_model.MaritalStatus" Label="Marital Status" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Single")">Single</MudSelectItem>
                        <MudSelectItem Value="@("Married")">Married</MudSelectItem>
                        <MudSelectItem Value="@("Divorced")">Divorced</MudSelectItem>
                        <MudSelectItem Value="@("Widowed")">Widowed</MudSelectItem>
                    </MudSelect>
                    <MudDatePicker @bind-Value="_model.DateOfBirth" Label="Date of Birth" Variant="Variant.Outlined" />
                    <MudSelect @bind-Value="_model.Nationality" Label="Nationality" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Zambian")">Zambian</MudSelectItem>
                        <MudSelectItem Value="@("Tanzanian")">Tanzanian</MudSelectItem>
                        <MudSelectItem Value="@("Malawian")">Malawian</MudSelectItem>
                        <MudSelectItem Value="@("South African")">South African</MudSelectItem>
                        <MudSelectItem Value="@("Kenyan")">Kenyan</MudSelectItem>
                    </MudSelect>
                    <MudTextField @bind-Value="_model.NationalIdentityNumber" Label="National ID (NRC)" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.PassportNumber" Label="Passport Number" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.Phone" Label="Phone Number" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.Email" Label="Email Address" Variant="Variant.Outlined" Required />
                    <MudTextField @bind-Value="_model.StreetAddress" Label="Street Address" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.City" Label="City" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.PostalCode" Label="Postal Code" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.Country" Label="Country" Variant="Variant.Outlined" />
                </div>
                <div class="mud-card-header" style="margin-top:16px;">
                    <h3 style="font-size:16px;font-weight:700;margin-bottom:2px;">Emergency Contact</h3>
                </div>
                <div class="mud-card-content" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;">
                    <MudTextField @bind-Value="_model.EmergencyContactName" Label="Full Name" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.EmergencyContactRelationship" Label="Relationship" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.EmergencyContactPhone" Label="Phone" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.EmergencyContactEmail" Label="Email" Variant="Variant.Outlined" />
                </div>
            </div>
        }
        else if (_currentStep == 1)
        {
            <div class="mud-card">
                <div class="mud-card-header">
                    <h3 style="font-size:18px;font-weight:700;margin-bottom:2px;">Employment Information</h3>
                    <p style="font-size:13px;color:var(--ukuu-text-muted);margin:0;">Job, contract, and reporting details.</p>
                </div>
                <div class="mud-card-content" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;">
                    <MudTextField @bind-Value="_model.EmployeeCode" Label="Employee Code" Variant="Variant.Outlined" Required />
                    <MudTextField @bind-Value="_model.JobTitle" Label="Job Title" Variant="Variant.Outlined" Required />
                    <MudTextField @bind-Value="_model.Department" Label="Department" Variant="Variant.Outlined" Required />
                    <MudSelect @bind-Value="_model.Status" Label="Employment Status" Variant="Variant.Outlined">
                        <MudSelectItem Value="@EmploymentStatus.Active">Active</MudSelectItem>
                        <MudSelectItem Value="@EmploymentStatus.Probation">Probation</MudSelectItem>
                        <MudSelectItem Value="@EmploymentStatus.Inactive">Inactive</MudSelectItem>
                        <MudSelectItem Value="@EmploymentStatus.Terminated">Terminated</MudSelectItem>
                    </MudSelect>
                    <MudSelect @bind-Value="_model.ContractType" Label="Contract Type" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Permanent")">Permanent</MudSelectItem>
                        <MudSelectItem Value="@("Fixed Term")">Fixed Term</MudSelectItem>
                        <MudSelectItem Value="@("Contract")">Contract</MudSelectItem>
                    </MudSelect>
                    <MudDatePicker @bind-Value="_model.JoiningDate" Label="Joining Date" Variant="Variant.Outlined" Required />
                    <MudDatePicker @bind-Value="_model.ContractEndDate" Label="Contract End Date" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.ReportingManagerName" Label="Reporting Manager" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.ReportingManagerTitle" Label="Manager's Title" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.PlaceOfWork" Label="Place of Work" Variant="Variant.Outlined" />
                    <MudNumericField @bind-Value="_model.WorkHoursPerWeek" Label="Work Hours/Week" Variant="Variant.Outlined" />
                    <MudNumericField @bind-Value="_model.HolidayEntitlementDays" Label="Holiday Entitlement (days)" Variant="Variant.Outlined" />
                    <MudNumericField @bind-Value="_model.ProbationaryPeriodMonths" Label="Probation (months)" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.TerminationNoticePeriod" Label="Notice Period" Variant="Variant.Outlined" />
                </div>
                <div class="mud-card-content">
                    <MudTextField @bind-Value="_model.JobDescription" Label="Job Description Summary" Variant="Variant.Outlined" Lines="4" />
                </div>
            </div>
        }
        else if (_currentStep == 2)
        {
            <div class="mud-card">
                <div class="mud-card-header">
                    <h3 style="font-size:18px;font-weight:700;margin-bottom:2px;">Banking & Payment</h3>
                    <p style="font-size:13px;color:var(--ukuu-text-muted);margin:0;">Compensation, allowances, and bank account details.</p>
                </div>
                <div class="mud-card-content" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;">
                    <MudNumericField @bind-Value="_model.BasicSalary" Label="Basic Salary (monthly)" Variant="Variant.Outlined" Required Min="0" />
                    <MudNumericField @bind-Value="_model.HourlyRate" Label="Hourly Rate (auto if blank)" Variant="Variant.Outlined" Min="0" />
                    <MudSelect @bind-Value="_model.Currency" Label="Currency" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("ZMW")">ZMW — Zambian Kwacha</MudSelectItem>
                        <MudSelectItem Value="@("USD")">USD — US Dollar</MudSelectItem>
                        <MudSelectItem Value="@("TZS")">TZS — Tanzanian Shilling</MudSelectItem>
                        <MudSelectItem Value="@("MWK")">MWK — Malawian Kwacha</MudSelectItem>
                    </MudSelect>
                </div>

                <div class="mud-card-header" style="margin-top:8px;">
                    <div style="display:flex;justify-content:space-between;align-items:center;width:100%;">
                        <h3 style="font-size:16px;font-weight:700;margin-bottom:2px;">Allowances</h3>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add" OnClick="@AddAllowance">Add Allowance</MudButton>
                    </div>
                </div>
                <div class="mud-card-content">
                    @if (!_model.Allowances.Any())
                    {
                        <div class="ukuu-empty" style="padding:24px;">
                            <p style="font-size:13px;">No allowances added yet. Click "Add Allowance" to add housing, transport, etc.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var allowance in _model.Allowances)
                        {
                            <div style="display:grid;grid-template-columns:1fr 100px 120px 80px 40px;gap:8px;align-items:end;margin-bottom:8px;">
                                <MudTextField @bind-Value="allowance.Name" Label="Name" Variant="Variant.Outlined" />
                                <MudNumericField @bind-Value="allowance.Amount" Label="Amount" Variant="Variant.Outlined" />
                                <MudSelect @bind-Value="allowance.Type" Label="Type" Variant="Variant.Outlined">
                                    <MudSelectItem Value="@AllowanceType.Fixed">Fixed</MudSelectItem>
                                    <MudSelectItem Value="@AllowanceType.Percentage">Percentage</MudSelectItem>
                                </MudSelect>
                                <MudCheckBox @bind-Value="allowance.Taxable" Label="Taxable" Color="Color.Primary" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => _model.Allowances.Remove(allowance))" />
                            </div>
                        }
                        <div style="display:flex;justify-content:space-between;padding:12px 0;margin-top:8px;border-top:1px solid var(--ukuu-divider);font-weight:700;">
                            <span>Total Allowances:</span>
                            <span>@_model.DisplayCurrency @_model.TotalAllowances.ToString("N0")</span>
                        </div>
                        <div style="display:flex;justify-content:space-between;padding:8px 0;font-weight:800;color:var(--ukuu-ink);">
                            <span>Gross Salary:</span>
                            <span>@_model.DisplayCurrency @_model.GrossSalary.ToString("N0")</span>
                        </div>
                    }
                </div>

                <div class="mud-card-header" style="margin-top:8px;">
                    <h3 style="font-size:16px;font-weight:700;margin-bottom:2px;">Bank Account Details</h3>
                </div>
                <div class="mud-card-content" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;">
                    <MudTextField @bind-Value="_model.BeneficiaryName" Label="Beneficiary Name" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.BankName" Label="Bank Name" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.Branch" Label="Branch" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.AccountNumber" Label="Account Number" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.IbanNumber" Label="IBAN" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.SwiftCode" Label="SWIFT/BIC" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.RoutingNumbers" Label="Routing Number" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.MobileMoney" Label="Mobile Money" Variant="Variant.Outlined" />
                </div>
            </div>
        }
        else if (_currentStep == 3)
        {
            <div class="mud-card">
                <div class="mud-card-header">
                    <h3 style="font-size:18px;font-weight:700;margin-bottom:2px;">Tax & Statutory</h3>
                    <p style="font-size:13px;color:var(--ukuu-text-muted);margin:0;">Compliance with local tax authorities (ZRA / NAPSA / NHIMA).</p>
                </div>
                <div class="mud-card-content" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;">
                    <MudTextField @bind-Value="_model.Tpin" Label="TPIN (Taxpayer Identification)" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.NapsaNumber" Label="NAPSA Number" Variant="Variant.Outlined" />
                    <MudTextField @bind-Value="_model.HealthInsuranceNumber" Label="NHIMA / Health Insurance No." Variant="Variant.Outlined" />
                </div>

                <!-- Live payroll preview -->
                <div class="mud-card-header" style="margin-top:8px;">
                    <h3 style="font-size:16px;font-weight:700;margin-bottom:2px;">Live Payroll Preview</h3>
                    <p style="font-size:13px;color:var(--ukuu-text-muted);margin:0;">Based on ZRA 2025 PAYE bands and statutory rates.</p>
                </div>
                <div class="mud-card-content">
                    @if (_preview != null)
                    {
                        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;">
                            <div style="text-align:center;padding:16px;background:var(--ukuu-surface-alt);border-radius:12px;">
                                <div style="font-size:11px;color:var(--ukuu-text-muted);font-weight:600;text-transform:uppercase;">Gross</div>
                                <div style="font-size:20px;font-weight:800;color:var(--ukuu-ink);margin-top:4px;">@_preview.Gross.ToString("N0")</div>
                            </div>
                            <div style="text-align:center;padding:16px;background:var(--ukuu-surface-alt);border-radius:12px;">
                                <div style="font-size:11px;color:var(--ukuu-text-muted);font-weight:600;text-transform:uppercase;">NAPSA</div>
                                <div style="font-size:20px;font-weight:800;color:var(--ukuu-warning);margin-top:4px;">-_preview.Napsa.ToString("N0")</div>
                            </div>
                            <div style="text-align:center;padding:16px;background:var(--ukuu-surface-alt);border-radius:12px;">
                                <div style="font-size:11px;color:var(--ukuu-text-muted);font-weight:600;text-transform:uppercase;">NHIMA</div>
                                <div style="font-size:20px;font-weight:800;color:var(--ukuu-warning);margin-top:4px;">-_preview.Nhima.ToString("N0")</div>
                            </div>
                            <div style="text-align:center;padding:16px;background:var(--ukuu-surface-alt);border-radius:12px;">
                                <div style="font-size:11px;color:var(--ukuu-text-muted);font-weight:600;text-transform:uppercase;">PAYE</div>
                                <div style="font-size:20px;font-weight:800;color:var(--ukuu-error);margin-top:4px;">-_preview.Paye.ToString("N0")</div>
                            </div>
                            <div style="text-align:center;padding:16px;background:linear-gradient(135deg,#25163F 0%,#4A3C68 100%);border-radius:12px;color:#FCFBFF;">
                                <div style="font-size:11px;color:rgba(252,251,255,0.6);font-weight:600;text-transform:uppercase;">Net Pay</div>
                                <div style="font-size:20px;font-weight:800;color:#FCFBFF;margin-top:4px;">@_preview.Net.ToString("N0")</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Footer actions -->
        <div style="display:flex;justify-content:space-between;margin-top:24px;">
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="@(() => Nav.NavigateTo("/employees"))">Cancel</MudButton>
            <div style="display:flex;gap:8px;">
                @if (_currentStep > 0)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => _currentStep--)">Previous</MudButton>
                }
                @if (_currentStep < _steps.Length - 1)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward" OnClick="@(() => _currentStep++)" Style="background:linear-gradient(135deg,#25163F 0%,#4A3C68 100%) !important;">Next Step</MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Success" ButtonType="ButtonType.Submit" StartIcon="@Icons.Material.Filled.Check">@(_isEdit ? "Save Changes" : "Create Employee")</MudButton>
                }
            </div>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public int? Id { get; set; }
    private bool _isEdit => Id.HasValue && Id.Value > 0;
    private Employee _model = new();
    private int _currentStep = 0;
    private string[] _steps = { "Personal Info", "Employment", "Banking & Pay", "Tax & Statutory" };
    private PayrollCalculation? _preview;

    protected override async Task OnInitializedAsync()
    {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;

        if (_isEdit)
        {
            var existing = await EmployeeSvc.GetAsync(org.Id, Id!.Value);
            if (existing != null)
            {
                _model = existing;
                RecomputePreview();
            }
        }
        else
        {
            _model.OrganizationId = org.Id;
            _model.Country = "Zambia";
            _model.Currency = "ZMW";
            _model.Status = EmploymentStatus.Active;
            _model.ContractType = "Permanent";
            _model.WorkHoursPerWeek = 40;
            _model.Allowances = new List<Allowance>();
        }
    }

    private void AddAllowance()
    {
        _model.Allowances.Add(new Allowance { Name = "", Amount = 0, Type = AllowanceType.Fixed, Taxable = true });
        RecomputePreview();
    }

    private void GoToStep(int idx)
    {
        if (idx >= 0 && idx < _steps.Length) _currentStep = idx;
        RecomputePreview();
    }

    private void RecomputePreview()
    {
        var allowances = _model.Allowances.Select(a => new AllowanceInput
        {
            Name = a.Name, Amount = a.Amount,
            Type = a.Type == AllowanceType.Percentage ? AllowanceTypeInput.Percentage : AllowanceTypeInput.Fixed,
            Taxable = a.Taxable
        }).ToList();

        _preview = PayrollCalculator.Calculate(_model.BasicSalary, allowances, countryConfig: PayrollCountryConfig.Zambia());
    }

    private async Task Save()
    {
        RecomputePreview();
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        _model.OrganizationId = org.Id;

        if (_isEdit)
        {
            await EmployeeSvc.UpdateAsync(_model);
            Snackbar.Add("Employee updated successfully!", Severity.Success);
        }
        else
        {
            _model.CreatedAt = DateTime.UtcNow;
            await EmployeeSvc.CreateAsync(_model);
            Snackbar.Add($"Employee {_model.FullName} added successfully!", Severity.Success);
        }
        Nav.NavigateTo("/employees");
    }
}
