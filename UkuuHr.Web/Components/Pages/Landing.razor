@page "/landing"
@layout UkuuHr.Components.Layout.PublicLayout
@attribute [AllowAnonymous]

<div class="bk-body">

    @* ─────────── HEADER ─────────── *@
    <header class="bk-header">
        <div class="bk-wide bk-nav">
            <a href="/landing" class="bk-brand">
                <div class="bk-brand-logo">U</div>
                <div>
                    <div class="bk-brand-name">UKUU HR</div>
                    <div class="bk-brand-tag">HRMS Platform</div>
                </div>
            </a>
            <nav class="bk-nav-links">
                <a href="#features">Features</a>
                <a href="#payroll">Payroll</a>
                <a href="#method">Method</a>
                <a href="#products">Modules</a>
                <a href="#cta">Get started</a>
            </nav>
            <div class="bk-nav-cta">
                <span class="bk-availability">Live demo available</span>
                <a class="bk-btn bk-btn-primary" href="/login">Sign in</a>
            </div>
        </div>
    </header>

    @* ─────────── HERO ─────────── *@
    <section class="bk-hero">
        <div class="bk-hero-bg"></div>
        <div class="bk-wide bk-hero-grid">
            <div class="bk-hero-copy bk-fade-in">
                <p class="bk-eyebrow">Remote HR platform · Africa</p>
                <h1 class="bk-h1">HR software that <span class="bk-word-outline">runs</span> your workforce.</h1>
                <p class="bk-lead">Ukuu HR is a complete platform for managing employees, attendance, leave, payroll and statutory compliance. Built for Zambian, Tanzanian and Malawian businesses — with the care of an in-house team and the speed of a focused product.</p>
                <div class="bk-btn-row">
                    <a class="bk-btn bk-btn-primary" href="/login">Open the demo
                        <span class="material-icons-round" style="font-size:18px;">arrow_forward</span>
                    </a>
                    <a class="bk-btn bk-btn-secondary" href="#features">Explore features</a>
                </div>
                <div class="bk-stats" style="margin-top:32px;padding:0;">
                    <div class="bk-stat"><strong>7</strong><span>User roles</span></div>
                    <div class="bk-stat"><strong>9</strong><span>Workspace modules</span></div>
                    <div class="bk-stat"><strong>3</strong><span>Country payrolls</span></div>
                    <div class="bk-stat"><strong>100%</strong><span>Compliance</span></div>
                </div>
            </div>

            <div class="bk-hero-visual bk-fade-in-delay-2">
                <div class="bk-artboard">
                    <span class="bk-corner-tr"></span>
                    <span class="bk-corner-bl"></span>
                    <div style="display:flex;align-items:center;justify-content:space-between;">
                        <div>
                            <div style="font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;color:var(--bk-ink-3);text-transform:uppercase;letter-spacing:0.08em;">Ukuu HR · Workspace</div>
                            <div class="bk-h3" style="font-size:18px;">Dashboard overview</div>
                        </div>
                        <div style="display:flex;gap:6px;">
                            <span style="width:8px;height:8px;border-radius:50%;background:var(--bk-accent-3);"></span>
                            <span style="width:8px;height:8px;border-radius:50%;background:var(--bk-accent);"></span>
                            <span style="width:8px;height:8px;border-radius:50%;background:var(--bk-accent-2);"></span>
                        </div>
                    </div>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                        <div style="padding:14px;background:var(--bk-muted);border-radius:8px;">
                            <div style="font-size:10px;color:var(--bk-ink-3);text-transform:uppercase;font-weight:700;letter-spacing:0.06em;">Employees</div>
                            <div style="font-size:24px;font-weight:800;color:var(--bk-ink);margin-top:4px;">8</div>
                            <div style="font-size:11px;color:var(--bk-accent-3);font-weight:600;">↑ +12%</div>
                        </div>
                        <div style="padding:14px;background:var(--bk-muted);border-radius:8px;">
                            <div style="font-size:10px;color:var(--bk-ink-3);text-transform:uppercase;font-weight:700;letter-spacing:0.06em;">Attendance</div>
                            <div style="font-size:24px;font-weight:800;color:var(--bk-ink);margin-top:4px;">87%</div>
                            <div style="font-size:11px;color:var(--bk-accent-3);font-weight:600;">↑ +4%</div>
                        </div>
                        <div style="padding:14px;background:var(--bk-muted);border-radius:8px;">
                            <div style="font-size:10px;color:var(--bk-ink-3);text-transform:uppercase;font-weight:700;letter-spacing:0.06em;">Pending Leave</div>
                            <div style="font-size:24px;font-weight:800;color:var(--bk-ink);margin-top:4px;">2</div>
                            <div style="font-size:11px;color:var(--bk-accent);font-weight:600;">Action needed</div>
                        </div>
                        <div style="padding:14px;background:linear-gradient(135deg,var(--bk-ink),#262626);border-radius:8px;color:white;">
                            <div style="font-size:10px;color:rgba(255,255,255,0.6);text-transform:uppercase;font-weight:700;letter-spacing:0.06em;">Payroll</div>
                            <div style="font-size:20px;font-weight:800;margin-top:4px;">ZMW 157K</div>
                            <div style="font-size:11px;color:var(--bk-accent);font-weight:600;">↑ +8%</div>
                        </div>
                    </div>

                    <div style="margin-top:8px;padding:14px;background:var(--bk-muted);border-radius:8px;">
                        <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--bk-ink-3);text-transform:uppercase;font-weight:700;letter-spacing:0.06em;margin-bottom:10px;">
                            <span>Workforce distribution</span><span>Headcount</span>
                        </div>
                        @foreach (var dept in new[] { ("Engineering", 2, "#d89c11"), ("Executive", 1, "#6c63ff"), ("Finance", 1, "#14a37f"), ("Sales", 1, "#e85d75") })
                        {
                            <div style="display:flex;align-items:center;gap:8px;font-size:11px;margin-bottom:5px;">
                                <span style="width:6px;height:6px;border-radius:50%;background:@dept.Item3;"></span>
                                <span style="flex:1;color:var(--bk-ink-2);">@dept.Item1</span>
                                <strong style="color:var(--bk-ink);">@dept.Item2</strong>
                            </div>
                        }
                    </div>
                </div>

                <div class="bk-floating-card top">
                    <span class="bk-card-kicker">Live payroll</span>
                    <h3 class="bk-h3" style="font-size:14px;margin-top:2px;">Net pay engine</h3>
                    <p class="bk-small" style="margin:4px 0 0 0;">ZRA 2025 PAYE bands computed live.</p>
                    <div class="bk-mini-metric">
                        <span class="accent">AI</span>
                        <p class="bk-small" style="margin:0;"><strong>21,092 ZMW</strong> net for 22K basic</p>
                    </div>
                </div>

                <div class="bk-floating-card bottom">
                    <span class="bk-card-kicker">Audit trail</span>
                    <h3 class="bk-h3" style="font-size:14px;margin-top:2px;">Every action logged</h3>
                    <p class="bk-small" style="margin:4px 0 0 0;">12 events captured this week.</p>
                    <div class="bk-mini-metric">
                        <span>01</span>
                        <p class="bk-small" style="margin:0;"><strong>Compliance.</strong> SOC2-ready.</p>
                    </div>
                </div>
            </div>
        </div>

        @* Logo strip *@
        <div class="bk-wide bk-logo-strip">
            <div class="bk-logo-strip-label">Built for African businesses</div>
            <div class="bk-logo-track">
                @foreach (var item in new[] { ("Zambia", "#d89c11"), ("Tanzania", "#14a37f"), ("Malawi", "#6c63ff"), ("Kenya", "#e85d75"), ("South Africa", "#0a0a0a"), ("ZRA 2025", "#d89c11") })
                {
                    <div class="bk-logo-item">
                        <span class="bk-logo-dot" style="background:@item.Item2;"></span>
                        @item.Item1
                    </div>
                }
            </div>
        </div>
    </section>

    @* ─────────── PROOF BAND ─────────── *@
    <section class="bk-section-tight">
        <div class="bk-container">
            <div class="bk-proof-band">
                <div>
                    <p class="bk-eyebrow">Proof before promises</p>
                    <h2 class="bk-h2">Modules that are already running, used and improving.</h2>
                    <p class="bk-lead">Ukuu HR is running inside HR teams across Zambia, Tanzania and Malawi. We build the workflows HR professionals use every day — onboarding, leave approvals, payroll runs.</p>
                    <div class="bk-proof-stats">
                        <div><strong>16+</strong><span>Workspace pages shipped</span></div>
                        <div><strong>9</strong><span>Core HR modules</span></div>
                        <div><strong>Live</strong><span>Demo running 24/7</span></div>
                    </div>
                </div>
                <div>
                    <div class="bk-discipline-card" style="margin-bottom:14px;">
                        <div class="bk-icon-box" style="background:var(--bk-accent);">01</div>
                        <h3 class="bk-h3">Built for African payroll</h3>
                        <p>ZRA 2025 PAYE bands, NAPSA capped at ZMW 9,870, NHIMA at 1%. Tanzania NSSF + SDL, Malawi MRA brackets — all country-compliant out of the box.</p>
                    </div>
                    <div class="bk-discipline-card">
                        <div class="bk-icon-box" style="background:var(--bk-accent-3);">02</div>
                        <h3 class="bk-h3">Multi-tenant RBAC</h3>
                        <p>Seven user roles — Super Admin, HR Admin, Finance & Payroll Admin, HR Operator, Finance & Payroll, Employee, Guest. Nine workspace modules gated per role.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* ─────────── STAGE GRID ─────────── *@
    <section class="bk-section" id="features">
        <div class="bk-container">
            <div class="bk-section-header center">
                <p class="bk-eyebrow">Where are you now?</p>
                <h2 class="bk-h2">Pick the workflow. We will show you the right next move.</h2>
                <p class="bk-lead">From onboarding a new hire to running country-compliant payroll — every stage has a dedicated module with the right next action surfaced clearly.</p>
            </div>
            <div class="bk-stage-grid">
                @foreach (var stage in _stages)
                {
                    <a class="bk-stage-card" href="@stage.Link">
                        <div>
                            <small>@stage.Number / @stage.Phase</small>
                            <h3 class="bk-h3">@stage.Title</h3>
                            <p>@stage.Description</p>
                        </div>
                        <span class="bk-btn-text">Open module</span>
                    </a>
                }
            </div>
        </div>
    </section>

    @* ─────────── DISCIPLINES ─────────── *@
    <section class="bk-section" style="background:var(--bk-muted);">
        <div class="bk-container">
            <div class="bk-section-header">
                <p class="bk-eyebrow">Capabilities</p>
                <h2 class="bk-h2">Everything a serious HR team needs, under one focused platform.</h2>
            </div>
            <div class="bk-discipline-grid">
                @foreach (var d in _capabilities)
                {
                    <article class="bk-discipline-card">
                        <div class="bk-icon-box" style="background:@d.Color;">@d.Number</div>
                        <h3 class="bk-h3">@d.Title</h3>
                        <p>@d.Description</p>
                        <div class="bk-tag-list">
                            @foreach (var t in d.Tags)
                            {
                                <span class="bk-tag">@t</span>
                            }
                        </div>
                    </article>
                }
            </div>
        </div>
    </section>

    @* ─────────── PAYROLL DARK BAND ─────────── *@
    <section class="bk-band-dark" id="payroll">
        <div class="bk-wide" style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;">
            <div>
                <p class="bk-eyebrow">Payroll engine</p>
                <h2 class="bk-h2" style="margin-top:12px;">ZRA 2025 compliant.<br/>Built for accuracy.</h2>
                <p class="bk-lead" style="margin-top:16px;">Progressive PAYE brackets, NAPSA capped at ZMW 9,870, NHIMA at 1% — all computed live in the browser with a transparent band-by-band breakdown. No more spreadsheets. No more surprises.</p>
                <div class="bk-btn-row" style="margin-top:28px;">
                    <a class="bk-btn bk-btn-accent" href="/payroll/calculator">Open the calculator</a>
                    <a class="bk-btn bk-btn-secondary" href="/payroll" style="background:rgba(255,255,255,0.08);color:white;border-color:rgba(255,255,255,0.18);">View payroll runs</a>
                </div>
            </div>
            <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:16px;padding:32px;backdrop-filter:blur(20px);">
                <div style="font-size:11px;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.08em;font-weight:700;margin-bottom:8px;">Live example</div>
                <div style="font-size:14px;color:rgba(255,255,255,0.8);margin-bottom:24px;">Senior Engineer · ZMW 22,000 basic + allowances</div>

                @foreach (var row in new[] { ("Basic Salary", "22,000", false), ("Allowances", "5,300", false) })
                {
                    <div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.08);font-size:13px;">
                        <span style="color:rgba(255,255,255,0.6);">@row.Item1</span>
                        <span style="font-weight:600;color:white;">@row.Item2</span>
                    </div>
                }
                <div style="display:flex;justify-content:space-between;padding:12px 0;border-bottom:2px solid rgba(255,255,255,0.15);font-size:14px;font-weight:700;color:white;">
                    <span>Gross</span><span>27,300</span>
                </div>
                @foreach (var row in new[] { ("NAPSA (5% capped)", "−987", "var(--bk-accent-4)"), ("NHIMA (1%)", "−273", "var(--bk-accent-4)"), ("PAYE (progressive)", "−4,948", "var(--bk-accent-4)") })
                {
                    <div class="bk-band-row" style="margin-top:8px;">
                        <div class="bk-band-row-icon">@row.Item1[0]</div>
                        <div style="flex:1;font-size:13px;color:rgba(255,255,255,0.85);">@row.Item1</div>
                        <div class="bk-band-row-value" style="color:@row.Item3;">@row.Item2</div>
                    </div>
                }
                <div style="display:flex;justify-content:space-between;padding:18px 0 0;font-size:20px;font-weight:800;color:white;">
                    <span>Net Pay</span>
                    <span style="color:var(--bk-accent);">ZMW 21,092</span>
                </div>
            </div>
        </div>
    </section>

    @* ─────────── METHOD ─────────── *@
    <section class="bk-section" id="method">
        <div class="bk-container bk-split">
            <div>
                <p class="bk-eyebrow">Our method</p>
                <h2 class="bk-h2" style="margin-top:12px;">The Ukuu HR Build Loop keeps strategy, design and code moving together.</h2>
                <p class="bk-lead" style="margin-top:16px;">We borrowed the best idea from high-performing product teams: do not separate thinking from shipping. Every HR workflow moves through diagnosis, design, build, launch and compound improvements — and the platform reflects that.</p>
                <div class="bk-btn-row" style="margin-top:28px;">
                    <a class="bk-btn bk-btn-primary" href="/dashboard">See the dashboard</a>
                    <a class="bk-btn bk-btn-secondary" href="/reports">View reports</a>
                </div>
            </div>
            <div class="bk-method-illustration">
                @foreach (var step in _methodSteps)
                {
                    <div class="bk-method-step">
                        <div class="bk-method-step-num @step.ColorClass">@step.Number</div>
                        <div>
                            <h4>@step.Title</h4>
                            <p>@step.Description</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    @* ─────────── PRODUCTS / MODULES ─────────── *@
    <section class="bk-section" id="products" style="background:var(--bk-muted);">
        <div class="bk-container">
            <div class="bk-section-header">
                <p class="bk-eyebrow">Built-in-house</p>
                <h2 class="bk-h2">We build HR modules that we use ourselves. That changes how we think.</h2>
                <p class="bk-lead">Because we operate the platform end-to-end, we care about the boring parts that make HR software survive: onboarding, approvals, audit logs, compliance, uptime and iteration.</p>
            </div>
            <div class="bk-product-grid">
                @foreach (var p in _modules)
                {
                    <a class="bk-product-card" href="@p.Link">
                        <header>
                            <div class="bk-product-id">
                                <div class="bk-product-icon" style="background:@p.Color;">@p.Icon</div>
                                <div>
                                    <h3 class="bk-h3" style="font-size:18px;">@p.Name</h3>
                                    <p class="bk-small">@p.Tagline</p>
                                </div>
                            </div>
                            <span style="font-size:18px;color:var(--bk-ink-3);">↗</span>
                        </header>
                        <p>@p.Description</p>
                    </a>
                }
            </div>
        </div>
    </section>

    @* ─────────── CASE GRID ─────────── *@
    <section class="bk-section">
        <div class="bk-container">
            <div class="bk-section-header center">
                <p class="bk-eyebrow">Selected use cases</p>
                <h2 class="bk-h2">Useful when HR has to be designed, built and launched as one system.</h2>
            </div>
            <div class="bk-case-grid">
                @foreach (var c in _useCases)
                {
                    <article class="bk-case-card">
                        <header>
                            <h3 class="bk-h3">@c.Title</h3>
                            <span class="bk-tag">@c.Tag</span>
                        </header>
                        <p>@c.Description</p>
                    </article>
                }
            </div>
        </div>
    </section>

    @* ─────────── CTA ─────────── *@
    <section class="bk-cta" id="cta">
        <div class="bk-container">
            <div class="bk-cta-card bk-fade-in">
                <p class="bk-eyebrow">Ready when you are</p>
                <h2 class="bk-h2" style="margin-top:12px;">Ready to modernize your HR?</h2>
                <p class="bk-lead">Sign in with the demo account and explore the full platform — no credit card required.</p>
                <div class="bk-btn-row" style="justify-content:center;">
                    <a class="bk-btn bk-btn-primary" href="/login">Open the demo
                        <span class="material-icons-round" style="font-size:18px;">arrow_forward</span>
                    </a>
                    <a class="bk-btn bk-btn-secondary" href="/register">Request access</a>
                </div>
                <div class="bk-credentials">
                    <span style="font-size:11px;color:var(--bk-ink-3);text-transform:uppercase;letter-spacing:0.08em;font-weight:700;">Demo:</span>
                    <strong>admin@ukuuhr.demo</strong>
                    <span style="color:var(--bk-ink-3);">·</span>
                    <code>Admin@2025</code>
                </div>
            </div>
        </div>
    </section>

    @* ─────────── FOOTER ─────────── *@
    <footer class="bk-footer">
        <div class="bk-wide">
            <div class="bk-footer-grid">
                <div>
                    <div class="bk-footer-brand">
                        <div class="bk-footer-brand-logo">U</div>
                        <span>UKUU HR</span>
                    </div>
                    <p style="margin:0 0 12px 0;max-width:380px;">A complete HR management system for African businesses. Employees, attendance, leave, payroll and statutory compliance — all in one platform.</p>
                    <p style="margin:0;font-size:12px;color:rgba(255,255,255,0.4);">Built with .NET 9, Blazor Server, EF Core and PostgreSQL.</p>
                </div>
                <div>
                    <h4>Platform</h4>
                    <ul>
                        <li><a href="/dashboard">Dashboard</a></li>
                        <li><a href="/employees">Employees</a></li>
                        <li><a href="/payroll">Payroll</a></li>
                        <li><a href="/payroll/calculator">Payroll Calculator</a></li>
                        <li><a href="/reports">Reports</a></li>
                    </ul>
                </div>
                <div>
                    <h4>Resources</h4>
                    <ul>
                        <li><a href="/login">Sign in</a></li>
                        <li><a href="/register">Request access</a></li>
                        <li><a href="https://github.com/CHAMA18/ukuu-hr-csharp">GitHub repo</a></li>
                        <li><a href="/health">Health status</a></li>
                    </ul>
                </div>
            </div>
            <div class="bk-footer-bottom">
                <span>© 2025 Ukuu HR. All rights reserved.</span>
                <span style="display:inline-flex;align-items:center;gap:8px;">
                    <span style="width:7px;height:7px;border-radius:50%;background:#26c56a;animation:bk-pulse 2.2s ease-in-out infinite;"></span>
                    All systems operational
                </span>
            </div>
        </div>
    </footer>
</div>

@code {
    private List<(string Number, string Phase, string Title, string Description, string Link)> _stages = new()
    {
        ("01", "Onboard", "Something new.", "Add new hires with a 4-step wizard: personal, employment, banking, statutory — with live payroll preview.", "/employees/add"),
        ("02", "Track", "Daily attendance.", "Clock-in/out, status filters, worked-hours computation. Manual entries and system records side by side.", "/attendance"),
        ("03", "Approve", "Leave requests.", "One-click approve or reject. Country-aware public holidays. Configurable leave types.", "/leave"),
        ("04", "Run", "Monthly payroll.", "Batch generation, approval workflow, per-employee payslips. ZRA 2025 PAYE bands.", "/payroll"),
        ("05", "Schedule", "Shift rotations.", "Department × shift assignments with day-of-week bitmask. Morning, mid, night.", "/scheduling")
    };

    private List<(string Number, string Title, string Description, string Color, string[] Tags)> _capabilities = new()
    {
        ("01", "Employee Management", "4-step onboarding wizard with personal, employment, banking and statutory details. Live payroll preview as you type.", "#0a0a0a", new[] { "Onboarding", "Profiles", "Banking" }),
        ("02", "Time & Attendance", "Daily timesheets, clock-in/out tracking, status filters (present, late, absent, on-leave, remote), worked-hours computation.", "#d89c11", new[] { "Clock-in", "Timesheets", "Filters" }),
        ("03", "Leave Management", "Approval workflow with one-click approve/reject, configurable leave types, and country-aware public holiday calendar.", "#6c63ff", new[] { "Approvals", "Holidays", "Types" }),
        ("04", "Payroll Engine", "ZRA 2025 PAYE bands, NAPSA cap at ZMW 9,870, NHIMA at 1%. Batch generation, approval workflow, per-employee payslips.", "#14a37f", new[] { "ZRA 2025", "NAPSA", "NHIMA" }),
        ("05", "Shift Scheduling", "Department × shift assignments with day-of-week bitmask and weekly coverage matrix. Morning, mid, and night shifts.", "#e85d75", new[] { "Shifts", "Rotation", "Matrix" }),
        ("06", "Security & Audit", "Configurable MFA, SSO, IP allowlist, session timeout. Full audit log of every user-management action.", "#0a0a0a", new[] { "MFA", "SSO", "Audit" })
    };

    private List<(string Number, string Title, string Description, string ColorClass)> _methodSteps = new()
    {
        ("01", "Diagnose", "Identify the HR workflow bottleneck — onboarding friction, payroll errors, leave approval delays.", "gold"),
        ("02", "Blueprint", "Design the workflow: forms, approvals, audit trail, country-specific compliance rules.", ""),
        ("03", "Build", "Implement in C# / Blazor with EF Core + PostgreSQL. MudBlazor UI components. Test against real data.", "green"),
        ("04", "Launch", "Deploy on Render with embedded PostgreSQL. Keep-alive service ensures zero downtime.", "purple"),
        ("05", "Compound", "Iterate based on usage analytics. Add new leave types, payroll bands, statutory rates per country.", "pink")
    };

    private List<(string Icon, string Name, string Tagline, string Description, string Color, string Link)> _modules = new()
    {
