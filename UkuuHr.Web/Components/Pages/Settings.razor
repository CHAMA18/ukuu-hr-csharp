@page "/settings"
@attribute [Authorize(Policy = "UserManagement")]
@using Microsoft.EntityFrameworkCore
@inject UkuuHrDbContext Db
@inject IHttpContextAccessor HttpAccessor
@inject ISnackbar Snackbar

<div class="bk-admin-fade-in">
    <div class="bk-admin-section-header">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">Settings · @_userName</div>
            <h1 class="bk-admin-h1">Settings</h1>
            <p class="bk-admin-sub">
                Manage your profile, organization details, payroll configuration, leave types,
                notification preferences, and user access. Select a section below.
            </p>
        </div>
    </div>

    @* ───── Quick-nav cards ───── *@
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:14px;margin-bottom:28px;">
        <a href="/settings/organization" class="bk-admin-card bk-admin-card-hover" style="padding:20px;display:flex;align-items:center;gap:14px;text-decoration:none;cursor:pointer;">
            <div style="width:44px;height:44px;border-radius:12px;background:rgba(37,99,235,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <span class="material-icons-round" style="color:var(--bk-info);font-size:24px;">business</span>
            </div>
            <div style="min-width:0;">
                <div style="font-size:14px;font-weight:700;color:var(--bk-ink);">Organization</div>
                <div style="font-size:12px;color:var(--bk-ink-3);margin-top:2px;">Company details, country, currency</div>
            </div>
        </a>
        <a href="/settings/payroll-config" class="bk-admin-card bk-admin-card-hover" style="padding:20px;display:flex;align-items:center;gap:14px;text-decoration:none;cursor:pointer;">
            <div style="width:44px;height:44px;border-radius:12px;background:rgba(22,163,74,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <span class="material-icons-round" style="color:var(--bk-success);font-size:24px;">payments</span>
            </div>
            <div style="min-width:0;">
                <div style="font-size:14px;font-weight:700;color:var(--bk-ink);">Payroll Config</div>
                <div style="font-size:12px;color:var(--bk-ink-3);margin-top:2px;">PAYE bands, NAPSA, NHIMA rates</div>
            </div>
        </a>
        <a href="/settings/leave-types" class="bk-admin-card bk-admin-card-hover" style="padding:20px;display:flex;align-items:center;gap:14px;text-decoration:none;cursor:pointer;">
            <div style="width:44px;height:44px;border-radius:12px;background:rgba(139,92,246,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <span class="material-icons-round" style="color:rgb(139,92,246);font-size:24px;">event_available</span>
            </div>
            <div style="min-width:0;">
                <div style="font-size:14px;font-weight:700;color:var(--bk-ink);">Leave Types</div>
                <div style="font-size:12px;color:var(--bk-ink-3);margin-top:2px;">Entitlements, carry forward, approval</div>
            </div>
        </a>
        <a href="/settings/notifications" class="bk-admin-card bk-admin-card-hover" style="padding:20px;display:flex;align-items:center;gap:14px;text-decoration:none;cursor:pointer;">
            <div style="width:44px;height:44px;border-radius:12px;background:rgba(245,158,11,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <span class="material-icons-round" style="color:var(--bk-warning);font-size:24px;">notifications</span>
            </div>
            <div style="min-width:0;">
                <div style="font-size:14px;font-weight:700;color:var(--bk-ink);">Notifications</div>
                <div style="font-size:12px;color:var(--bk-ink-3);margin-top:2px;">Delivery channels, event preferences</div>
            </div>
        </a>
        <a href="/settings/user-management" class="bk-admin-card bk-admin-card-hover" style="padding:20px;display:flex;align-items:center;gap:14px;text-decoration:none;cursor:pointer;">
            <div style="width:44px;height:44px;border-radius:12px;background:rgba(220,38,38,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <span class="material-icons-round" style="color:var(--bk-error);font-size:24px;">manage_accounts</span>
            </div>
            <div style="min-width:0;">
                <div style="font-size:14px;font-weight:700;color:var(--bk-ink);">User Management</div>
                <div style="font-size:12px;color:var(--bk-ink-3);margin-top:2px;">Roles, permissions, invites</div>
            </div>
        </a>
        <a href="/security" class="bk-admin-card bk-admin-card-hover" style="padding:20px;display:flex;align-items:center;gap:14px;text-decoration:none;cursor:pointer;">
            <div style="width:44px;height:44px;border-radius:12px;background:rgba(37,99,235,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <span class="material-icons-round" style="color:var(--bk-info);font-size:24px;">shield</span>
            </div>
            <div style="min-width:0;">
                <div style="font-size:14px;font-weight:700;color:var(--bk-ink);">Security & Audit</div>
                <div style="font-size:12px;color:var(--bk-ink-3);margin-top:2px;">Policies, audit logs, encryption</div>
            </div>
        </a>
    </div>

    @* ───── Profile section ───── *@
    <div class="bk-admin-card">
        <div class="bk-admin-card-header">
            <h3>Your Profile</h3>
            <p>Update your personal information displayed across the workspace.</p>
        </div>
        <div class="bk-admin-card-content">
            <EditForm Model="@_profile" OnValidSubmit="SaveProfile">
                <div style="display:flex;align-items:center;gap:20px;margin-bottom:24px;padding-bottom:20px;border-bottom:1px solid var(--bk-line);">
                    <div class="bk-admin-avatar" style="width:56px;height:56px;font-size:22px;background:var(--bk-accent);flex-shrink:0;">@_profile.Initials</div>
                    <div>
                        <div style="font-weight:700;font-size:16px;color:var(--bk-ink);">@_profile.FullName</div>
                        <div style="font-size:13px;color:var(--bk-ink-3);">@_profile.Email</div>
                    </div>
                </div>
                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px;">
                    <div class="bk-field">
                        <label class="bk-label">First Name</label>
                        <div class="bk-input-wrap">
                            <span class="material-icons-round bk-input-icon">person</span>
                            <InputText class="bk-input" style="padding-left:36px;" @bind-Value="_profile.FirstName" placeholder="First name" />
                        </div>
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Last Name</label>
                        <div class="bk-input-wrap">
                            <span class="material-icons-round bk-input-icon">person</span>
                            <InputText class="bk-input" style="padding-left:36px;" @bind-Value="_profile.LastName" placeholder="Last name" />
                        </div>
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Email</label>
                        <div class="bk-input-wrap">
                            <span class="material-icons-round bk-input-icon">mail</span>
                            <InputText class="bk-input" style="padding-left:36px;" @bind-Value="_profile.Email" placeholder="you@company.com" />
                        </div>
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Phone</label>
                        <div class="bk-input-wrap">
                            <span class="material-icons-round bk-input-icon">phone</span>
                            <InputText class="bk-input" style="padding-left:36px;" @bind-Value="_profile.Phone" placeholder="+260 97 123 4567" />
                        </div>
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Job Title</label>
                        <div class="bk-input-wrap">
                            <span class="material-icons-round bk-input-icon">work</span>
                            <InputText class="bk-input" style="padding-left:36px;" @bind-Value="_profile.JobTitle" placeholder="Job title" />
                        </div>
                    </div>
                    <div class="bk-field">
                        <label class="bk-label">Timezone</label>
                        <div class="bk-input-wrap">
                            <span class="material-icons-round bk-input-icon">schedule</span>
                            <InputSelect class="bk-input" style="padding-left:36px;" @bind-Value="_profile.Timezone">
                                <option value="Africa/Lusaka">Africa/Lusaka (UTC+2)</option>
                                <option value="Africa/Harare">Africa/Harare (UTC+2)</option>
                                <option value="Africa/Dar_es_Salaam">Africa/Dar_es_Salaam (UTC+3)</option>
                                <option value="Africa/Nairobi">Africa/Nairobi (UTC+3)</option>
                                <option value="Africa/Johannesburg">Africa/Johannesburg (UTC+2)</option>
                                <option value="Africa/Lagos">Africa/Lagos (UTC+1)</option>
                                <option value="Africa/Accra">Africa/Accra (UTC+0)</option>
                            </InputSelect>
                        </div>
                    </div>
                </div>
                <div style="display:flex;justify-content:flex-end;margin-top:20px;padding-top:16px;border-top:1px solid var(--bk-line);">
                    <button type="submit" class="bk-btn bk-btn-primary">
                        <span class="material-icons-round" style="font-size:16px;">save</span>
                        Save Changes
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private ProfileModel _profile = new();
    private string _userName = "User";
    private int _orgId;

    protected override async Task OnInitializedAsync()
    {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        _orgId = org.Id;

        // Load profile from the auth cookie
        var httpCtx = HttpAccessor.HttpContext;
        var nameClaim = httpCtx?.User?.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value;
        var emailClaim = httpCtx?.User?.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;

        if (!string.IsNullOrWhiteSpace(nameClaim))
        {
            _userName = nameClaim;
            var parts = nameClaim.Split(' ', 2, StringSplitOptions.RemoveEmptyEntries);
            _profile.FirstName = parts.Length > 0 ? parts[0] : "";
            _profile.LastName = parts.Length > 1 ? parts[1] : "";
        }
        if (!string.IsNullOrWhiteSpace(emailClaim)) _profile.Email = emailClaim;
    }

    private void SaveProfile()
    {
        // In production, this would update the UserAccount record.
        Snackbar.Add("Profile saved successfully.", Severity.Success);
    }

    private class ProfileModel
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Phone { get; set; } = "";
        public string JobTitle { get; set; } = "";
        public string Timezone { get; set; } = "Africa/Lusaka";

        public string FullName => $"{FirstName} {LastName}".Trim();
        public string Initials => $"{(!string.IsNullOrEmpty(FirstName) ? FirstName[..1] : "")}{(!string.IsNullOrEmpty(LastName) ? LastName[..1] : "")}".ToUpper();
    }
}
