@page "/devices"
@attribute [Authorize(Policy = "HrOrAdmin")]
@using Microsoft.EntityFrameworkCore
@using UkuuHr.Services.Devices
@inject DeviceSyncOrchestrator Orchestrator
@inject UkuuHrDbContext Db
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<div class="bk-admin-fade-in">
    <div class="bk-admin-section-header">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">Device Integration · @_devices.Count devices · @_vendorsSupported vendors supported</div>
            <h1 class="bk-admin-h1">Attendance Devices</h1>
            <p class="bk-admin-sub">
                Connect third-party time & attendance devices (FR-001). Supports 7 vendors × 4 integration modes
                (REST API, SDK, TCP/IP, CSV file). Sync automatically or on-demand.
            </p>
        </div>
        <div class="bk-admin-actions">
            <form method="post" action="/api/devices/sync-all" style="display:inline;">
                <button type="submit" class="bk-btn bk-btn-secondary">
                    <span class="material-icons-round" style="font-size:16px;">sync</span>
                    Sync All
                </button>
            </form>
            <a href="/devices/add" class="bk-btn bk-btn-primary" style="text-decoration:none;">
                <span class="material-icons-round" style="font-size:16px;">add</span>
                Add Device
            </a>
        </div>
    </div>

    @if (!_loaded)
    {
        <div class="bk-admin-card" style="text-align:center;padding:48px 24px;">
            <span class="material-icons-round" style="font-size:48px;color:var(--bk-ink-3);opacity:0.5;">fingerprint</span>
            <h3 style="margin-top:16px;">Loading devices…</h3>
        </div>
    }
    else if (_orgMissing)
    {
        <div class="bk-admin-card" style="text-align:center;padding:48px 24px;">
            <span class="material-icons-round" style="font-size:48px;color:var(--bk-warning);opacity:0.7;">error_outline</span>
            <h3 style="margin-top:16px;">No Organization Found</h3>
            <p style="color:var(--bk-ink-3);max-width:420px;margin:8px auto 0;font-size:14px;">
                Attendance devices require an organization record. Your workspace has no
                organization yet — create one to start connecting devices.
            </p>
            <div style="margin-top:20px;display:flex;gap:10px;justify-content:center;">
                <a href="/settings/organization" class="bk-btn bk-btn-secondary">
                    <span class="material-icons-round" style="font-size:16px;">business</span>
                    Organization Settings
                </a>
                <form method="post" action="/api/organization/seed" style="display:inline;">
                    <button type="submit" class="bk-btn bk-btn-primary">
                        <span class="material-icons-round" style="font-size:16px;">add_business</span>
                        Create Default Organization
                    </button>
                </form>
            </div>
        </div>
    }
    else
    {
        @* ───── Vendor matrix ───── *@
        <div class="bk-admin-card" style="margin-bottom:24px;">
        <div class="bk-admin-card-header">
            <h3>Supported Vendors (FR-001)</h3>
            <p>All 7 vendors × 4 integration modes. REST API + CSV are fully functional; SDK + TCP/IP require vendor binaries.</p>
        </div>
        <div class="bk-admin-card-content">
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;">
                @foreach (var v in _vendorMatrix)
                {
                    <div style="padding:14px;border:1px solid var(--bk-line);border-radius:12px;background:@(v.HasDevices ? "rgba(37,22,63,0.02)" : "transparent");transition:all 0.15s ease;">
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                            <div style="width:8px;height:24px;border-radius:2px;background:@v.Color;"></div>
                            <div style="font-weight:700;font-size:13px;color:var(--bk-ink);">@v.Name</div>
                        </div>
                        <div style="display:flex;flex-direction:column;gap:4px;font-size:11px;">
                            @foreach (var m in v.Modes)
                            {
                                <div style="display:flex;align-items:center;gap:6px;color:var(--bk-ink-2);">
                                    <span class="material-icons-round" style="font-size:12px;color:@(m.Supported ? "var(--bk-success)" : "var(--bk-ink-3)");">@(m.Supported ? "check_circle" : "radio_button_unchecked")</span>
                                    <span style="@(m.Supported ? "" : "color:var(--bk-ink-3);")">@m.Name</span>
                                </div>
                            }
                        </div>
                        @if (v.HasDevices)
                        {
                            <div style="margin-top:8px;padding-top:8px;border-top:1px solid var(--bk-line);font-size:11px;color:var(--bk-accent);font-weight:600;">
                                @v.DeviceCount device(s) connected
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    @* ───── KPI cards ───── *@
    <div class="bk-admin-kpi-grid" style="grid-template-columns:repeat(auto-fit,minmax(180px,1fr));">
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon"><span class="material-icons-round">devices</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_devices.Count</div>
            <div class="bk-admin-kpi-label">Total Devices</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon green"><span class="material-icons-round">cloud_done</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_devices.Count(d => d.LastSuccessfulSyncAt.HasValue)</div>
            <div class="bk-admin-kpi-label">Online</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon gold"><span class="material-icons-round">sync</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_devices.Sum(d => d.TotalEventsSynced)</div>
            <div class="bk-admin-kpi-label">Total Events Synced</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon pink"><span class="material-icons-round">error_outline</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_devices.Sum(d => d.TotalSyncErrors)</div>
            <div class="bk-admin-kpi-label">Sync Errors</div>
        </div>
    </div>

    @* ───── Devices list ───── *@
    <div class="bk-admin-kpi-grid" style="grid-template-columns:repeat(auto-fit,minmax(380px,1fr));">
        @foreach (var d in _devices)
        {
            <div class="bk-admin-card bk-admin-card-hover">
                <div class="bk-admin-card-header" style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;">
                    <div style="display:flex;gap:12px;align-items:center;flex:1;min-width:0;">
                        <div style="width:36px;height:36px;border-radius:8px;background:@(d.VendorColor);display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:13px;flex-shrink:0;">
                            @(d.Vendor.ToString()[..2].ToUpper())
                        </div>
                        <div style="min-width:0;flex:1;">
                            <h3 style="font-size:14px;font-weight:700;color:var(--bk-ink);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-bottom:2px;">@d.Name</h3>
                            <p style="font-size:11px;color:var(--bk-ink-3);margin:0;">@d.VendorDisplay · @d.ModeDisplay · @(d.Location ?? "No location")</p>
                        </div>
                    </div>
                    <span class="bk-admin-pill @DeviceStatusClass(d)" style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;">
                        @d.StatusDisplay
                    </span>
                </div>
                <div class="bk-admin-card-content" style="padding-top:12px;">
                    <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--bk-line);">
                        <span style="font-size:11px;color:var(--bk-ink-3);">Connection</span>
                        <span style="font-size:12px;font-weight:600;font-family:var(--ukuu-font-mono);">@(d.IpAddress ?? "—")@($":{d.Port ?? 80}")</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--bk-line);">
                        <span style="font-size:11px;color:var(--bk-ink-3);">Last sync</span>
                        <span style="font-size:12px;font-weight:600;">@d.LastSyncDisplay</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--bk-line);">
                        <span style="font-size:11px;color:var(--bk-ink-3);">Events synced</span>
                        <span style="font-size:12px;font-weight:600;color:var(--bk-accent);">@d.TotalEventsSynced</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--bk-line);">
                        <span style="font-size:11px;color:var(--bk-ink-3);">Auto-sync</span>
                        <span style="font-size:12px;font-weight:600;color:@(d.AutoSyncEnabled ? "var(--bk-success)" : "var(--bk-ink-3)");">@(d.AutoSyncEnabled ? $"Every {d.SyncIntervalMinutes} min" : "Off")</span>
                    </div>
                    @if (!string.IsNullOrEmpty(d.LastErrorMessage))
                    {
                        <div style="padding:8px 12px;margin-top:8px;background:rgba(220,38,38,0.06);border-radius:6px;font-size:11px;color:var(--bk-error);line-height:1.4;">
                            <span class="material-icons-round" style="font-size:12px;vertical-align:middle;">error</span>
                            @d.LastErrorMessage
                        </div>
                    }
                    <div style="display:flex;gap:6px;margin-top:12px;">
                        <form method="post" action="/api/devices/sync/@d.Id" style="flex:1;">
                            <button type="submit" class="bk-btn bk-btn-primary" style="width:100%;font-size:11px;padding:6px 10px;">
                                <span class="material-icons-round" style="font-size:13px;">sync</span>
                                Sync
                            </button>
                        </form>
                        <a href="/devices/@d.Id/edit" class="bk-btn bk-btn-secondary" style="font-size:11px;padding:6px 10px;text-decoration:none;">
                            <span class="material-icons-round" style="font-size:13px;">edit</span>
                        </a>
                        <form method="post" action="/api/devices/delete/@d.Id" style="display:inline;"
                              onsubmit="return confirm('Delete device @d.Name?');">
                            <button type="submit" class="bk-btn bk-btn-secondary" style="font-size:11px;padding:6px 10px;color:var(--bk-error);">
                                <span class="material-icons-round" style="font-size:13px;">delete</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
        @if (_devices.Count == 0)
        {
            <div class="bk-admin-card" style="grid-column:1/-1;text-align:center;padding:48px 24px;">
                <span class="material-icons-round" style="font-size:48px;color:var(--bk-ink-3);opacity:0.5;">devices</span>
                <h3 style="margin-top:16px;">No devices configured yet</h3>
                <p style="color:var(--bk-ink-3);margin:8px 0 20px;">Add your first attendance device to start syncing clock events.</p>
                <a href="/devices/add" class="bk-btn bk-btn-primary" style="text-decoration:none;">
                    <span class="material-icons-round" style="font-size:16px;">add</span>
                    Add First Device
                </a>
            </div>
        }
    </div>
    }
</div>



@code {
    private List<AttendanceDevice> _devices = new();
    private int _orgId;
    private bool _loaded;
    private bool _orgMissing;
    private bool _seeding;
    private const int _vendorsSupported = 7;

    // Vendor matrix data (computed once).
    private List<VendorMatrixItem> _vendorMatrix = new();

    // Dialog state.
    private bool _showDeviceDialog;
    private AttendanceDevice? _editingDevice;
    private AttendanceDevice _deviceForm = new();
    private string _csvFilePath = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Show success/error toasts from query string (after redirect from API endpoints)
            try
            {
                var uri = Nav.ToAbsoluteUri(Nav.Uri);
                var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
                if (query["saved"] == "1")
                    Snackbar.Add($"Device '{query["name"]}' saved successfully.", Severity.Success);
                else if (query["synced"] == "1")
                    Snackbar.Add($"Sync complete: {query["name"]}.", Severity.Success);
                else if (query["synced"] == "0")
                    Snackbar.Add($"Sync failed: {query["error"]}", Severity.Error);
                else if (query["deleted"] == "1")
                    Snackbar.Add($"Device '{query["name"]}' deleted.", Severity.Info);
            }
            catch { }

            var org = await Db.Organizations.FirstOrDefaultAsync();
            if (org == null)
            {
                _orgMissing = true;
                return;
            }
            _orgId = org.Id;
            await LoadData();
            BuildVendorMatrix();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[Devices] Failed to load: {ex.Message}");
            _orgMissing = true;
        }
        finally
        {
            _loaded = true;
        }
    }

    private async Task SeedOrg()
    {
        if (_seeding) return;
        _seeding = true;
        try
        {
            var org = new Organization
            {
                Name = "My Organization",
                Country = "Zambia",
                Currency = "ZMW",
                Industry = "Human Resources",
                OwnerUserId = "system",
                CreatedAt = DateTime.UtcNow
            };
            Db.Organizations.Add(org);
            await Db.SaveChangesAsync();

            Snackbar.Add("Default organization created. Refreshing…", Severity.Success);
            Nav.NavigateTo("/devices", forceLoad: true);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to create organization: {ex.Message}", Severity.Error);
        }
        finally
        {
            _seeding = false;
        }
    }

    private async Task LoadData()
    {
        _devices = await Db.AttendanceDevices.Where(d => d.OrganizationId == _orgId).OrderByDescending(d => d.CreatedAt).ToListAsync();
    }

    private void BuildVendorMatrix()
    {
        var vendors = Enum.GetValues<DeviceVendor>();
        var modes = Enum.GetValues<DeviceIntegrationMode>();
        _vendorMatrix = vendors.Select(v => new VendorMatrixItem
        {
            Name = v.ToString(),
            Color = GetVendorColor(v),
            Modes = modes.Select(m => new ModeMatrixItem
            {
                Name = m switch
                {
                    DeviceIntegrationMode.RestApi => "REST API",
                    DeviceIntegrationMode.Sdk => "SDK",
                    DeviceIntegrationMode.TcpIp => "TCP/IP",
                    DeviceIntegrationMode.CsvFile => "CSV File",
                    _ => m.ToString()
                },
                Supported = m == DeviceIntegrationMode.RestApi || m == DeviceIntegrationMode.CsvFile
            }).ToList(),
            HasDevices = _devices.Any(d => d.Vendor == v),
            DeviceCount = _devices.Count(d => d.Vendor == v)
        }).ToList();
    }

    private static string GetVendorColor(DeviceVendor v) => v switch
    {
        DeviceVendor.Hikvision => "#D92136",
        DeviceVendor.ZKTeco => "#0066B3",
        DeviceVendor.Suprema => "#00A651",
        DeviceVendor.Dahua => "#E2231A",
        DeviceVendor.Anviz => "#0080FF",
        DeviceVendor.Matrix => "#FF6600",
        DeviceVendor.eSSL => "#6E5F92",
        _ => "#6B7280"
    };

    private void OpenDeviceDialog(AttendanceDevice? existing)
    {
        _editingDevice = existing;
        if (existing != null)
        {
            _deviceForm = new AttendanceDevice
            {
                Id = existing.Id,
                Name = existing.Name,
                Vendor = existing.Vendor,
                Mode = existing.Mode,
                IpAddress = existing.IpAddress,
                Port = existing.Port,
                Username = existing.Username,
                Password = existing.Password,
                DeviceSerial = existing.DeviceSerial,
                Location = existing.Location,
                AutoSyncEnabled = existing.AutoSyncEnabled,
                SyncIntervalMinutes = existing.SyncIntervalMinutes,
                IsActive = existing.IsActive,
                ConnectionJson = existing.ConnectionJson
            };
            // Try to extract CSV path from ConnectionJson.
            if (!string.IsNullOrEmpty(existing.ConnectionJson))
            {
                try
                {
                    using var doc = System.Text.Json.JsonDocument.Parse(existing.ConnectionJson);
                    _csvFilePath = doc.RootElement.TryGetProperty("filePath", out var p) ? p.GetString() ?? "" : "";
                }
                catch { _csvFilePath = ""; }
            }
        }
        else
        {
            _deviceForm = new AttendanceDevice
            {
                Vendor = DeviceVendor.Hikvision,
                Mode = DeviceIntegrationMode.RestApi,
                Username = "admin",
                Port = 80,
                AutoSyncEnabled = true,
                SyncIntervalMinutes = 5,
                IsActive = true
            };
            _csvFilePath = "";
        }
        _showDeviceDialog = true;
    }

    private void CloseDeviceDialog() => _showDeviceDialog = false;

    private async Task SaveDevice()
    {
        try
        {
            // For CSV mode, store the file path in ConnectionJson.
            if (_deviceForm.Mode == DeviceIntegrationMode.CsvFile && !string.IsNullOrEmpty(_csvFilePath))
            {
                _deviceForm.ConnectionJson = $"{{\"filePath\":\"{_csvFilePath}\"}}";
            }

            if (_editingDevice != null && _editingDevice.Id > 0)
            {
                var existing = await Db.AttendanceDevices.FirstOrDefaultAsync(d => d.Id == _editingDevice.Id);
                if (existing != null)
                {
                    existing.Name = _deviceForm.Name;
                    existing.Vendor = _deviceForm.Vendor;
                    existing.Mode = _deviceForm.Mode;
                    existing.IpAddress = _deviceForm.IpAddress;
                    existing.Port = _deviceForm.Port;
                    existing.Username = _deviceForm.Username;
                    existing.Password = _deviceForm.Password;
                    existing.DeviceSerial = _deviceForm.DeviceSerial;
                    existing.Location = _deviceForm.Location;
                    existing.ConnectionJson = _deviceForm.ConnectionJson;
                    existing.AutoSyncEnabled = _deviceForm.AutoSyncEnabled;
                    existing.SyncIntervalMinutes = _deviceForm.SyncIntervalMinutes;
                    existing.UpdatedAt = DateTime.UtcNow;
                }
                Snackbar.Add($"Device '{_deviceForm.Name}' updated.", Severity.Success);
            }
            else
            {
                _deviceForm.OrganizationId = _orgId;
                _deviceForm.CreatedAt = DateTime.UtcNow;
                _deviceForm.CreatedByEmail = "admin@ukuuhr.demo";
                Db.AttendanceDevices.Add(_deviceForm);
                Snackbar.Add($"Device '{_deviceForm.Name}' added.", Severity.Success);
            }
            await Db.SaveChangesAsync();
            _showDeviceDialog = false;
            await LoadData();
            BuildVendorMatrix();
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task DeleteDevice(AttendanceDevice d)
    {
        Db.AttendanceDevices.Remove(d);
        await Db.SaveChangesAsync();
        Snackbar.Add($"Device '{d.Name}' removed.", Severity.Info);
        await LoadData();
        BuildVendorMatrix();
    }

    private async Task TestConnection(AttendanceDevice d)
    {
        Snackbar.Add($"Testing connection to {d.Name}...", Severity.Info);
        var (reachable, error) = await Orchestrator.PingAsync(_orgId, d.Id);
        if (reachable)
            Snackbar.Add($"✓ {d.Name} is reachable.", Severity.Success);
        else
            Snackbar.Add($"✗ {d.Name}: {error}", Severity.Error);
    }

    private async Task SyncDevice(AttendanceDevice d)
    {
        Snackbar.Add($"Syncing {d.Name}...", Severity.Info);
        var result = await Orchestrator.SyncDeviceAsync(_orgId, d.Id);
        if (result.Success)
            Snackbar.Add($"✓ {d.Name}: {result.EventsFetched} fetched, {result.EventsImported} imported, {result.DuplicatesSkipped} duplicates.", Severity.Success);
        else
            Snackbar.Add($"✗ {d.Name}: {result.ErrorMessage}", Severity.Error);
        await LoadData();
        BuildVendorMatrix();
    }

    private async Task SyncAll()
    {
        Snackbar.Add($"Syncing all active devices...", Severity.Info);
        var results = await Orchestrator.SyncAllDevicesAsync(_orgId);
        var ok = results.Count(r => r.Success);
        var fail = results.Count - ok;
        Snackbar.Add($"Sync complete: {ok} succeeded, {fail} failed.", ok > 0 ? Severity.Success : Severity.Warning);
        await LoadData();
    }

    private static string DeviceStatusClass(AttendanceDevice d) => d.StatusDisplay switch
    {
        "Online" => "approved",
        "Error" => "rejected",
        "Disabled" => "inactive",
        _ => "pending"
    };

    // ───── Helper classes ─────
    private sealed class VendorMatrixItem
    {
        public string Name { get; set; } = "";
        public string Color { get; set; } = "#6B7280";
        public List<ModeMatrixItem> Modes { get; set; } = new();
        public bool HasDevices { get; set; }
        public int DeviceCount { get; set; }
    }
    private sealed class ModeMatrixItem
    {
        public string Name { get; set; } = "";
        public bool Supported { get; set; }
    }
}
