@page "/settings/leave-types"
@attribute [Authorize(Policy = "UserManagement")]
@using Microsoft.EntityFrameworkCore
@inject UkuuHrDbContext Db
@inject ISnackbar Snackbar
@inject IHttpContextAccessor HttpAccessor

<div class="bk-admin-fade-in">
    <div class="bk-admin-section-header">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">Settings · Leave Types · @_leaveTypes.Count configured</div>
            <h1 class="bk-admin-h1">Leave Types</h1>
            <p class="bk-admin-sub">
                Configure leave categories, entitlement days, and policies. Each leave type defines
                how many days employees are entitled to per year, whether it's paid, requires approval,
                and can carry forward unused days.
            </p>
        </div>
        <div class="bk-admin-actions">
            <a href="/settings" class="bk-btn bk-btn-secondary">
                <span class="material-icons-round" style="font-size:16px;">arrow_back</span>
                All Settings
            </a>
            <button class="bk-btn bk-btn-primary" @onclick="() => OpenDialog(null)">
                <span class="material-icons-round" style="font-size:16px;">add</span>
                New Leave Type
            </button>
        </div>
    </div>

    @* ───── KPI cards ───── *@
    <div class="bk-admin-kpi-grid">
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon green"><span class="material-icons-round">check_circle</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_leaveTypes.Count(lt => lt.IsPaid)</div>
            <div class="bk-admin-kpi-label">Paid Leave Types</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon gold"><span class="material-icons-round">gavel</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_leaveTypes.Count(lt => lt.RequiresApproval)</div>
            <div class="bk-admin-kpi-label">Require Approval</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon blue"><span class="material-icons-round">forward</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_leaveTypes.Count(lt => lt.CarryForward)</div>
            <div class="bk-admin-kpi-label">Carry Forward</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon purple"><span class="material-icons-round">event_available</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_leaveTypes.Sum(lt => lt.DefaultDays)</div>
            <div class="bk-admin-kpi-label">Total Entitlement Days</div>
        </div>
    </div>

    @* ───── Leave types table ───── *@
    <div class="bk-admin-card" style="overflow:hidden;">
        <div style="overflow-x:auto;">
            <table class="bk-admin-table bk-mobile-card-view">
                <thead>
                    <tr>
                        <th>Leave Type</th>
                        <th>Default Days</th>
                        <th>Paid</th>
                        <th>Approval</th>
                        <th>Carry Forward</th>
                        <th>Max Carry</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lt in _leaveTypes)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <span style="width:12px;height:12px;border-radius:3px;background:@lt.Color;flex-shrink:0;"></span>
                                    <div>
                                        <div style="font-weight:600;color:var(--bk-ink);">@lt.Name</div>
                                        <div style="font-size:11px;color:var(--bk-ink-3);">Created @lt.CreatedAt.ToString("dd MMM yyyy")</div>
                                    </div>
                                </div>
                            </td>
                            <td><span style="font-weight:700;font-size:15px;">@lt.DefaultDays</span></td>
                            <td>
                                <span class="bk-admin-pill @(lt.IsPaid ? "active" : "inactive")" style="font-size:10px;">
                                    @(lt.IsPaid ? "Paid" : "Unpaid")
                                </span>
                            </td>
                            <td>
                                <span style="font-size:12px;color:var(--bk-ink-2);">
                                    @(lt.RequiresApproval ? "Required" : "Auto-approve")
                                </span>
                            </td>
                            <td>
                                <span style="font-size:12px;color:var(--bk-ink-2);">
                                    @(lt.CarryForward ? $"Yes" : "No")
                                </span>
                            </td>
                            <td>
                                <span style="font-size:12px;color:var(--bk-ink-2);">
                                    @(lt.CarryForward ? $"{lt.MaxCarryForwardDays ?? lt.DefaultDays} days" : "—")
                                </span>
                            </td>
                            <td>
                                <div style="display:flex;gap:4px;">
                                    <button class="bk-btn bk-btn-secondary" style="padding:4px 8px;font-size:11px;" @onclick="() => OpenDialog(lt)">
                                        <span class="material-icons-round" style="font-size:14px;">edit</span>
                                    </button>
                                    <button class="bk-btn bk-btn-secondary" style="padding:4px 8px;font-size:11px;color:var(--bk-error);" @onclick="() => DeleteLeaveType(lt)">
                                        <span class="material-icons-round" style="font-size:14px;">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (_leaveTypes.Count == 0)
                    {
                        <tr><td colspan="7" style="text-align:center;padding:48px;color:var(--bk-ink-3);">
                            <span class="material-icons-round" style="font-size:36px;color:var(--bk-ink-3);opacity:0.4;display:block;margin-bottom:12px;">event_available</span>
                            No leave types configured. Click "New Leave Type" to add one.
                        </td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* ───── Leave type dialog ───── *@
@if (_showDialog)
{
    <div class="bk-modal-backdrop" @onclick="CloseDialog">
        <div class="bk-modal" @onclick:stopPropagation style="max-width:520px;">
            <div class="bk-modal-header">
                <h3>@(_editing?.Id > 0 ? "Edit Leave Type" : "New Leave Type")</h3>
                <button class="bk-modal-close" @onclick="CloseDialog"><span class="material-icons-round">close</span></button>
            </div>
            <div class="bk-modal-body">
                <EditForm Model="@_form" OnValidSubmit="SaveLeaveType">
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                        <div class="bk-field" style="grid-column:1/-1;">
                            <label class="bk-label">Leave Type Name *</label>
                            <InputText class="bk-input" @bind-Value="_form.Name" placeholder="e.g. Annual Leave, Sick Leave" />
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Color</label>
                            <input type="color" class="bk-input" style="height:42px;padding:4px;" value="@_form.Color" @oninput="e => _form.Color = e.Value?.ToString() ?? '#25163F'" />
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Default Days per Year</label>
                            <InputNumber class="bk-input" @bind-Value="_form.DefaultDays" />
                            <small style="color:var(--bk-ink-3);font-size:11px;">Annual entitlement per employee</small>
                        </div>
                        <div class="bk-field" style="display:flex;align-items:center;gap:8px;padding-top:24px;">
                            <InputCheckbox @bind-Value="_form.IsPaid" id="isPaid" />
                            <label for="isPaid" style="font-size:13px;cursor:pointer;">Paid leave</label>
                        </div>
                        <div class="bk-field" style="display:flex;align-items:center;gap:8px;padding-top:24px;">
                            <InputCheckbox @bind-Value="_form.RequiresApproval" id="reqApproval" />
                            <label for="reqApproval" style="font-size:13px;cursor:pointer;">Requires approval</label>
                        </div>
                        <div class="bk-field" style="display:flex;align-items:center;gap:8px;">
                            <InputCheckbox @bind-Value="_form.CarryForward" id="carryFwd" />
                            <label for="carryFwd" style="font-size:13px;cursor:pointer;">Allow carry forward</label>
                        </div>
                        @if (_form.CarryForward)
                        {
                            <div class="bk-field">
                                <label class="bk-label">Max Carry Forward (days)</label>
                                <InputNumber class="bk-input" @bind-Value="_form.MaxCarryForwardDays" />
                                <small style="color:var(--bk-ink-3);font-size:11px;">Leave empty for no limit</small>
                            </div>
                        }
                    </div>
                    <div style="display:flex;justify-content:flex-end;gap:8px;margin-top:24px;padding-top:16px;border-top:1px solid var(--bk-line);">
                        <button type="button" class="bk-btn bk-btn-secondary" @onclick="CloseDialog">Cancel</button>
                        <button type="submit" class="bk-btn bk-btn-primary">
                            <span class="material-icons-round" style="font-size:16px;">save</span>
                            @(_editing?.Id > 0 ? "Update Leave Type" : "Create Leave Type")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<LeaveType> _leaveTypes = new();
    private int _orgId;

    // Dialog state
    private bool _showDialog;
    private LeaveType? _editing;
    private LeaveType _form = new();

    protected override async Task OnInitializedAsync()
    {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        _orgId = org.Id;
        _leaveTypes = await Db.LeaveTypes.Where(l => l.OrganizationId == _orgId).OrderBy(l => l.Name).ToListAsync();
    }

    private void OpenDialog(LeaveType? existing)
    {
        _editing = existing;
        _form = existing != null ? new LeaveType
        {
            Id = existing.Id,
            Name = existing.Name,
            Color = existing.Color,
            DefaultDays = existing.DefaultDays,
            IsPaid = existing.IsPaid,
            RequiresApproval = existing.RequiresApproval,
            CarryForward = existing.CarryForward,
            MaxCarryForwardDays = existing.MaxCarryForwardDays
        } : new LeaveType
        {
            Color = "#25163F",
            DefaultDays = 21,
            IsPaid = true,
            RequiresApproval = true,
            CarryForward = false
        };
        _showDialog = true;
    }

    private void CloseDialog() => _showDialog = false;

    private async Task SaveLeaveType()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(_form.Name))
            {
                Snackbar.Add("Leave type name is required.", Severity.Warning);
                return;
            }

            if (_editing?.Id > 0)
            {
                var existing = await Db.LeaveTypes.FirstOrDefaultAsync(l => l.Id == _editing.Id);
                if (existing == null) return;

                existing.Name = _form.Name;
                existing.Color = _form.Color;
                existing.DefaultDays = _form.DefaultDays;
                existing.IsPaid = _form.IsPaid;
                existing.RequiresApproval = _form.RequiresApproval;
                existing.CarryForward = _form.CarryForward;
                existing.MaxCarryForwardDays = _form.CarryForward ? _form.MaxCarryForwardDays : null;
                Db.LeaveTypes.Update(existing);
                await Db.SaveChangesAsync();
                Snackbar.Add($"Leave type '{existing.Name}' updated.", Severity.Success);
            }
            else
            {
                _form.OrganizationId = _orgId;
                if (!_form.CarryForward) _form.MaxCarryForwardDays = null;
                Db.LeaveTypes.Add(_form);
                await Db.SaveChangesAsync();
                Snackbar.Add($"Leave type '{_form.Name}' created.", Severity.Success);
            }

            _leaveTypes = await Db.LeaveTypes.Where(l => l.OrganizationId == _orgId).OrderBy(l => l.Name).ToListAsync();
            _showDialog = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteLeaveType(LeaveType lt)
    {
        try
        {
            // Check if leave type is in use
            var inUse = await Db.LeaveRequests.AnyAsync(l => l.LeaveTypeId == lt.Id);
            if (inUse)
            {
                Snackbar.Add($"Cannot delete '{lt.Name}' — it is assigned to existing leave requests.", Severity.Warning);
                return;
            }
            Db.LeaveTypes.Remove(lt);
            await Db.SaveChangesAsync();
            _leaveTypes = await Db.LeaveTypes.Where(l => l.OrganizationId == _orgId).OrderBy(l => l.Name).ToListAsync();
            Snackbar.Add($"Leave type '{lt.Name}' deleted.", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to delete: {ex.Message}", Severity.Error);
        }
    }
}
