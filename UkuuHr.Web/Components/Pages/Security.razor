@page "/security"
@attribute [Authorize(Policy = "UserManagement")]
@using Microsoft.EntityFrameworkCore
@inject UkuuHrDbContext Db
@inject NavigationManager Nav

<div class="bk-admin-fade-in">
    <div class="bk-admin-section-header">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">Security & Audit · Score @_securityScore/100</div>
            <h1 class="bk-admin-h1">Security & Audit</h1>
            <p class="bk-admin-sub">Monitor user activity, configure security policies, and review audit logs.</p>
        </div>
        <div class="bk-admin-actions">
            <a href="/settings" class="bk-btn bk-btn-secondary">
                <span class="material-icons-round" style="font-size:16px;">settings</span>
                Configure
            </a>
        </div>
    </div>

    @if (_loadError != null)
    {
        <div style="padding:12px 16px;margin-bottom:16px;background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.25);border-radius:8px;color:var(--bk-warning);font-size:13px;">
            <span class="material-icons-round" style="font-size:18px;vertical-align:middle;">info</span>
            @_loadError
        </div>
    }

    <!-- Security posture -->
    <div class="bk-admin-kpi-grid">
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon green"><span class="material-icons-round">shield</span></div>
                <span class="bk-admin-pill active">Secure</span>
            </div>
            <div class="bk-admin-kpi-value">@_securityScore/100</div>
            <div class="bk-admin-kpi-label">Security Score</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon blue"><span class="material-icons-round">login</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_loginSuccess</div>
            <div class="bk-admin-kpi-label">Logins (30 days)</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon pink"><span class="material-icons-round">warning</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_loginFailed</div>
            <div class="bk-admin-kpi-label">Failed Attempts</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon purple"><span class="material-icons-round">history</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_auditLogs.Count</div>
            <div class="bk-admin-kpi-label">Audit Events</div>
        </div>
    </div>

    <!-- Security toggles -->
    <form method="post" action="/api/security/policies" class="bk-admin-card" style="margin-bottom:24px;">
        <div class="bk-admin-card-header">
            <h3>Security Policies</h3>
            <p>Configure authentication and access controls. Changes are saved automatically.</p>
        </div>
        <div class="bk-admin-card-content" style="display:flex;flex-direction:column;gap:0;">
            @for (int i = 0; i < _securityPolicies.Count; i++)
            {
                var p = _securityPolicies[i];
                <input type="hidden" name="policies[@i].Title" value="@p.Title" />
                <input type="hidden" name="policies[@i].Description" value="@p.Description" />
                <input type="hidden" name="policies[@i].Icon" value="@p.Icon" />
                <div style="display:flex;justify-content:space-between;align-items:center;padding:16px 0;border-bottom:1px solid var(--bk-line);">
                    <div style="display:flex;align-items:center;gap:14px;">
                        <div class="bk-admin-kpi-icon ink" style="width:40px;height:40px;">
                            <span class="material-icons-round">@p.Icon</span>
                        </div>
                        <div>
                            <div style="font-weight:600;font-size:13px;color:var(--bk-ink);">@p.Title</div>
                            <div style="font-size:12px;color:var(--bk-ink-3);">@p.Description</div>
                        </div>
                    </div>
                    <label class="bk-check-row" style="margin:0;">
                        <input type="checkbox" name="policies[@i].Enabled" value="true" @(p.Enabled ? "checked" : "") class="bk-check" onchange="this.nextElementSibling.value = this.checked ? 'true' : 'false'; document.getElementById('security-save-bar').style.display='flex';" />
                        <input type="hidden" name="policies[@i].EnabledValue" value="@p.Enabled.ToString().ToLower()" />
                    </label>
                </div>
            }
        </div>
        <div id="security-save-bar" style="display:none;justify-content:flex-end;padding:16px 0 0;border-top:1px solid var(--bk-line);margin-top:8px;">
            <button type="submit" class="bk-btn bk-btn-primary">
                <span class="material-icons-round" style="font-size:16px;">save</span>
                Save Security Policies
            </button>
        </div>
    </form>

    <!-- Audit log -->
    <div class="bk-admin-card" style="overflow:hidden;">
        <div class="bk-admin-card-header" style="display:flex;justify-content:space-between;align-items:center;">
            <div><h3>Audit Log</h3><p>Recent activity across the system</p></div>
            <a href="/api/security/audit-log.csv" class="bk-btn bk-btn-secondary" download>
                <span class="material-icons-round" style="font-size:16px;">download</span>
                Export
            </a>
        </div>
        <div style="overflow-x:auto;">
            <table class="bk-admin-table bk-mobile-card-view">
                <thead>
                    <tr><th>Action</th><th>Performed By</th><th>Target</th><th>Details</th><th>Timestamp</th></tr>
                </thead>
                <tbody>
                    @if (_auditLogs.Any())
                    {
                        @foreach (var a in _auditLogs)
                        {
                            <tr>
                                <td data-label="Action">
                                    <div style="display:flex;align-items:center;gap:8px;">
                                        <span style="width:8px;height:8px;border-radius:50%;background:@GetActionColor(a.Action);flex-shrink:0;"></span>
                                        <span style="font-weight:600;font-size:13px;">@a.ActionDisplay</span>
                                    </div>
                                </td>
                                <td data-label="Performed By" style="font-size:12px;">@(a.PerformedByEmail ?? "—")</td>
                                <td data-label="Target" style="font-size:12px;color:var(--bk-ink-3);">@(a.TargetUserEmail ?? "—")</td>
                                <td data-label="Details" style="font-size:12px;color:var(--bk-ink-3);max-width:300px;">@(a.Details ?? "—")</td>
                                <td data-label="Timestamp" style="font-size:11px;color:var(--bk-ink-3);font-weight:600;">@a.FormattedTimestamp</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" style="text-align:center;padding:32px;color:var(--bk-ink-3);">No audit events recorded yet.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<AuditLog> _auditLogs = new();
    private int _loginSuccess, _loginFailed;
    private int _securityScore = 92;
    private string? _loadError;

    private List<SecurityPolicy> _securityPolicies = new()
    {
        new("Multi-Factor Authentication", "Require 2FA for all admin accounts", "lock", true),
        new("Session Timeout", "Auto sign-out after 8 hours of inactivity", "schedule", true),
        new("IP Allowlist", "Restrict access to specific IP addresses", "security", false),
        new("SSO Integration", "Single sign-on with Google/Microsoft", "key", false),
        new("Device Verification", "Require email verification for new devices", "devices", true),
        new("Password Rotation", "Force password change every 90 days", "password", false)
    };

    private record SecurityPolicy(string Title, string Description, string Icon, bool Enabled)
    {
        public bool Enabled { get; set; } = Enabled;
    }

    protected override async Task OnInitializedAsync()
    {
        // Check for ?saved=1 query param
        try
        {
            var uri = Nav.ToAbsoluteUri(Nav.Uri);
            if (uri.Query.Contains("saved=1"))
                _loadError = "Security policies saved successfully.";
        }
        catch { }

        // Load audit logs — fall back to empty if DB fails
        try
        {
            var org = await Db.Organizations.FirstOrDefaultAsync();
            if (org != null)
            {
                _auditLogs = await Db.AuditLogs
                    .Where(a => a.OrganizationId == org.Id)
                    .OrderByDescending(a => a.Timestamp)
                    .Take(50)
                    .ToListAsync();
                _loginSuccess = _auditLogs.Count(a => a.Action == AuditAction.LoginSuccess);
                _loginFailed = _auditLogs.Count(a => a.Action == AuditAction.LoginFailed);

                // Compute security score based on enabled policies
                int enabledCount = _securityPolicies.Count(p => p.Enabled);
                _securityScore = 60 + (enabledCount * 5); // 60 base + 5 per policy
                if (_securityScore > 100) _securityScore = 100;
            }
        }
        catch
        {
            // DB not ready — show defaults
            _loadError = "Database not fully initialized. Showing default values.";
        }
    }

    private string GetActionColor(AuditAction action) => action switch
    {
        AuditAction.LoginSuccess or AuditAction.UserCreated or AuditAction.BulkImport => "#14a37f",
        AuditAction.LoginFailed or AuditAction.UserDeleted => "#e85d75",
        AuditAction.PasswordReset or AuditAction.StatusChanged => "#d89c11",
        _ => "#6c63ff"
    };
}
