@page "/security"
@using Microsoft.EntityFrameworkCore
@inject UkuuHrDbContext Db

<div class="bk-admin-fade-in">
    <div class="bk-admin-section-header">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">Security & Audit · Score 92/100</div>
            <h1 class="bk-admin-h1">Security & Audit</h1>
            <p class="bk-admin-sub">Monitor user activity, configure security policies, and review audit logs.</p>
        </div>
    </div>

    <!-- Security posture -->
    <div class="bk-admin-kpi-grid">
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon green"><span class="material-icons-round">shield</span></div>
                <span class="bk-admin-pill active">Secure</span>
            </div>
            <div class="bk-admin-kpi-value">92/100</div>
            <div class="bk-admin-kpi-label">Security Score</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon blue"><span class="material-icons-round">login</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_loginSuccess</div>
            <div class="bk-admin-kpi-label">Logins (30 days)</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon pink"><span class="material-icons-round">warning</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_loginFailed</div>
            <div class="bk-admin-kpi-label">Failed Attempts</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon purple"><span class="material-icons-round">history</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_auditLogs.Count</div>
            <div class="bk-admin-kpi-label">Audit Events</div>
        </div>
    </div>

    <!-- Security toggles -->
    <div class="bk-admin-card" style="margin-bottom:24px;">
        <div class="bk-admin-card-header">
            <h3>Security Policies</h3>
            <p>Configure authentication and access controls</p>
        </div>
        <div class="bk-admin-card-content" style="display:flex;flex-direction:column;gap:0;">
            @for (int i = 0; i < _securityPolicies.Count; i++)
            {
                var p = _securityPolicies[i];
                <div style="display:flex;justify-content:space-between;align-items:center;padding:16px 0;border-bottom:1px solid var(--bk-line);">
                    <div style="display:flex;align-items:center;gap:14px;">
                        <div class="bk-admin-kpi-icon ink" style="width:40px;height:40px;">
                            <span class="material-icons-round">@p.Icon</span>
                        </div>
                        <div>
                            <div style="font-weight:600;font-size:13px;color:var(--bk-ink);">@p.Title</div>
                            <div style="font-size:12px;color:var(--bk-ink-3);">@p.Description</div>
                        </div>
                    </div>
                    <label class="bk-check-row" style="margin:0;">
                        <input type="checkbox" @bind="_securityPolicies[i].Enabled" class="bk-check" />
                    </label>
                </div>
            }
        </div>
    </div>

    <!-- Audit log -->
    <div class="bk-admin-card" style="overflow:hidden;">
        <div class="bk-admin-card-header" style="display:flex;justify-content:space-between;align-items:center;">
            <div><h3>Audit Log</h3><p>Recent activity across the system</p></div>
            <button class="bk-btn bk-btn-secondary"><span class="material-icons-round" style="font-size:16px;">download</span>Export</button>
        </div>
        <table class="bk-admin-table">
            <thead>
                <tr><th>Action</th><th>Performed By</th><th>Target</th><th>Details</th><th>Timestamp</th></tr>
            </thead>
            <tbody>
                @foreach (var a in _auditLogs)
                {
                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:8px;">
                                <span style="width:8px;height:8px;border-radius:50%;background:@GetActionColor(a.Action);"></span>
                                <span style="font-weight:600;font-size:13px;">@a.ActionDisplay</span>
                            </div>
                        </td>
                        <td style="font-size:12px;">@(a.PerformedByEmail ?? "—")</td>
                        <td style="font-size:12px;color:var(--bk-ink-3);">@(a.TargetUserEmail ?? "—")</td>
                        <td style="font-size:12px;color:var(--bk-ink-3);max-width:300px;">@a.Details</td>
                        <td style="font-size:11px;color:var(--bk-ink-3);font-weight:600;">@a.FormattedTimestamp</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<AuditLog> _auditLogs = new();
    private int _loginSuccess, _loginFailed;

    private List<SecurityPolicy> _securityPolicies = new()
    {
        new("Multi-Factor Authentication", "Require 2FA for all admin accounts", "lock", true),
        new("Session Timeout", "Auto sign-out after 8 hours of inactivity", "schedule", true),
        new("IP Allowlist", "Restrict access to specific IP addresses", "security", false),
        new("SSO Integration", "Single sign-on with Google/Microsoft", "key", false),
        new("Device Verification", "Require email verification for new devices", "devices", true),
        new("Password Rotation", "Force password change every 90 days", "password", false)
    };

    private record SecurityPolicy(string Title, string Description, string Icon, bool Enabled)
    {
        public bool Enabled { get; set; } = Enabled;
    }

    protected override async Task OnInitializedAsync()
    {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        _auditLogs = await Db.AuditLogs.Where(a => a.OrganizationId == org.Id).OrderByDescending(a => a.Timestamp).Take(50).ToListAsync();
        _loginSuccess = _auditLogs.Count(a => a.Action == AuditAction.LoginSuccess);
        _loginFailed = _auditLogs.Count(a => a.Action == AuditAction.LoginFailed);
    }

    private string GetActionColor(AuditAction action) => action switch
    {
        AuditAction.LoginSuccess or AuditAction.UserCreated or AuditAction.BulkImport => "#14a37f",
        AuditAction.LoginFailed or AuditAction.UserDeleted => "#e85d75",
        AuditAction.PasswordReset or AuditAction.StatusChanged => "#d89c11",
        _ => "#6c63ff"
    };
}
