@page "/security"
@using Microsoft.EntityFrameworkCore
@inject UkuuHrDbContext Db

<div class="ukuu-fade-in">
    <div class="ukuu-section-header">
        <h1>Security & Audit</h1>
        <p>Monitor user activity, configure security policies, and review audit logs.</p>
    </div>

    <!-- Security posture -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;margin-bottom:24px;">
        <div class="ukuu-kpi-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
                <div style="width:44px;height:44px;border-radius:12px;background:var(--ukuu-success-bg);color:var(--ukuu-success);display:flex;align-items:center;justify-content:center;">
                    <span class="material-icons-round">shield</span>
                </div>
                <span class="ukuu-status-pill ukuu-status-active">Secure</span>
            </div>
            <div class="ukuu-kpi-value" style="font-size:24px;">92/100</div>
            <div class="ukuu-kpi-label">Security Score</div>
        </div>
        <div class="ukuu-kpi-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
                <div style="width:44px;height:44px;border-radius:12px;background:var(--ukuu-info-bg);color:var(--ukuu-info);display:flex;align-items:center;justify-content:center;">
                    <span class="material-icons-round">login</span>
                </div>
            </div>
            <div class="ukuu-kpi-value" style="font-size:24px;">@_loginSuccess</div>
            <div class="ukuu-kpi-label">Logins (30 days)</div>
        </div>
        <div class="ukuu-kpi-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
                <div style="width:44px;height:44px;border-radius:12px;background:var(--ukuu-error-bg);color:var(--ukuu-error);display:flex;align-items:center;justify-content:center;">
                    <span class="material-icons-round">warning</span>
                </div>
            </div>
            <div class="ukuu-kpi-value" style="font-size:24px;">@_loginFailed</div>
            <div class="ukuu-kpi-label">Failed Attempts</div>
        </div>
        <div class="ukuu-kpi-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
                <div style="width:44px;height:44px;border-radius:12px;background:#EDE0FE;color:#7C3AED;display:flex;align-items:center;justify-content:center;">
                    <span class="material-icons-round">history</span>
                </div>
            </div>
            <div class="ukuu-kpi-value" style="font-size:24px;">@_auditLogs.Count</div>
            <div class="ukuu-kpi-label">Audit Events</div>
        </div>
    </div>

    <!-- Security toggles -->
    <div class="mud-card" style="margin-bottom:24px;">
        <div class="mud-card-header">
            <h3 style="font-size:16px;font-weight:700;margin-bottom:2px;">Security Policies</h3>
            <p style="font-size:12px;color:var(--ukuu-text-muted);margin:0;">Configure authentication and access controls</p>
        </div>
        <div class="mud-card-content" style="display:flex;flex-direction:column;gap:0;">
            @for (int i = 0; i < _securityPolicies.Count; i++)
            {
                var p = _securityPolicies[i];
                <div style="display:flex;justify-content:space-between;align-items:center;padding:16px 0;border-bottom:1px solid var(--ukuu-divider);">
                    <div style="display:flex;align-items:center;gap:14px;">
                        <div style="width:40px;height:40px;border-radius:10px;background:var(--ukuu-surface-alt);color:var(--ukuu-ink);display:flex;align-items:center;justify-content:center;">
                            <span class="material-icons-round">@p.Icon</span>
                        </div>
                        <div>
                            <div style="font-weight:600;font-size:13px;color:var(--ukuu-text);">@p.Title</div>
                            <div style="font-size:12px;color:var(--ukuu-text-muted);">@p.Description</div>
                        </div>
                    </div>
                    <MudSwitch @bind-Value="_securityPolicies[i].Enabled" Color="Color.Primary" />
                </div>
            }
        </div>
    </div>

    <!-- Audit log -->
    <div class="mud-card">
        <div class="mud-card-header" style="display:flex;justify-content:space-between;align-items:center;">
            <div>
                <h3 style="font-size:16px;font-weight:700;margin-bottom:2px;">Audit Log</h3>
                <p style="font-size:12px;color:var(--ukuu-text-muted);margin:0;">Recent activity across the system</p>
            </div>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" StartIcon="@Icons.Material.Filled.Download">Export</MudButton>
        </div>
        <MudTable Items="@_auditLogs" Hover="true" Elevation="0">
            <HeaderContent>
                <MudTh>Action</MudTh>
                <MudTh>Performed By</MudTh>
                <MudTh>Target</MudTh>
                <MudTh>Details</MudTh>
                <MudTh>Timestamp</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <div style="display:flex;align-items:center;gap:8px;">
                        <span style="width:8px;height:8px;border-radius:50%;background:@(GetActionColor(context.Action));"></span>
                        <span style="font-weight:600;font-size:13px;">@context.ActionDisplay</span>
                    </div>
                </MudTd>
                <MudTd Style="font-size:12px;">@(context.PerformedByEmail ?? "—")</MudTd>
                <MudTd Style="font-size:12px;color:var(--ukuu-text-muted);">@(context.TargetUserEmail ?? "—")</MudTd>
                <MudTd Style="font-size:12px;color:var(--ukuu-text-muted);max-width:300px;">@context.Details</MudTd>
                <MudTd Style="font-size:11px;color:var(--ukuu-text-subtle);font-weight:600;">@context.FormattedTimestamp</MudTd>
            </RowTemplate>
        </MudTable>
    </div>
</div>

@code {
    private List<AuditLog> _auditLogs = new();
    private int _loginSuccess, _loginFailed;

    private List<SecurityPolicy> _securityPolicies = new()
    {
        new("Multi-Factor Authentication", "Require 2FA for all admin accounts", "lock", true),
        new("Session Timeout", "Auto sign-out after 8 hours of inactivity", "schedule", true),
        new("IP Allowlist", "Restrict access to specific IP addresses", "security", false),
        new("SSO Integration", "Single sign-on with Google/Microsoft", "key", false),
        new("Device Verification", "Require email verification for new devices", "devices", true),
        new("Password Rotation", "Force password change every 90 days", "password", false)
    };

    private record SecurityPolicy(string Title, string Description, string Icon, bool Enabled)
    {
        public bool Enabled { get; set; } = Enabled;
    }

    protected override async Task OnInitializedAsync()
    {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        _auditLogs = await Db.AuditLogs.Where(a => a.OrganizationId == org.Id).OrderByDescending(a => a.Timestamp).Take(50).ToListAsync();
        _loginSuccess = _auditLogs.Count(a => a.Action == AuditAction.LoginSuccess);
        _loginFailed = _auditLogs.Count(a => a.Action == AuditAction.LoginFailed);
    }

    private string GetActionColor(AuditAction action) => action switch
    {
        AuditAction.LoginSuccess or AuditAction.UserCreated or AuditAction.BulkImport => "#16A34A",
        AuditAction.LoginFailed or AuditAction.UserDeleted => "#DC2626",
        AuditAction.PasswordReset or AuditAction.StatusChanged => "#F59E0B",
        _ => "#6E5F92"
    };
}
