@page "/shifts/coverage"
@attribute [Authorize(Policy = "HrOrAdmin")]
@using Microsoft.EntityFrameworkCore
@inject ShiftService ShiftSvc
@inject UkuuHrDbContext Db
@inject ISnackbar Snackbar

<div class="bk-admin-fade-in">
    <div class="bk-admin-section-header">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">Shift Management · Weekly Coverage</div>
            <h1 class="bk-admin-h1">Weekly Coverage Matrix</h1>
            <p class="bk-admin-sub">
                Employees per shift per day-of-week. Green = full coverage, Amber = thin (fewer than 2),
                Red = uncovered (no one assigned). Use this to identify staffing gaps and optimize shift distribution.
            </p>
        </div>
        <div class="bk-admin-actions">
            <a href="/shifts" class="bk-btn bk-btn-secondary">
                <span class="material-icons-round" style="font-size:16px;">arrow_back</span>
                All Shifts
            </a>
            <button class="bk-btn bk-btn-secondary" @onclick="ToggleView">
                <span class="material-icons-round" style="font-size:16px;">@(_showPercentage ? "numbers" : "percent")</span>
                @(_showPercentage ? "Show Counts" : "Show % Fill")
            </button>
        </div>
    </div>

    @* ───── Summary KPIs ───── *@
    <div class="bk-admin-kpi-grid">
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon green"><span class="material-icons-round">check_circle</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_greenCount</div>
            <div class="bk-admin-kpi-label">Cells Fully Covered</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon gold"><span class="material-icons-round">warning</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_amberCount</div>
            <div class="bk-admin-kpi-label">Thin Coverage</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon" style="--kpi-color:var(--bk-error);"><span class="material-icons-round">error</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_redCount</div>
            <div class="bk-admin-kpi-label">Uncovered</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon blue"><span class="material-icons-round">trending_up</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_coveragePercent%</div>
            <div class="bk-admin-kpi-label">Overall Coverage</div>
        </div>
    </div>

    @* ───── Coverage matrix ───── *@
    <div class="bk-admin-card" style="overflow:hidden;">
        <div class="bk-admin-card-header">
            <h3>Coverage by Shift × Day</h3>
            <p>@_shifts.Count shifts across @_assignments.Select(a => a.EmployeeId).Distinct().Count() assigned employees.</p>
        </div>

        @if (_shifts.Count == 0)
        {
            <div style="text-align:center;padding:64px 24px;">
                <span class="material-icons-round" style="font-size:48px;color:var(--bk-ink-3);opacity:0.5;">calendar_view_week</span>
                <h3 style="margin-top:16px;">No shifts defined</h3>
                <p style="color:var(--bk-ink-3);margin:8px 0 20px;">Create shifts and assign employees to see the coverage matrix.</p>
                <a href="/shifts" class="bk-btn bk-btn-primary">
                    <span class="material-icons-round" style="font-size:16px;">add</span>
                    Create Shift
                </a>
            </div>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table class="bk-admin-table">
                    <thead>
                        <tr>
                            <th style="min-width:220px;">Shift</th>
                            @foreach (var day in new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" })
                            {
                                <th style="text-align:center;min-width:100px;">
                                    <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;color:var(--bk-ink-2);">@day</div>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in _shifts)
                        {
                            <tr>
                                <td>
                                    <div style="display:flex;align-items:center;gap:10px;">
                                        <div style="width:8px;height:36px;border-radius:4px;background:@(s.Color);flex-shrink:0;"></div>
                                        <div>
                                            <div style="font-weight:600;color:var(--bk-ink);">@s.Name</div>
                                            <div style="font-size:11px;color:var(--bk-ink-3);display:flex;gap:6px;align-items:center;">
                                                <span>@s.TimeWindow</span>
                                                <span>·</span>
                                                <span class="bk-admin-pill @ShiftKindClass(s.Kind)">@s.KindDisplay</span>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                @for (int d = 0; d < 7; d++)
                                {
                                    var shiftActiveOnDay = (s.DaysOfWeekMask & (1 << d)) != 0;
                                    var count = shiftActiveOnDay ? _assignments.Count(a => a.ShiftId == s.Id && (a.EffectiveDaysMask & (1 << d)) != 0) : 0;
                                    var maxShift = shiftActiveOnDay ? Math.Max(1, _assignments.Count(a => a.ShiftId == s.Id && (a.EffectiveDaysMask & (1 << d)) != 0)) : 1;
                                    var fillPercent = shiftActiveOnDay ? Math.Min(100, (int)((double)count / Math.Max(1, _maxExpectedPerShift) * 100)) : 0;

                                    var bg = !shiftActiveOnDay ? "transparent" : count == 0 ? "rgba(220,38,38,0.08)" : count < 2 ? "rgba(245,158,11,0.08)" : "rgba(22,163,74,0.08)";
                                    var color = !shiftActiveOnDay ? "var(--bk-ink-3)" : count == 0 ? "var(--bk-error)" : count < 2 ? "var(--bk-warning)" : "var(--bk-success)";
                                    var borderColor = !shiftActiveOnDay ? "transparent" : count == 0 ? "rgba(220,38,38,0.2)" : count < 2 ? "rgba(245,158,11,0.2)" : "rgba(22,163,74,0.2)";

                                    <td style="text-align:center;padding:14px 12px;background:@bg;border:1px solid @borderColor;position:relative;">
                                        @if (shiftActiveOnDay)
                                        {
                                            if (_showPercentage)
                                            {
                                                <div style="font-weight:700;color:@color;font-size:18px;">@fillPercent%</div>
                                                <div style="font-size:10px;color:var(--bk-ink-3);margin-top:2px;">filled</div>
                                            }
                                            else
                                            {
                                                <div style="font-weight:700;color:@color;font-size:18px;">@count</div>
                                                <div style="font-size:10px;color:var(--bk-ink-3);margin-top:2px;">employees</div>
                                            }
                                            @* Mini bar at bottom *@
                                            <div style="position:absolute;bottom:0;left:0;right:0;height:3px;background:rgba(0,0,0,0.06);border-radius:0 0 4px 4px;overflow:hidden;">
                                                <div style="height:100%;width:@fillPercent%;background:@color;border-radius:0 0 0 4px;"></div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span style="color:var(--bk-ink-3);font-size:12px;">—</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* ───── Legend ───── *@
            <div style="display:flex;gap:20px;padding:16px 24px;border-top:1px solid var(--bk-line);flex-wrap:wrap;">
                <div style="display:flex;align-items:center;gap:6px;">
                    <div style="width:12px;height:12px;border-radius:3px;background:rgba(22,163,74,0.3);border:1px solid rgba(22,163,74,0.5);"></div>
                    <span style="font-size:11px;color:var(--bk-ink-2);">Full coverage (2+ employees)</span>
                </div>
                <div style="display:flex;align-items:center;gap:6px;">
                    <div style="width:12px;height:12px;border-radius:3px;background:rgba(245,158,11,0.3);border:1px solid rgba(245,158,11,0.5);"></div>
                    <span style="font-size:11px;color:var(--bk-ink-2);">Thin coverage (1 employee)</span>
                </div>
                <div style="display:flex;align-items:center;gap:6px;">
                    <div style="width:12px;height:12px;border-radius:3px;background:rgba(220,38,38,0.3);border:1px solid rgba(220,38,38,0.5);"></div>
                    <span style="font-size:11px;color:var(--bk-ink-2);">Uncovered (no employees)</span>
                </div>
                <div style="display:flex;align-items:center;gap:6px;">
                    <div style="width:12px;height:12px;border-radius:3px;background:transparent;border:1px solid var(--bk-line);"></div>
                    <span style="font-size:11px;color:var(--bk-ink-2);">Shift not active on day</span>
                </div>
            </div>
        }
    </div>

    @* ───── Shift timeline view ───── *@
    @if (_shifts.Count > 0)
    {
        <div class="bk-admin-card" style="margin-top:20px;">
            <div class="bk-admin-card-header">
                <h3>Shift Timeline — 24-Hour View</h3>
                <p>Visual representation of active shift windows across the day.</p>
            </div>
            <div style="padding:4px 24px 20px;overflow-x:auto;">
                <div style="min-width:700px;">
                    @* Hour labels *@
                    <div style="display:flex;margin-bottom:4px;">
                        <div style="width:140px;flex-shrink:0;"></div>
                        @for (int h = 0; h < 24; h++)
                        {
                            <div style="flex:1;font-size:10px;color:var(--bk-ink-3);text-align:center;font-weight:600;">@h.ToString("D2")</div>
                        }
                    </div>
                    @* Grid lines *@
                    <div style="position:relative;height:4px;margin-bottom:8px;">
                        <div style="display:flex;position:absolute;inset:0;">
                            @for (int h = 0; h < 24; h++)
                            {
                                <div style="flex:1;border-left:1px solid var(--bk-line);height:4px;"></div>
                            }
                            <div style="flex:0;border-right:1px solid var(--bk-line);height:4px;"></div>
                        </div>
                    </div>
                    @* Shift bars *@
                    @foreach (var s in _shifts.OrderBy(x => x.StartMinutes))
                    {
                        <div style="display:flex;align-items:center;margin-bottom:6px;">
                            <div style="width:140px;flex-shrink:0;font-size:12px;font-weight:600;color:var(--bk-ink);padding-right:12px;text-align:right;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@s.Name</div>
                            <div style="flex:1;position:relative;height:28px;">
                                @{
                                    var start = s.StartMinutes / (24.0 * 60) * 100;
                                    var end = s.EndMinutes / (24.0 * 60) * 100;
                                    var width = s.IsOvernight
                                        ? (100 - start) + end  // wraps past midnight
                                        : end - start;
                                    var barColor = s.Color;
                                }
                                <div style="position:absolute;left:@(start)%;width:@(width)%;height:28px;background:@barColor;border-radius:6px;display:flex;align-items:center;justify-content:center;opacity:0.85;">
                                    <span style="color:white;font-size:10px;font-weight:700;text-shadow:0 1px 2px rgba(0,0,0,0.3);white-space:nowrap;">
                                        @s.TimeWindow
                                        @if (s.IsOvernight)
                                        {
                                            <span> 🌙</span>
                                        }
                                    </span>
                                </div>
                                @if (s.IsOvernight)
                                {
                                    // Show wrapped portion
                                    <div style="position:absolute;left:0%;width:@(end)%;height:28px;background:@barColor;border-radius:6px;opacity:0.5;display:flex;align-items:center;justify-content:center;border:1px dashed rgba(255,255,255,0.3);">
                                        <span style="color:white;font-size:10px;font-weight:700;text-shadow:0 1px 2px rgba(0,0,0,0.3);white-space:nowrap;">↻ wraps here</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Shift> _shifts = new();
    private List<EmployeeShiftAssignment> _assignments = new();
    private int _orgId;
    private bool _showPercentage;
    private int _maxExpectedPerShift = 3;

    private int _greenCount => _shifts.Sum(s => DayCounts(s, d => { var c = ShiftCount(s, d); return c >= 2; }));
    private int _amberCount => _shifts.Sum(s => DayCounts(s, d => { var c = ShiftCount(s, d); return c == 1; }));
    private int _redCount => _shifts.Sum(s => DayCounts(s, d => { var c = ShiftCount(s, d); return c == 0; }));
    private int _coveragePercent
    {
        get
        {
            var total = _shifts.Sum(s => s.DaysOfWeekMask != 0 ? 7 : 0);
            var activeDays = _shifts.Sum(s => {
                var count = 0;
                for (int d = 0; d < 7; d++) if ((s.DaysOfWeekMask & (1 << d)) != 0) count++;
                return count;
            });
            if (activeDays == 0) return 100;
            var covered = _greenCount + _amberCount;
            return (int)Math.Round((double)covered / activeDays * 100);
        }
    }

    private int ShiftCount(Shift s, int dayIdx) =>
        _assignments.Count(a => a.ShiftId == s.Id && (a.EffectiveDaysMask & (1 << dayIdx)) != 0);

    private int DayCounts(Shift s, Func<int, bool> predicate)
    {
        var count = 0;
        for (int d = 0; d < 7; d++)
        {
            if ((s.DaysOfWeekMask & (1 << d)) != 0 && predicate(d))
                count++;
        }
        return count;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        _orgId = org.Id;

        _shifts = await Db.Shifts.Where(s => s.OrganizationId == _orgId && s.IsActive).OrderBy(s => s.Name).ToListAsync();
        _assignments = await Db.EmployeeShiftAssignments
            .Include(a => a.Shift)
            .Include(a => a.Employee)
            .Where(a => a.OrganizationId == _orgId && a.IsActive)
            .ToListAsync();

        // Estimate expected per shift (average of all non-zero day counts)
        var allCounts = new List<int>();
        foreach (var s in _shifts)
        {
            for (int d = 0; d < 7; d++)
            {
                if ((s.DaysOfWeekMask & (1 << d)) != 0)
                {
                    var c = ShiftCount(s, d);
                    if (c > 0) allCounts.Add(c);
                }
            }
        }
        if (allCounts.Count > 0)
            _maxExpectedPerShift = (int)Math.Ceiling(allCounts.Average()) + 1;
        else
            _maxExpectedPerShift = 3;
        }
        catch
        {
            // Fall back to empty data — page renders with defaults
        }
    }

    private void ToggleView()
    {
        _showPercentage = !_showPercentage;
    }

    private static string ShiftKindClass(ShiftKind kind) => kind switch
    {
        ShiftKind.Fixed => "approved",
        ShiftKind.Rotating => "pending",
        ShiftKind.Overnight => "rejected",
        ShiftKind.Flexible => "info",
        _ => ""
    };
}
