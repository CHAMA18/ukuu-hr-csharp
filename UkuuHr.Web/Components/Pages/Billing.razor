@page "/billing"
@attribute [Authorize(Policy = "FinanceOrAdmin")]
@using Microsoft.EntityFrameworkCore
@inject UkuuHrDbContext Db

<div class="bk-admin-fade-in">
    <div class="bk-admin-section-header">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">Billing & License · @_daysLeft days remaining</div>
            <h1 class="bk-admin-h1">Billing & License</h1>
            <p class="bk-admin-sub">Manage your subscription, view invoices, and activate license codes.</p>
        </div>
        <div class="bk-admin-actions">
            <button class="bk-btn bk-btn-primary">
                <span class="material-icons-round" style="font-size:16px;">vpn_key</span>
                Activate License
            </button>
        </div>
    </div>

    <!-- Subscription card -->
    <div class="bk-admin-card" style="margin-bottom:24px;background:linear-gradient(135deg,#0a0a0a 0%,#1a1a1a 100%);color:white;position:relative;overflow:hidden;">
        <div style="position:absolute;top:-100px;right:-100px;width:400px;height:400px;background:radial-gradient(circle,rgba(216,156,17,0.15) 0%,transparent 70%);border-radius:50%;"></div>
        <div class="bk-admin-card-content" style="position:relative;z-index:1;display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:center;">
            <div>
                <div style="display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;background:rgba(20,163,127,0.2);color:#2dd4a7;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:12px;">
                    <span style="width:6px;height:6px;border-radius:50%;background:#2dd4a7;"></span>
                    Active Subscription
                </div>
                <h2 style="font-size:28px;font-weight:800;color:#FCFBFF;margin-bottom:4px;font-family:Geist,sans-serif;">Annual Plan</h2>
                <p style="color:rgba(255,255,255,0.6);font-size:13px;margin:0 0 16px 0;">Ukuu HR Professional — full feature access for unlimited employees</p>
                <div style="display:flex;gap:24px;">
                    <div>
                        <div style="font-size:11px;color:rgba(255,255,255,0.5);text-transform:uppercase;font-weight:600;">Activated</div>
                        <div style="font-size:14px;font-weight:600;margin-top:2px;">@(_license?.ActivatedAt?.ToString("dd MMM yyyy") ?? "—")</div>
                    </div>
                    <div>
                        <div style="font-size:11px;color:rgba(255,255,255,0.5);text-transform:uppercase;font-weight:600;">Expires</div>
                        <div style="font-size:14px;font-weight:600;margin-top:2px;">@(_license?.ExpiresAt.ToString("dd MMM yyyy") ?? "—")</div>
                    </div>
                    <div>
                        <div style="font-size:11px;color:rgba(255,255,255,0.5);text-transform:uppercase;font-weight:600;">Days Left</div>
                        <div style="font-size:14px;font-weight:700;color:var(--bk-accent);margin-top:2px;">@_daysLeft days</div>
                    </div>
                </div>
            </div>
            <div style="text-align:right;">
                <div style="font-size:11px;color:rgba(255,255,255,0.5);text-transform:uppercase;font-weight:600;letter-spacing:0.08em;">License Code</div>
                <div style="font-family:'JetBrains Mono',monospace;font-size:22px;font-weight:700;color:#FCFBFF;margin-top:4px;letter-spacing:0.02em;">@_license?.Code</div>
                <div style="font-size:11px;color:rgba(255,255,255,0.4);margin-top:8px;">Activated by @(_license?.ActivatedByEmail ?? "—")</div>
            </div>
        </div>
    </div>

    <!-- Usage stats -->
    <div class="bk-admin-kpi-grid">
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon blue"><span class="material-icons-round">groups</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_empCount</div>
            <div class="bk-admin-kpi-label">Active Employees</div>
            <div style="margin-top:8px;height:6px;background:var(--bk-muted);border-radius:999px;overflow:hidden;">
                <div style="width:@(_empCount * 100.0 / _empLimit)%;height:100%;background:linear-gradient(90deg,var(--bk-ink),var(--bk-accent));"></div>
            </div>
            <div style="font-size:11px;color:var(--bk-ink-3);margin-top:4px;">of @_empLimit included</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon gold"><span class="material-icons-round">storage</span></div>
            </div>
            <div class="bk-admin-kpi-value">@(_storageMb.ToString("0.0")) MB</div>
            <div class="bk-admin-kpi-label">Storage Used</div>
            <div style="margin-top:8px;height:6px;background:var(--bk-muted);border-radius:999px;overflow:hidden;">
                <div style="width:@(_storageMb * 100.0 / 1024)%;height:100%;background:linear-gradient(90deg,var(--bk-accent),#b8810a);"></div>
            </div>
            <div style="font-size:11px;color:var(--bk-ink-3);margin-top:4px;">of 1 GB included</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon green"><span class="material-icons-round">receipt_long</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_payrollRuns</div>
            <div class="bk-admin-kpi-label">Payroll Runs (Month)</div>
            <div style="font-size:11px;color:var(--bk-ink-3);margin-top:8px;">Unlimited on annual plan</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon purple"><span class="material-icons-round">support_agent</span></div>
            </div>
            <div class="bk-admin-kpi-value">0</div>
            <div class="bk-admin-kpi-label">Support Tickets</div>
            <div style="font-size:11px;color:var(--bk-ink-3);margin-top:8px;">Priority support included</div>
        </div>
    </div>

    <!-- Plan comparison -->
    <div class="bk-admin-kpi-grid" style="grid-template-columns:repeat(auto-fit,minmax(260px,1fr));margin-top:24px;">
        @foreach (var plan in _plans)
        {
            <div class="bk-admin-card" style="@(plan.IsCurrent ? "border-color:var(--bk-accent);border-width:2px;" : "")">
                <div class="bk-admin-card-content">
                    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;">
                        <h3 style="font-size:18px;font-weight:700;">@plan.Name</h3>
                        @if (plan.IsCurrent)
                        {
                            <span class="bk-admin-pill active">Current</span>
                        }
                    </div>
                    <div style="font-size:32px;font-weight:800;color:var(--bk-ink);margin-bottom:4px;font-family:Geist,sans-serif;">$@plan.Price<span style="font-size:14px;font-weight:500;color:var(--bk-ink-3);">/@plan.Interval</span></div>
                    <p style="font-size:12px;color:var(--bk-ink-3);margin-bottom:16px;">@plan.Description</p>
                    <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:16px;">
                        @foreach (var feature in plan.Features)
                        {
                            <div style="display:flex;align-items:center;gap:8px;font-size:12px;color:var(--bk-ink);">
                                <span class="material-icons-round" style="color:var(--bk-accent-3);font-size:16px;">check</span>
                                @feature
                            </div>
                        }
                    </div>
                    <button class="bk-btn @(plan.IsCurrent ? "bk-btn-secondary" : "bk-btn-primary")" disabled="@plan.IsCurrent" style="width:100%;">
                        @(plan.IsCurrent ? "Current Plan" : "Upgrade")
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private LicenseCode? _license;
    private int _daysLeft, _empCount, _empLimit = 50, _payrollRuns;
    private double _storageMb;

    private List<Plan> _plans = new()
    {
        new("Starter", "9", "month", "Perfect for small teams up to 10 employees.", new[] { "Up to 10 employees", "Employee management", "Basic attendance", "Email support" }, false),
        new("Professional", "29", "month", "For growing businesses up to 50 employees.", new[] { "Up to 50 employees", "Full payroll & statutory", "Leave management", "Scheduling", "Priority support" }, true),
        new("Enterprise", "99", "month", "Unlimited employees with advanced features.", new[] { "Unlimited employees", "Multi-country payroll", "Advanced analytics", "API access", "Dedicated manager" }, false)
    };

    private record Plan(string Name, string Price, string Interval, string Description, string[] Features, bool IsCurrent);

    protected override async Task OnInitializedAsync()
    {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        _license = await Db.LicenseCodes.FirstOrDefaultAsync(l => l.ActivatedByOrganizationId == org.Id);
        _daysLeft = _license != null ? Math.Max(0, (_license.ExpiresAt - DateTime.UtcNow).Days) : 0;
        _empCount = await Db.Employees.CountAsync(e => e.OrganizationId == org.Id);
        _payrollRuns = await Db.PayrollRuns.CountAsync(p => p.OrganizationId == org.Id && p.Month == DateTime.Now.Month && p.Year == DateTime.Now.Year);
        _storageMb = await Db.EmployeeDocuments.Where(d => d.OrganizationId == org.Id).SumAsync(d => d.SizeBytes) / (1024.0 * 1024.0);
    }
}
