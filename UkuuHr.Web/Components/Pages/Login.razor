@page "/login"
@inject AuthService Auth
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ILogger<Login> Logger
@inject NavigationManager Navigation
@layout UkuuHr.Components.Layout.PublicLayout
@attribute [AllowAnonymous]

<div class="bk-auth">
    @* ─────────── LEFT: Visual panel ─────────── *@
    <aside class="bk-auth-visual">
        <a href="/landing" class="bk-auth-brand" style="text-decoration:none;color:inherit;">
            <div class="bk-auth-brand-logo">U</div>
            <div>
                <div class="bk-auth-brand-name">UKUU HR</div>
                <div class="bk-auth-brand-tag">HRMS Platform</div>
            </div>
        </a>

        <div class="bk-auth-visual-mid">
            <span class="bk-auth-visual-eyebrow">Remote HR platform · Africa</span>
            <h1>Welcome back to your <span class="bk-word-outline">workforce</span> command center.</h1>
            <p class="bk-auth-visual-lead">Sign in to manage employees, run country-compliant payroll, approve leave, and track attendance — all from one focused HR platform built for African businesses.</p>
        </div>

        <div class="bk-auth-visual-foot">
            <div class="bk-auth-quote">
                <p>"Ukuu HR brings employees, attendance, payroll, and leave together in one focused platform — purpose-built for African businesses, with country-aware statutory compliance."</p>
                <div class="bk-auth-quote-foot">
                    <div class="bk-auth-quote-avatar">U</div>
                    <div>
                        <strong>Ukuu HR</strong>
                        <div>HRMS Platform</div>
                    </div>
                </div>
            </div>

            <div class="bk-auth-visual-stats">
                <div><strong>13</strong><span>FRS modules</span></div>
                <div><strong>7</strong><span>Device vendors</span></div>
                <div><strong>3</strong><span>Country payroll configs</span></div>
            </div>
        </div>
    </aside>

    @* ─────────── RIGHT: Form panel ─────────── *@
    <main class="bk-auth-form-side">
        <a href="/landing" class="bk-auth-back">
            <span class="material-icons-round" style="font-size:14px;">arrow_back</span>
            Back to home
        </a>

        <div class="bk-auth-card bk-fade-in">
            @* Mobile brand (hidden on desktop where visual side is shown) *@
            <a href="/landing" class="bk-auth-mobile-brand">
                <div class="bk-auth-brand-logo">U</div>
                <div>
                    <div class="bk-auth-brand-name" style="color:var(--bk-ink);">UKUU HR</div>
                    <div class="bk-auth-brand-tag">HRMS Platform</div>
                </div>
            </a>

            <div class="bk-auth-header">
                <span class="bk-auth-eyebrow">Sign in</span>
                <h1 class="bk-auth-h1">Welcome back</h1>
                <p class="bk-auth-sub">Sign in to your Ukuu HR workspace to continue.</p>
            </div>

            <form method="post" action="/auth/login" class="bk-form">
                @if (_error != null)
                {
                    <div style="margin-bottom:16px;padding:10px 14px;background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.25);border-radius:8px;color:#991b1b;font-size:13px;display:flex;align-items:center;gap:8px;">
                        <span class="material-icons-round" style="font-size:18px;">error_outline</span>
                        @_error
                    </div>
                }

                <div class="bk-field">
                    <label class="bk-label" for="bk-email">Email address</label>
                    <div class="bk-input-wrap">
                        <span class="material-icons-round bk-input-icon">mail_outline</span>
                        <input id="bk-email" type="email" name="FormData.Email" value="@FormData?.Email" class="bk-input" placeholder="you@company.com" autocomplete="email" required />
                    </div>
                </div>

                <div class="bk-field">
                    <div class="bk-auth-row">
                        <label class="bk-label" for="bk-password">Password</label>
                        <a href="#" class="bk-auth-link">Forgot?</a>
                    </div>
                    <div class="bk-input-wrap">
                        <span class="material-icons-round bk-input-icon">lock_outline</span>
                        <input id="bk-password" type="password" name="FormData.Password" value="@FormData?.Password" class="bk-input" placeholder="••••••••" autocomplete="current-password" style="padding-right:48px;" required />
                        <button type="button" class="bk-input-toggle" onclick="togglePasswordVisibility()" aria-label="Toggle password visibility">
                            <span class="material-icons-round" id="bk-pwd-icon" style="font-size:18px;">visibility</span>
                        </button>
                    </div>
                </div>

                <label class="bk-check-row">
                    <input type="checkbox" name="FormData.RememberMe" value="true" class="bk-check" checked="@(FormData?.RememberMe ?? true)" />
                    <span class="bk-check-label">Remember me for 30 days</span>
                </label>

                <button type="submit" class="bk-auth-submit">
                    <span>Sign In to Dashboard</span>
                    <span class="material-icons-round" style="font-size:18px;">arrow_forward</span>
                </button>
            </form>

            <div class="bk-divider"><span>or continue with</span></div>

            <div class="bk-social-grid">
                <button type="button" class="bk-social-btn">
                    <span class="bk-social-icon bk-social-icon-google"></span>
                    Google
                </button>
                <button type="button" class="bk-social-btn">
                    <span class="bk-social-icon bk-social-icon-ms">
                        <span></span><span></span><span></span><span></span>
                    </span>
                    Microsoft
                </button>
            </div>

            <div class="bk-demo-creds">
                <div class="bk-demo-creds-label">Default admin credentials</div>
                <div class="bk-demo-creds-row">
                    <span class="bk-demo-creds-email">admin@ukuuhr.demo</span>
                    <span class="bk-demo-creds-sep">·</span>
                    <span class="bk-demo-creds-pass">Admin@2025</span>
                </div>
            </div>

            <div class="bk-auth-footer">
                Don't have an account? <a href="/signup">Create an account</a>
            </div>
        </div>
    </main>
</div>

<script>
    function togglePasswordVisibility() {
        const input = document.getElementById('bk-password');
        const icon = document.getElementById('bk-pwd-icon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.textContent = 'visibility_off';
        } else {
            input.type = 'password';
            icon.textContent = 'visibility';
        }
    }
</script>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorParam { get; set; }

    [SupplyParameterFromForm(FormName = "login")]
    public LoginModel? FormData { get; set; }

    private string? _error = null;

    protected override void OnInitialized()
    {
        FormData ??= new LoginModel();
        if (ErrorParam == "1")
        {
            _error = "Invalid email or password. Try admin@ukuuhr.demo / Admin@2025";
        }
    }

    public class LoginModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Enter a valid email")]
        public string Email { get; set; } = "admin@ukuuhr.demo";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = "Admin@2025";

        public bool RememberMe { get; set; } = true;
    }
}
