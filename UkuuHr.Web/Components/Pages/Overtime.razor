@page "/overtime"
@attribute [Authorize(Policy = "HrOrAdmin")]
@using Microsoft.EntityFrameworkCore
@inject OvertimeService OvertimeSvc
@inject UkuuHrDbContext Db
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<div class="bk-admin-fade-in">
    <div class="bk-admin-section-header">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">Overtime Management · @_summary.PendingCount pending</div>
            <h1 class="bk-admin-h1">Overtime Management</h1>
            <p class="bk-admin-sub">Track, calculate, and approve overtime. Auto-calculated from attendance + Hikvision clock events.</p>
        </div>
        <div class="bk-admin-actions">
            <form method="post" action="/api/overtime/auto-calculate" style="display:inline;">
                <button type="submit" class="bk-btn bk-btn-secondary">
                    <span class="material-icons-round" style="font-size:16px;">calculate</span>
                    Auto-Calculate
                </button>
            </form>
            <a href="/overtime/add" class="bk-btn bk-btn-primary" style="text-decoration:none;">
                <span class="material-icons-round" style="font-size:16px;">add</span>
                Add Overtime
            </a>
        </div>
    </div>

    <!-- KPI cards -->
    <div class="bk-admin-kpi-grid">
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon gold"><span class="material-icons-round">schedule</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_summary.TotalHours.ToString("0.0")h</div>
            <div class="bk-admin-kpi-label">Total OT Hours (@DateTime.Now.ToString("MMM yyyy"))</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon pink"><span class="material-icons-round">pending_actions</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_summary.PendingCount</div>
            <div class="bk-admin-kpi-label">Pending Approval</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon blue"><span class="material-icons-round">groups</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_summary.EmployeeCount</div>
            <div class="bk-admin-kpi-label">Employees with OT</div>
        </div>
    </div>

    <!-- Tabs -->
    <div style="display:flex;gap:4px;border-bottom:1px solid var(--bk-line);margin-bottom:24px;overflow-x:auto;">
        <a href="/overtime?tab=pending" style="padding:12px 16px;border-bottom:2px solid @(_tab == "pending" ? "var(--bk-ink)" : "transparent");color:@(_tab == "pending" ? "var(--bk-ink)" : "var(--bk-ink-3)");font-weight:600;font-size:13px;cursor:pointer;white-space:nowrap;text-decoration:none;">
            <span class="material-icons-round" style="font-size:18px;vertical-align:middle;margin-right:6px;">pending_actions</span>
            Pending (@_summary.PendingCount)
        </a>
        <a href="/overtime?tab=approved" style="padding:12px 16px;border-bottom:2px solid @(_tab == "approved" ? "var(--bk-ink)" : "transparent");color:@(_tab == "approved" ? "var(--bk-ink)" : "var(--bk-ink-3)");font-weight:600;font-size:13px;cursor:pointer;white-space:nowrap;text-decoration:none;">
            <span class="material-icons-round" style="font-size:18px;vertical-align:middle;margin-right:6px;">check_circle</span>
            Approved (@_summary.ApprovedCount)
        </a>
        <a href="/overtime?tab=all" style="padding:12px 16px;border-bottom:2px solid @(_tab == "all" ? "var(--bk-ink)" : "transparent");color:@(_tab == "all" ? "var(--bk-ink)" : "var(--bk-ink-3)");font-weight:600;font-size:13px;cursor:pointer;white-space:nowrap;text-decoration:none;">
            <span class="material-icons-round" style="font-size:18px;vertical-align:middle;margin-right:6px;">list_alt</span>
            All Records (@_all.Count)
        </a>
    </div>

    <div class="bk-admin-card" style="overflow:hidden;">
        <div style="display:flex;justify-content:space-between;align-items:center;padding:16px 20px;border-bottom:1px solid var(--bk-line);">
            <div style="font-size:13px;font-weight:700;color:var(--bk-ink);">
                @_filtered.Count() records
            </div>
            <a href="/api/overtime/export?tab=@_tab" class="bk-btn bk-btn-secondary" style="font-size:12px;padding:6px 14px;text-decoration:none;">
                <span class="material-icons-round" style="font-size:14px;">file_download</span>
                Export Excel
            </a>
        </div>
        <div style="overflow-x:auto;">
        <table class="bk-admin-table bk-mobile-card-view">
            <thead>
                <tr>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>ID</th>
                    <th>Department</th>
                    <th>Date</th>
                    <th>Weekday</th>
                    <th>OT Hours</th>
                    <th>Workday OT</th>
                    <th>Weekend OT</th>
                    <th>Holiday OT</th>
                    <th>Status</th>
                    @if (_tab == "pending") { <th>Actions</th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var ot in _filtered)
                {
                    <tr>
                        <td style="font-weight:600;font-size:13px;">@GetFirstName(ot.EmployeeId)</td>
                        <td style="font-size:13px;">@GetLastName(ot.EmployeeId)</td>
                        <td style="font-size:12px;color:var(--bk-ink-3);font-family:'JetBrains Mono',monospace;">@GetEmployeeCode(ot.EmployeeId)</td>
                        <td style="font-size:12px;color:var(--bk-ink-3);">@GetDepartment(ot.EmployeeId)</td>
                        <td style="font-size:12px;color:var(--bk-ink-3);">@ot.Date.ToString("dd MMM yyyy")</td>
                        <td style="font-size:12px;color:var(--bk-ink-3);">@ot.Date.ToString("dddd")</td>
                        <td style="font-weight:700;color:var(--bk-accent);">@ot.Hours.ToString("0.0")h</td>
                        <td style="font-size:12px;">@GetOvertimeByCategory(ot, "workday")</td>
                        <td style="font-size:12px;">@GetOvertimeByCategory(ot, "weekend")</td>
                        <td style="font-size:12px;">@GetOvertimeByCategory(ot, "holiday")</td>
                        <td>
                            <span class="bk-admin-pill @(ot.Status == OvertimeStatus.Approved || ot.Status == OvertimeStatus.AutoApproved ? "approved" : ot.Status == OvertimeStatus.Rejected ? "rejected" : "pending")">
                                @ot.StatusDisplay
                            </span>
                        </td>
                        @if (_tab == "pending")
                        {
                            <td>
                                <div style="display:flex;gap:4px;">
                                    <form method="post" action="/api/overtime/@ot.Id/approve" style="display:inline;">
                                        <button type="submit" class="bk-btn bk-btn-primary" style="font-size:11px;padding:6px 12px;min-height:32px;background:linear-gradient(180deg,var(--bk-accent-3),#0d8061);box-shadow:none;">
                                            <span class="material-icons-round" style="font-size:14px;">check</span>
                                            Approve
                                        </button>
                                    </form>
                                    <form method="post" action="/api/overtime/@ot.Id/reject" style="display:inline;">
                                        <button type="submit" class="bk-btn bk-btn-secondary" style="font-size:11px;padding:6px 12px;min-height:32px;color:var(--bk-accent-4);border-color:var(--bk-accent-4);">
                                            <span class="material-icons-round" style="font-size:14px;">close</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
        </div>
        @if (!_filtered.Any())
        {
            <div style="padding:48px 24px;text-align:center;color:var(--bk-ink-3);">
                <div style="width:64px;height:64px;margin:0 auto 16px;background:var(--bk-muted);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                    <span class="material-icons-round" style="font-size:32px;color:var(--bk-ink-3);">schedule</span>
                </div>
                <h3 style="font-size:16px;margin-bottom:4px;color:var(--bk-ink);">No overtime records</h3>
                <p style="font-size:13px;">Click "Auto-Calculate" to generate overtime from attendance records, or add manually.</p>
            </div>
        }
    </div>
</div>

@code {
    private string _tab = "pending";
    private List<OvertimeRecord> _all = new();
    private OvertimeSummary _summary = new();
    private Dictionary<int, Employee> _employeeMap = new();
    private int _orgId;
    private IEnumerable<OvertimeRecord> _filtered => _tab switch
    {
        "pending" => _all.Where(o => o.Status == OvertimeStatus.Pending),
        "approved" => _all.Where(o => o.Status == OvertimeStatus.Approved || o.Status == OvertimeStatus.AutoApproved),
        _ => _all
    };

    protected override async Task OnInitializedAsync()
    {
        // Read tab from query string (?tab=approved) — works without Blazor circuit
        try
        {
            var uri = Nav.ToAbsoluteUri(Nav.Uri);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
            var qTab = query["tab"];
            if (!string.IsNullOrEmpty(qTab) && (qTab == "pending" || qTab == "approved" || qTab == "all"))
                _tab = qTab;

            // Show success toast if we just redirected from the Add Overtime page
            if (query["added"] == "1")
            {
                Snackbar.Add("Overtime record created successfully.", Severity.Success);
            }
        }
        catch { }

        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        _orgId = org.Id;
        await LoadData();
    }

    private async Task LoadData()
    {
        _all = await OvertimeSvc.GetAllAsync(_orgId);
        var now = DateTime.Now;
        _summary = await OvertimeSvc.GetSummaryAsync(_orgId, now.Month, now.Year);

        // Load employee details for the table
        var empIds = _all.Select(o => o.EmployeeId).Distinct().ToList();
        if (empIds.Any())
        {
            var employees = await Db.Employees.Where(e => empIds.Contains(e.Id)).ToListAsync();
            _employeeMap = employees.ToDictionary(e => e.Id);
        }
    }

    private string GetFirstName(int employeeId)
    {
        if (_employeeMap.TryGetValue(employeeId, out var emp) && !string.IsNullOrWhiteSpace(emp.FirstName))
            return emp.FirstName;
        return "—";
    }

    private string GetLastName(int employeeId)
    {
        if (_employeeMap.TryGetValue(employeeId, out var emp) && !string.IsNullOrWhiteSpace(emp.Surname))
            return emp.Surname;
        return "—";
    }

    private string GetEmployeeCode(int employeeId)
    {
        if (_employeeMap.TryGetValue(employeeId, out var emp) && !string.IsNullOrWhiteSpace(emp.EmployeeCode))
            return emp.EmployeeCode;
        return "—";
    }

    private string GetDepartment(int employeeId)
    {
        if (_employeeMap.TryGetValue(employeeId, out var emp) && !string.IsNullOrWhiteSpace(emp.Department))
            return emp.Department;
        return "—";
    }

    private string GetOvertimeByCategory(OvertimeRecord ot, string category)
    {
        var match = category switch
        {
            "workday" => ot.RateType == OvertimeRateType.Standard || ot.RateType == OvertimeRateType.DoubleTime,
            "weekend" => ot.RateType == OvertimeRateType.RestDay,
            "holiday" => ot.RateType == OvertimeRateType.PublicHoliday,
            _ => false
        };
        return match ? $"{ot.Hours:F1}h" : "—";
    }

    private async Task AutoCalculate()
    {
        var from = DateTime.Today.AddDays(-30);
        var to = DateTime.Today;
        var count = await OvertimeSvc.AutoCalculateForDateRangeAsync(_orgId, from, to);
        Snackbar.Add($"Auto-calculated {count} overtime records from attendance.", Severity.Success);
        await LoadData();
    }

    private async Task Approve(int id)
    {
        await OvertimeSvc.ApproveAsync(_orgId, id, "admin@ukuuhr.demo", "Approved.");
        Snackbar.Add("Overtime approved.", Severity.Success);
        await LoadData();
    }

    private async Task Reject(int id)
    {
        await OvertimeSvc.RejectAsync(_orgId, id, "admin@ukuuhr.demo", "Rejected by admin.");
        Snackbar.Add("Overtime rejected.", Severity.Warning);
        await LoadData();
    }

    private string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length < 2 ? (name.Length > 2 ? name[..2].ToUpper() : name.ToUpper()) : $"{parts[0][0]}{parts[^1][0]}".ToUpper();
    }
}
