@page "/shifts"
@attribute [Authorize(Policy = "HrOrAdmin")]
@page "/scheduling"
@attribute [Authorize(Policy = "HrOrAdmin")]
@using Microsoft.EntityFrameworkCore
@inject NavigationManager Nav
@inject ShiftService ShiftSvc
@inject UkuuHrDbContext Db
@inject ISnackbar Snackbar

<div class="bk-admin-fade-in">
    @if (!_loaded)
    {
        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80px 24px;">
            <div style="width:32px;height:32px;border:3px solid var(--bk-line);border-top-color:var(--bk-accent);border-radius:50%;animation:bk-spin 0.8s linear infinite;"></div>
            <p style="margin-top:16px;color:var(--bk-ink-3);font-size:13px;">Loading shifts…</p>
        </div>
    }
    else if (_orgMissing)
    {
        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80px 24px;text-align:center;">
            <span class="material-icons-round" style="font-size:48px;color:var(--bk-ink-3);opacity:0.4;">business</span>
            <h3 style="margin-top:16px;">No Organization Found</h3>
            <p style="color:var(--bk-ink-3);margin:8px 0 20px;max-width:400px;">
                You need to create an organization before you can manage shifts.
            </p>
            <button class="bk-btn bk-btn-primary" @onclick="SeedOrg" disabled="@_seeding">
                @if (_seeding)
                {
                    <span style="width:14px;height:14px;border:2px solid rgba(255,255,255,0.3);border-top-color:white;border-radius:50%;display:inline-block;animation:bk-spin 0.8s linear infinite;"></span>
                }
                <span>Create Default Organization</span>
            </button>
        </div>
    }
    else
    {
        <div class="bk-admin-section-header">
            <div class="bk-admin-section-header-left">
                <div class="bk-admin-greeting">Shift Management · @_shifts.Count active shifts · @_assignments.Count assignments</div>
                <h1 class="bk-admin-h1">Shifts</h1>
                <p class="bk-admin-sub">
                    Define fixed, rotating, flexible, and overnight shifts. Configure attendance tolerance,
                    manage assignments, and view weekly coverage from the sidebar sections below.
                </p>
            </div>
            <div class="bk-admin-actions">
                <a href="/shifts/assignments" class="bk-btn bk-btn-secondary">
                    <span class="material-icons-round" style="font-size:16px;">assignment_ind</span>
                    Assignments
                </a>
                <a href="/shifts/tolerance" class="bk-btn bk-btn-secondary">
                    <span class="material-icons-round" style="font-size:16px;">tune</span>
                    Tolerance
                </a>
                <a href="/shifts/coverage" class="bk-btn bk-btn-secondary">
                    <span class="material-icons-round" style="font-size:16px;">calendar_view_week</span>
                    Coverage
                </a>
                <button class="bk-btn bk-btn-primary" @onclick="() => OpenShiftDialog(null)">
                    <span class="material-icons-round" style="font-size:16px;">add</span>
                    New Shift
                </button>
            </div>
        </div>

    @* ───── KPI cards ───── *@
    <div class="bk-admin-kpi-grid">
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon"><span class="material-icons-round">schedule</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_shifts.Count(s => s.Kind == ShiftKind.Fixed)</div>
            <div class="bk-admin-kpi-label">Fixed Shifts</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon gold"><span class="material-icons-round">autorenew</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_shifts.Count(s => s.Kind == ShiftKind.Rotating)</div>
            <div class="bk-admin-kpi-label">Rotating</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon purple"><span class="material-icons-round">wb_twilight</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_shifts.Count(s => s.Kind == ShiftKind.Overnight)</div>
            <div class="bk-admin-kpi-label">Overnight</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon blue"><span class="material-icons-round">swap_horiz</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_shifts.Count(s => s.Kind == ShiftKind.Flexible)</div>
            <div class="bk-admin-kpi-label">Flexible</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon green"><span class="material-icons-round">groups</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_assignments.Select(a => a.EmployeeId).Distinct().Count()</div>
            <div class="bk-admin-kpi-label">Employees with Shifts</div>
        </div>
    </div>

    @* ───── Quick nav cards ───── *@
    <div style="display:flex;gap:12px;margin-bottom:24px;flex-wrap:wrap;">
        <a href="/shifts/assignments" class="bk-admin-card" style="flex:1;min-width:180px;padding:16px;display:flex;align-items:center;gap:12px;text-decoration:none;cursor:pointer;">
            <div style="width:40px;height:40px;border-radius:10px;background:rgba(37,99,235,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <span class="material-icons-round" style="color:var(--bk-info);font-size:22px;">assignment_ind</span>
            </div>
            <div>
                <div style="font-size:13px;font-weight:700;color:var(--bk-ink);">@_assignments.Count Assignments</div>
                <div style="font-size:11px;color:var(--bk-ink-3);">Manage employee shift assignments</div>
            </div>
        </a>
        <a href="/shifts/tolerance" class="bk-admin-card" style="flex:1;min-width:180px;padding:16px;display:flex;align-items:center;gap:12px;text-decoration:none;cursor:pointer;">
            <div style="width:40px;height:40px;border-radius:10px;background:rgba(245,158,11,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <span class="material-icons-round" style="color:var(--bk-warning);font-size:22px;">tune</span>
            </div>
            <div>
                <div style="font-size:13px;font-weight:700;color:var(--bk-ink);">Tolerance Policy</div>
                <div style="font-size:11px;color:var(--bk-ink-3);">Late, early, absent thresholds</div>
            </div>
        </a>
        <a href="/shifts/coverage" class="bk-admin-card" style="flex:1;min-width:180px;padding:16px;display:flex;align-items:center;gap:12px;text-decoration:none;cursor:pointer;">
            <div style="width:40px;height:40px;border-radius:10px;background:rgba(22,163,74,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <span class="material-icons-round" style="color:var(--bk-success);font-size:22px;">calendar_view_week</span>
            </div>
            <div>
                <div style="font-size:13px;font-weight:700;color:var(--bk-ink);">Weekly Coverage</div>
                <div style="font-size:11px;color:var(--bk-ink-3);">Staffing matrix per shift × day</div>
            </div>
        </a>
    </div>

    @* ───── Shift cards ───── *@
    <div class="bk-admin-kpi-grid" style="grid-template-columns:repeat(auto-fit,minmax(360px,1fr));">
        @foreach (var s in _shifts)
        {
            <div class="bk-admin-card bk-admin-card-hover">
                <div class="bk-admin-card-header" style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;">
                    <div style="display:flex;gap:12px;align-items:center;flex:1;min-width:0;">
                        <div style="width:8px;height:42px;border-radius:4px;background:@(s.Color);flex-shrink:0;"></div>
                        <div style="min-width:0;flex:1;">
                            <h3 style="font-size:15px;font-weight:700;color:var(--bk-ink);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-bottom:4px;">@s.Name</h3>
                            <p style="font-size:12px;color:var(--bk-ink-3);margin:0;">@s.TimeWindow · @s.PlannedHours.ToString("0.0")h planned · @s.BreakMinutes min break</p>
                        </div>
                    </div>
                    <span class="bk-admin-pill @ShiftKindClass(s.Kind)" style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;">
                        @s.KindDisplay
                    </span>
                </div>
                <div class="bk-admin-card-content" style="padding-top:12px;">
                    <p style="font-size:13px;color:var(--bk-ink-2);margin:0 0 12px;line-height:1.5;">@(s.Description ?? "—")</p>
                    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--bk-line);">
                        <span style="font-size:12px;color:var(--bk-ink-3);">Days</span>
                        <span style="font-size:13px;font-weight:600;">@s.DaysDisplay</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--bk-line);">
                        <span style="font-size:12px;color:var(--bk-ink-3);">Assigned to</span>
                        <span style="font-size:13px;font-weight:600;color:var(--bk-accent);">@_assignments.Count(a => a.ShiftId == s.Id) employees</span>
                    </div>
                    @if (s.Kind == ShiftKind.Rotating)
                    {
                        <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--bk-line);">
                            <span style="font-size:12px;color:var(--bk-ink-3);">Rotation</span>
                            <span style="font-size:13px;font-weight:600;">@s.RotationSlots slots × @s.RotationCycleDays days</span>
                        </div>
                    }
                    @if (s.Kind == ShiftKind.Flexible)
                    {
                        <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--bk-line);">
                            <span style="font-size:12px;color:var(--bk-ink-3);">Flex Range</span>
                            <span style="font-size:13px;font-weight:600;">@s.FlexibleMinHours.ToString("0.0")h – @s.FlexibleMaxHours.ToString("0.0")h</span>
                        </div>
                    }
                    <div style="display:flex;gap:8px;margin-top:16px;">
                        <button class="bk-btn bk-btn-secondary" style="flex:1;font-size:12px;padding:8px 12px;" @onclick="() => OpenShiftDialog(s)">
                            <span class="material-icons-round" style="font-size:14px;">edit</span>
                            Edit
                        </button>
                        <button class="bk-btn bk-btn-secondary" style="flex:1;font-size:12px;padding:8px 12px;color:var(--bk-error);" @onclick="() => DeleteShift(s)">
                            <span class="material-icons-round" style="font-size:14px;">delete</span>
                            Delete
                        </button>
                    </div>
                </div>
            </div>
        }
        @if (_shifts.Count == 0)
        {
            <div class="bk-admin-card" style="grid-column:1/-1;text-align:center;padding:48px 24px;">
                <span class="material-icons-round" style="font-size:48px;color:var(--bk-ink-3);opacity:0.5;">schedule</span>
                <h3 style="margin-top:16px;">No shifts defined yet</h3>
                <p style="color:var(--bk-ink-3);margin:8px 0 20px;">Create your first shift to start assigning employees. Morning, mid, night — or any custom window.</p>
                <button class="bk-btn bk-btn-primary" @onclick="() => OpenShiftDialog(null)">
                    <span class="material-icons-round" style="font-size:18px;">add</span>
                    Create First Shift
                </button>
            </div>
        }
    </div>
}

@* ───── Shift create/edit dialog ───── *@
@if (_showShiftDialog)
{
    <div class="bk-modal-backdrop" @onclick="CloseShiftDialog">
        <div class="bk-modal" @onclick:stopPropagation style="max-width:640px;">
            <div class="bk-modal-header">
                <h3>@(_editingShift?.Id > 0 ? "Edit Shift" : "New Shift")</h3>
                <button class="bk-modal-close" @onclick="CloseShiftDialog"><span class="material-icons-round">close</span></button>
            </div>
            <div class="bk-modal-body">
                @if (!string.IsNullOrEmpty(_dialogError))
                {
                    <div style="margin-bottom:16px;padding:10px 14px;background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.25);border-radius:8px;color:#991b1b;font-size:13px;display:flex;align-items:flex-start;gap:8px;">
                        <span class="material-icons-round" style="font-size:16px;flex-shrink:0;margin-top:1px;">error_outline</span>
                        <span>@_dialogError</span>
                    </div>
                }
                <EditForm Model="@_shiftForm" OnValidSubmit="SaveShift">
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                        <div class="bk-field" style="grid-column:1/-1;">
                            <label class="bk-label">Shift Name *</label>
                            <InputText class="bk-input" @bind-Value="_shiftForm.Name" placeholder="e.g. Day Shift (08:00-17:00)" />
                        </div>
                        <div class="bk-field" style="grid-column:1/-1;">
                            <label class="bk-label">Description</label>
                            <InputTextArea class="bk-input" @bind-Value="_shiftForm.Description" rows="2" placeholder="Optional notes about this shift" />
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Shift Type</label>
                            <InputSelect class="bk-input" @bind-Value="_shiftForm.Kind">
                                <option value="@ShiftKind.Fixed">Fixed (same time every day)</option>
                                <option value="@ShiftKind.Rotating">Rotating (cycles between slots)</option>
                                <option value="@ShiftKind.Flexible">Flexible (employee chooses within core hours)</option>
                                <option value="@ShiftKind.Overnight">Overnight (crosses midnight)</option>
                            </InputSelect>
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Color</label>
                            <input type="color" class="bk-input" style="height:42px;padding:4px;" value="@_shiftForm.Color" @oninput="OnColorInput" />
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Start Time</label>
                            <input type="time" class="bk-input" value="@_startTimeStr" @oninput="OnStartTimeInput" />
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">End Time</label>
                            <input type="time" class="bk-input" value="@_endTimeStr" @oninput="OnEndTimeInput" />
                            @if (_shiftForm.IsOvernight)
                            {
                                <small style="color:var(--bk-info);font-size:11px;">⚠ Crosses midnight — check-out rolls into next calendar day.</small>
                            }
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Break (minutes)</label>
                            <InputNumber class="bk-input" @bind-Value="_shiftForm.BreakMinutes" />
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Active Days</label>
                            <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:6px;">
                                @for (int i = 0; i < 7; i++)
                                {
                                    var dayIdx = i;
                                    var dayName = new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" }[i];
                                    var isActive = (_shiftForm.DaysOfWeekMask & (1 << i)) != 0;
                                    <button type="button" @onclick="() => ToggleShiftDay(dayIdx)"
                                            style="padding:6px 10px;border-radius:6px;border:1px solid @(isActive ? "var(--bk-ink)" : "var(--bk-line)");background:@(isActive ? "var(--bk-ink)" : "transparent");color:@(isActive ? "white" : "var(--bk-ink-2)");font-size:11px;font-weight:600;cursor:pointer;font-family:inherit;">
                                        @dayName
                                    </button>
                                }
                            </div>
                        </div>
                        @if (_shiftForm.Kind == ShiftKind.Rotating)
                        {
                            <div class="bk-field">
                                <label class="bk-label">Rotation Slots</label>
                                <InputNumber class="bk-input" @bind-Value="_shiftForm.RotationSlots" />
                            </div>
                            <div class="bk-field">
                                <label class="bk-label">Cycle Days</label>
                                <InputNumber class="bk-input" @bind-Value="_shiftForm.RotationCycleDays" />
                            </div>
                        }
                        @if (_shiftForm.Kind == ShiftKind.Flexible)
                        {
                            <div class="bk-field">
                                <label class="bk-label">Min Hours</label>
                                <InputNumber class="bk-input" @bind-Value="_shiftForm.FlexibleMinHours" />
                            </div>
                            <div class="bk-field">
                                <label class="bk-label">Max Hours</label>
                                <InputNumber class="bk-input" @bind-Value="_shiftForm.FlexibleMaxHours" />
                            </div>
                        }
                    </div>
                    <div style="display:flex;justify-content:flex-end;gap:8px;margin-top:24px;padding-top:16px;border-top:1px solid var(--bk-line);">
                        <button type="button" class="bk-btn bk-btn-secondary" @onclick="CloseShiftDialog" disabled="@_isSaving">Cancel</button>
                        <button type="submit" class="bk-btn bk-btn-primary" disabled="@_isSaving" style="@(_isSaving ? "opacity:0.7;cursor:not-allowed;" : "")">
                            @if (_isSaving)
                            {
                                <span style="width:14px;height:14px;border:2px solid rgba(255,255,255,0.3);border-top-color:white;border-radius:50%;display:inline-block;animation:bk-spin 0.8s linear infinite;"></span>
                            }
                            else
                            {
                                <span class="material-icons-round" style="font-size:16px;">save</span>
                            }
                            @(_editingShift?.Id > 0 ? "Update Shift" : "Create Shift")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<Shift> _shifts = new();
    private List<EmployeeShiftAssignment> _assignments = new();
    private int _orgId;

    // Loading & org state
    private bool _loaded;
    private bool _orgMissing;
    private bool _seeding;

    // Shift dialog state
    private bool _showShiftDialog;
    private bool _isSaving;
    private string _dialogError = "";
    private Shift? _editingShift;
    private Shift _shiftForm = new();
    private string _startTimeStr = "08:00";
    private string _endTimeStr = "17:00";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var org = await Db.Organizations.FirstOrDefaultAsync();
            if (org == null)
            {
                _orgMissing = true;
                return;
            }
            _orgId = org.Id;

            _shifts = await Db.Shifts.Where(s => s.OrganizationId == _orgId && s.IsActive).OrderBy(s => s.Name).ToListAsync();
            _assignments = await Db.EmployeeShiftAssignments
                .Include(a => a.Shift)
                .Include(a => a.Employee)
                .Where(a => a.OrganizationId == _orgId && a.IsActive)
                .ToListAsync();
        }
        catch
        {
            _orgMissing = true;
        }
        finally
        {
            _loaded = true;
        }
    }

    private async Task SeedOrg()
    {
        if (_seeding) return;
        _seeding = true;
        try
        {
            Db.Organizations.Add(new Organization
            {
                Name = "My Organization",
                Slug = "my-org",
                Country = "Zambia",
                Industry = "Technology",
                OwnerUserId = "system",
                CreatedAt = DateTime.UtcNow
            });
            await Db.SaveChangesAsync();
            Nav.NavigateTo("/shifts", forceLoad: true);
        }
        finally
        {
            _seeding = false;
        }
    }

    // ───── Shift dialog handlers ─────
    private void OpenShiftDialog(Shift? existing)
    {
        _editingShift = existing;
        if (existing != null)
        {
            _shiftForm = new Shift
            {
                Id = existing.Id,
                Name = existing.Name,
                Description = existing.Description,
                Kind = existing.Kind,
                Color = existing.Color,
                StartMinutes = existing.StartMinutes,
                EndMinutes = existing.EndMinutes,
                BreakMinutes = existing.BreakMinutes,
                DaysOfWeekMask = existing.DaysOfWeekMask,
                RotationCycleDays = existing.RotationCycleDays,
                RotationSlots = existing.RotationSlots,
                FlexibleMinHours = existing.FlexibleMinHours,
                FlexibleMaxHours = existing.FlexibleMaxHours,
                FlexibleCoreStartMinutes = existing.FlexibleCoreStartMinutes,
                FlexibleCoreEndMinutes = existing.FlexibleCoreEndMinutes,
                IsActive = existing.IsActive
            };
            _startTimeStr = TimeSpan.FromMinutes(existing.StartMinutes).ToString(@"hh\:mm");
            _endTimeStr = TimeSpan.FromMinutes(existing.EndMinutes).ToString(@"hh\:mm");
        }
        else
        {
            _shiftForm = new Shift
            {
                Color = "#25163F",
                StartMinutes = 8 * 60,
                EndMinutes = 17 * 60,
                BreakMinutes = 60,
                DaysOfWeekMask = 0b0011111,
                RotationCycleDays = 7,
                RotationSlots = 2,
                FlexibleMinHours = 6.0,
                FlexibleMaxHours = 9.0,
                IsActive = true
            };
            _startTimeStr = "08:00";
            _endTimeStr = "17:00";
        }
        _showShiftDialog = true;
    }

    private void CloseShiftDialog() => _showShiftDialog = false;

    private async Task SaveShift()
    {
        _dialogError = "";
        _isSaving = true;
        try
        {
            // Parse times.
            if (TimeSpan.TryParse(_startTimeStr, out var st)) _shiftForm.StartMinutes = (int)st.TotalMinutes;
            if (TimeSpan.TryParse(_endTimeStr, out var et)) _shiftForm.EndMinutes = (int)et.TotalMinutes;

            // Validate via engine.
            var errors = ShiftEngine.ValidateShift(_shiftForm);
            if (errors.Count > 0)
            {
                _dialogError = string.Join(" ", errors);
                return;
            }

            if (_editingShift != null && _editingShift.Id > 0)
            {
                await ShiftSvc.UpdateShiftAsync(_orgId, _shiftForm, "admin@ukuuhr.demo");
                Snackbar.Add($"Shift '{_shiftForm.Name}' updated.", Severity.Success);
            }
            else
            {
                await ShiftSvc.CreateShiftAsync(_orgId, _shiftForm, "admin@ukuuhr.demo");
                Snackbar.Add($"Shift '{_shiftForm.Name}' created.", Severity.Success);
            }
            _shifts = await Db.Shifts.Where(s => s.OrganizationId == _orgId && s.IsActive).OrderBy(s => s.Name).ToListAsync();
            _showShiftDialog = false;
        }
        catch (Exception ex)
        {
            _dialogError = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteShift(Shift s)
    {
        try
        {
            await ShiftSvc.DeleteShiftAsync(_orgId, s.Id, "admin@ukuuhr.demo");
            _shifts = await Db.Shifts.Where(x => x.OrganizationId == _orgId && x.IsActive).OrderBy(x => x.Name).ToListAsync();
            _assignments = await Db.EmployeeShiftAssignments.Include(a => a.Shift).Include(a => a.Employee)
                .Where(a => a.OrganizationId == _orgId && a.IsActive).ToListAsync();
            Snackbar.Add($"Shift '{s.Name}' deactivated.", Severity.Info);
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private void ToggleShiftDay(int dayIdx)
    {
        _shiftForm.DaysOfWeekMask ^= (1 << dayIdx);
    }

    // ───── Helpers ─────
    private static string ShiftKindClass(ShiftKind kind) => kind switch
    {
        ShiftKind.Fixed => "approved",
        ShiftKind.Rotating => "pending",
        ShiftKind.Overnight => "rejected",
        ShiftKind.Flexible => "info",
        _ => ""
    };

    // ───── Input handlers ─────
    private void OnColorInput(Microsoft.AspNetCore.Components.ChangeEventArgs e)
        => _shiftForm.Color = e.Value?.ToString() ?? "#25163F";

    private void OnStartTimeInput(Microsoft.AspNetCore.Components.ChangeEventArgs e)
        => _startTimeStr = e.Value?.ToString() ?? "08:00";

    private void OnEndTimeInput(Microsoft.AspNetCore.Components.ChangeEventArgs e)
        => _endTimeStr = e.Value?.ToString() ?? "17:00";
}
