@page "/shifts"
@attribute [Authorize(Policy = "HrOrAdmin")]
@page "/scheduling"
@attribute [Authorize(Policy = "HrOrAdmin")]
@using Microsoft.EntityFrameworkCore
@inject NavigationManager Nav
@inject ShiftService ShiftSvc
@inject UkuuHrDbContext Db
@inject ISnackbar Snackbar

<div class="bk-admin-fade-in">
    @if (!_loaded)
    {
        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80px 24px;">
            <div style="width:32px;height:32px;border:3px solid var(--bk-line);border-top-color:var(--bk-accent);border-radius:50%;animation:bk-spin 0.8s linear infinite;"></div>
            <p style="margin-top:16px;color:var(--bk-ink-3);font-size:13px;">Loading shifts…</p>
        </div>
    }
    else if (_orgMissing)
    {
        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80px 24px;text-align:center;">
            <span class="material-icons-round" style="font-size:48px;color:var(--bk-ink-3);opacity:0.4;">business</span>
            <h3 style="margin-top:16px;">No Organization Found</h3>
            <p style="color:var(--bk-ink-3);margin:8px 0 20px;max-width:400px;">
                You need to create an organization before you can manage shifts.
            </p>
            <form method="post" action="/api/organization/seed" style="display:inline;">
                <button type="submit" class="bk-btn bk-btn-primary">
                    <span class="material-icons-round" style="font-size:16px;">add_business</span>
                    Create Default Organization
                </button>
            </form>
        </div>
    }
    else
    {
        <div class="bk-admin-section-header">
            <div class="bk-admin-section-header-left">
                <div class="bk-admin-greeting">Shift Management · @_shifts.Count active shifts · @_assignments.Count assignments</div>
                <h1 class="bk-admin-h1">Shifts</h1>
                <p class="bk-admin-sub">
                    Define fixed, rotating, flexible, and overnight shifts. Configure attendance tolerance,
                    manage assignments, and view weekly coverage from the sidebar sections below.
                </p>
            </div>
            <div class="bk-admin-actions">
                <a href="/shifts/assignments" class="bk-btn bk-btn-secondary">
                    <span class="material-icons-round" style="font-size:16px;">assignment_ind</span>
                    Assignments
                </a>
                <a href="/shifts/tolerance" class="bk-btn bk-btn-secondary">
                    <span class="material-icons-round" style="font-size:16px;">tune</span>
                    Tolerance
                </a>
                <a href="/shifts/coverage" class="bk-btn bk-btn-secondary">
                    <span class="material-icons-round" style="font-size:16px;">calendar_view_week</span>
                    Coverage
                </a>
                <a href="/shifts/add" class="bk-btn bk-btn-primary" style="text-decoration:none;">
                    <span class="material-icons-round" style="font-size:16px;">add</span>
                    New Shift
                </a>
                    <span class="material-icons-round" style="font-size:16px;">add</span>
                    New Shift
                </button>
            </div>
        </div>

    @* ───── KPI cards ───── *@
    <div class="bk-admin-kpi-grid">
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon"><span class="material-icons-round">schedule</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_shifts.Count(s => s.Kind == ShiftKind.Fixed)</div>
            <div class="bk-admin-kpi-label">Fixed Shifts</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon gold"><span class="material-icons-round">autorenew</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_shifts.Count(s => s.Kind == ShiftKind.Rotating)</div>
            <div class="bk-admin-kpi-label">Rotating</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon purple"><span class="material-icons-round">wb_twilight</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_shifts.Count(s => s.Kind == ShiftKind.Overnight)</div>
            <div class="bk-admin-kpi-label">Overnight</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon blue"><span class="material-icons-round">swap_horiz</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_shifts.Count(s => s.Kind == ShiftKind.Flexible)</div>
            <div class="bk-admin-kpi-label">Flexible</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon green"><span class="material-icons-round">groups</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_assignments.Select(a => a.EmployeeId).Distinct().Count()</div>
            <div class="bk-admin-kpi-label">Employees with Shifts</div>
        </div>
    </div>

    @* ───── Quick nav cards ───── *@
    <div style="display:flex;gap:12px;margin-bottom:24px;flex-wrap:wrap;">
        <a href="/shifts/assignments" class="bk-admin-card" style="flex:1;min-width:180px;padding:16px;display:flex;align-items:center;gap:12px;text-decoration:none;cursor:pointer;">
            <div style="width:40px;height:40px;border-radius:10px;background:rgba(37,99,235,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <span class="material-icons-round" style="color:var(--bk-info);font-size:22px;">assignment_ind</span>
            </div>
            <div>
                <div style="font-size:13px;font-weight:700;color:var(--bk-ink);">@_assignments.Count Assignments</div>
                <div style="font-size:11px;color:var(--bk-ink-3);">Manage employee shift assignments</div>
            </div>
        </a>
        <a href="/shifts/tolerance" class="bk-admin-card" style="flex:1;min-width:180px;padding:16px;display:flex;align-items:center;gap:12px;text-decoration:none;cursor:pointer;">
            <div style="width:40px;height:40px;border-radius:10px;background:rgba(245,158,11,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <span class="material-icons-round" style="color:var(--bk-warning);font-size:22px;">tune</span>
            </div>
            <div>
                <div style="font-size:13px;font-weight:700;color:var(--bk-ink);">Tolerance Policy</div>
                <div style="font-size:11px;color:var(--bk-ink-3);">Late, early, absent thresholds</div>
            </div>
        </a>
        <a href="/shifts/coverage" class="bk-admin-card" style="flex:1;min-width:180px;padding:16px;display:flex;align-items:center;gap:12px;text-decoration:none;cursor:pointer;">
            <div style="width:40px;height:40px;border-radius:10px;background:rgba(22,163,74,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <span class="material-icons-round" style="color:var(--bk-success);font-size:22px;">calendar_view_week</span>
            </div>
            <div>
                <div style="font-size:13px;font-weight:700;color:var(--bk-ink);">Weekly Coverage</div>
                <div style="font-size:11px;color:var(--bk-ink-3);">Staffing matrix per shift × day</div>
            </div>
        </a>
    </div>

    @* ───── Shift cards ───── *@
    <div class="bk-admin-kpi-grid" style="grid-template-columns:repeat(auto-fit,minmax(360px,1fr));">
        @foreach (var s in _shifts)
        {
            <div class="bk-admin-card bk-admin-card-hover">
                <div class="bk-admin-card-header" style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;">
                    <div style="display:flex;gap:12px;align-items:center;flex:1;min-width:0;">
                        <div style="width:8px;height:42px;border-radius:4px;background:@(s.Color);flex-shrink:0;"></div>
                        <div style="min-width:0;flex:1;">
                            <h3 style="font-size:15px;font-weight:700;color:var(--bk-ink);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-bottom:4px;">@s.Name</h3>
                            <p style="font-size:12px;color:var(--bk-ink-3);margin:0;">@s.TimeWindow · @s.PlannedHours.ToString("0.0")h planned · @s.BreakMinutes min break</p>
                        </div>
                    </div>
                    <span class="bk-admin-pill @ShiftKindClass(s.Kind)" style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;">
                        @s.KindDisplay
                    </span>
                </div>
                <div class="bk-admin-card-content" style="padding-top:12px;">
                    <p style="font-size:13px;color:var(--bk-ink-2);margin:0 0 12px;line-height:1.5;">@(s.Description ?? "—")</p>
                    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--bk-line);">
                        <span style="font-size:12px;color:var(--bk-ink-3);">Days</span>
                        <span style="font-size:13px;font-weight:600;">@s.DaysDisplay</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--bk-line);">
                        <span style="font-size:12px;color:var(--bk-ink-3);">Assigned to</span>
                        <span style="font-size:13px;font-weight:600;color:var(--bk-accent);">@_assignments.Count(a => a.ShiftId == s.Id) employees</span>
                    </div>
                    @if (s.Kind == ShiftKind.Rotating)
                    {
                        <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--bk-line);">
                            <span style="font-size:12px;color:var(--bk-ink-3);">Rotation</span>
                            <span style="font-size:13px;font-weight:600;">@s.RotationSlots slots × @s.RotationCycleDays days</span>
                        </div>
                    }
                    @if (s.Kind == ShiftKind.Flexible)
                    {
                        <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--bk-line);">
                            <span style="font-size:12px;color:var(--bk-ink-3);">Flex Range</span>
                            <span style="font-size:13px;font-weight:600;">@s.FlexibleMinHours.ToString("0.0")h – @s.FlexibleMaxHours.ToString("0.0")h</span>
                        </div>
                    }
                    <div style="display:flex;gap:8px;margin-top:16px;">
                        <a href="/shifts/@s.Id/edit" class="bk-btn bk-btn-secondary" style="flex:1;font-size:12px;padding:8px 12px;text-decoration:none;text-align:center;">
                            <span class="material-icons-round" style="font-size:14px;">edit</span>
                            Edit
                        </a>
                            <span class="material-icons-round" style="font-size:14px;">edit</span>
                            Edit
                        </button>
                        <form method="post" action="/api/shifts/delete/@s.Id" style="flex:1;" onsubmit="return confirm('Delete shift @s.Name?');">
                            <button type="submit" class="bk-btn bk-btn-secondary" style="width:100%;font-size:12px;padding:8px 12px;color:var(--bk-error);">
                                <span class="material-icons-round" style="font-size:14px;">delete</span>
                                Delete
                            </button>
                        </form>
                            <span class="material-icons-round" style="font-size:14px;">delete</span>
                            Delete
                        </button>
                    </div>
                </div>
            </div>
        }
        @if (_shifts.Count == 0)
        {
            <div class="bk-admin-card" style="grid-column:1/-1;text-align:center;padding:48px 24px;">
                <span class="material-icons-round" style="font-size:48px;color:var(--bk-ink-3);opacity:0.5;">schedule</span>
                <h3 style="margin-top:16px;">No shifts defined yet</h3>
                <p style="color:var(--bk-ink-3);margin:8px 0 20px;">Create your first shift to start assigning employees. Morning, mid, night — or any custom window.</p>
                    <span class="material-icons-round" style="font-size:18px;">add</span>
                    Create First Shift
                </button>
            </div>
        }
    </div>
}

</div>

@code {
    private List<Shift> _shifts = new();
    private List<EmployeeShiftAssignment> _assignments = new();
    private int _orgId;

    // Loading & org state
    private bool _loaded;
    private bool _orgMissing;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var org = await Db.Organizations.FirstOrDefaultAsync();
            if (org == null)
            {
                _orgMissing = true;
                return;
            }
            _orgId = org.Id;

            _shifts = await Db.Shifts.Where(s => s.OrganizationId == _orgId && s.IsActive).OrderBy(s => s.Name).ToListAsync();
            _assignments = await Db.EmployeeShiftAssignments
                .Include(a => a.Shift)
                .Include(a => a.Employee)
                .Where(a => a.OrganizationId == _orgId && a.IsActive)
                .ToListAsync();
        }
        catch
        {
            _orgMissing = true;
        }
        finally
        {
            _loaded = true;
        }
    }

    private static string ShiftKindClass(ShiftKind kind) => kind switch
    {
        ShiftKind.Fixed => "active",
        ShiftKind.Rotating => "pending",
        ShiftKind.Overnight => "approved",
        ShiftKind.Flexible => "active",
        _ => "active"
    };
}
