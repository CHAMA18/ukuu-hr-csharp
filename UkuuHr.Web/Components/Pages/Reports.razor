@page "/reports"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@inject UkuuHrDbContext Db

<div class="bk-admin-fade-in">
    <div class="bk-admin-section-header">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">Reports & Analytics · Last 90 days</div>
            <h1 class="bk-admin-h1">Reports & Analytics</h1>
            <p class="bk-admin-sub">Workforce insights — headcount, payroll spend, attendance, and leave trends.</p>
        </div>
        <div class="bk-admin-actions">
            <select @bind="_period" style="height:40px;border:1px solid var(--bk-line);border-radius:999px;background:rgba(255,255,255,0.74);padding:0 16px;font-family:inherit;font-size:13px;color:var(--bk-ink);outline:none;min-width:160px;">
                <option value="30d">Last 30 days</option>
                <option value="90d">Last quarter</option>
                <option value="ytd">Year to date</option>
            </select>
            <button class="bk-btn bk-btn-secondary">
                <span class="material-icons-round" style="font-size:16px;">download</span>
                Export PDF
            </button>
        </div>
    </div>

    <!-- KPI Row -->
    <div class="bk-admin-kpi-grid">
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon blue"><span class="material-icons-round">groups</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_totalEmps</div>
            <div class="bk-admin-kpi-label">Total Headcount</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon gold"><span class="material-icons-round">payments</span></div>
            </div>
            <div class="bk-admin-kpi-value">@if (_avgSalary > 0) { <text>ZMW @_avgSalary.ToString("N0")</text> } else { <text>—</text> }</div>
            <div class="bk-admin-kpi-label">Avg Salary</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon green"><span class="material-icons-round">check_circle</span></div>
            </div>
            <div class="bk-admin-kpi-value">@if (_avgAttendance > 0) { @_avgAttendance.ToString("0.0")<text>%</text> } else { <text>—</text> }</div>
            <div class="bk-admin-kpi-label">Avg Attendance</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon purple"><span class="material-icons-round">event_available</span></div>
            </div>
            <div class="bk-admin-kpi-value">@if (_leaveUtil > 0) { @_leaveUtil.ToString("0.0")<text>%</text> } else { <text>—</text> }</div>
            <div class="bk-admin-kpi-label">Leave Utilization</div>
        </div>
    </div>

    <!-- Headcount trend chart -->
    <div class="bk-admin-card" style="margin-bottom:24px;">
        <div class="bk-admin-card-header">
            <div>
                <h3>Headcount Growth — Last 12 Months</h3>
                <p>Cumulative employee count by month</p>
            </div>
        </div>
        <div class="bk-admin-card-content">
            @if (_totalEmps > 0)
            {
                <svg viewBox="0 0 800 240" style="width:100%;height:240px;">
                    @{
                        // Use the actual current headcount for the trend — historical
                        // data would come from an Employees.CreatedAt time-series query.
                        // For now we draw a flat line at the current value (no phantom history).
                        var data = Enumerable.Repeat(_totalEmps, 12).ToArray();
                        var maxData = Math.Max(1, data.Max());
                        var w = 800.0; var h = 200.0;
                        var padding = 40;
                }
                @for (int i = 0; i <= 4; i++)
                {
                    var y = padding + (h - 2 * padding) * i / 4;
                    <line x1="@padding" y1="@y" x2="@(w-padding)" y2="@y" stroke="var(--bk-line)" stroke-width="1" stroke-dasharray="3 3" />
                }
                <path d="@GetAreaPath(data, w, h, padding, maxData)" fill="url(#headcountGradient)" opacity="0.4" />
                <path d="@GetLinePath(data, w, h, padding, maxData)" fill="none" stroke="#0a0a0a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                @for (int i = 0; i < data.Length; i++)
                {
                    var x = padding + (w - 2 * padding) * i / (data.Length - 1);
                    var y = padding + (h - 2 * padding) * (1 - (double)data[i] / maxData);
                    <circle cx="@x" cy="@y" r="4" fill="#0a0a0a" stroke="white" stroke-width="2" />
                }
                <defs>
                    <linearGradient id="headcountGradient" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#d89c11" stop-opacity="0.4" />
                        <stop offset="100%" stop-color="#d89c11" stop-opacity="0" />
                    </linearGradient>
                </defs>
            </svg>
            }
            else
            {
                <div style="padding:48px 24px;text-align:center;color:var(--bk-ink-3);">
                    <span class="material-icons-round" style="font-size:48px;opacity:0.4;">show_chart</span>
                    <h3 style="margin-top:12px;font-size:16px;color:var(--bk-ink-2);">No headcount data yet</h3>
                    <p style="font-size:13px;margin-top:4px;">Add employees to see headcount growth trends.</p>
                </div>
            }
        </div>
    </div>

    <!-- Two columns -->
    <div class="bk-admin-grid-2-even">
        <!-- Department distribution -->
        <div class="bk-admin-card">
            <div class="bk-admin-card-header">
                <div>
                    <h3>By Department</h3>
                    <p>Headcount distribution</p>
                </div>
            </div>
            <div class="bk-admin-card-content">
                @{
                    var total = _byDept.Values.Sum();
                    var colors = new[] { "#d89c11", "#6c63ff", "#14a37f", "#e85d75", "#0a0a0a", "#8b80ff", "#2dd4a7" };
                }
                <div style="display:flex;align-items:center;gap:24px;">
                    <svg width="160" height="160" viewBox="0 0 160 160">
                        @{
                            var cumulative = 0.0;
                            var idx = 0;
                        }
                        @foreach (var dept in _byDept.OrderByDescending(d => d.Value))
                        {
                            var pct = (double)dept.Value / total;
                            var startAngle = cumulative * 2 * Math.PI - Math.PI / 2;
                            var endAngle = (cumulative + pct) * 2 * Math.PI - Math.PI / 2;
                            var x1 = 80 + 70 * Math.Cos(startAngle);
                            var y1 = 80 + 70 * Math.Sin(startAngle);
                            var x2 = 80 + 70 * Math.Cos(endAngle);
                            var y2 = 80 + 70 * Math.Sin(endAngle);
                            var largeArc = pct > 0.5 ? 1 : 0;
                            <path d="M 80 80 L @x1.ToString("0.00") @y1.ToString("0.00") A 70 70 0 @largeArc 1 @x2.ToString("0.00") @y2.ToString("0.00") Z" fill="@colors[idx % colors.Length]" />
                            cumulative += pct;
                            idx++;
                        }
                        <circle cx="80" cy="80" r="40" fill="var(--bk-bg-strong)" />
                    </svg>
                    <div style="flex:1;display:flex;flex-direction:column;gap:6px;">
                        @{ idx = 0; }
                        @foreach (var dept in _byDept.OrderByDescending(d => d.Value))
                        {
                            <div style="display:flex;align-items:center;gap:8px;font-size:12px;">
                                <span style="width:10px;height:10px;border-radius:3px;background:@colors[idx % colors.Length];"></span>
                                <span style="flex:1;color:var(--bk-ink-3);">@dept.Key</span>
                                <span style="font-weight:700;color:var(--bk-ink);">@dept.Value</span>
                                <span style="color:var(--bk-ink-3);width:36px;text-align:right;">@((double)dept.Value / total * 100).ToString("0")%</span>
                            </div>
                            idx++;
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Payroll trend -->
        <div class="bk-admin-card">
            <div class="bk-admin-card-header">
                <div>
                    <h3>Payroll Spend — Last 6 Months</h3>
                    <p>Total monthly gross payroll (ZMW '000)</p>
                </div>
            </div>
            <div class="bk-admin-card-content">
                @if (_avgSalary > 0)
                {
                    <svg viewBox="0 0 400 200" style="width:100%;height:200px;">
                        @{
                            // No historical payroll data in the DB — draw a flat bar
                            // at the current average salary (no phantom trend).
                            var currentBar = Math.Round(_avgSalary / 1000, 1);
                            var bars = Enumerable.Repeat(currentBar, 6).ToArray();
                            var maxBar = Math.Max(1.0, bars.Max());
                        }
                        @for (int i = 0; i < bars.Length; i++)
                        {
                            var barH = (bars[i] / maxBar) * 140;
                            var x = 40 + i * 60;
                            <rect x="@x" y="@(180-barH)" width="40" height="@barH" fill="url(#barGradient)" rx="6" />
                        }
                    <defs>
                        <linearGradient id="barGradient" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="#d89c11" />
                            <stop offset="100%" stop-color="#b8810a" />
                        </linearGradient>
                    </defs>
                </svg>
                }
                else
                {
                    <div style="padding:48px 24px;text-align:center;color:var(--bk-ink-3);">
                        <span class="material-icons-round" style="font-size:48px;opacity:0.4;">bar_chart</span>
                        <h3 style="margin-top:12px;font-size:16px;color:var(--bk-ink-2);">No payroll data yet</h3>
                        <p style="font-size:13px;margin-top:4px;">Add employees with salaries to see payroll trends.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string _period = "90d";
    private int _totalEmps;
    private double _avgSalary;
    private double _avgAttendance;
    private double _leaveUtil;
    private Dictionary<string, int> _byDept = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        var emps = await Db.Employees.Where(e => e.OrganizationId == org.Id).ToListAsync();
        _totalEmps = emps.Count;
        _avgSalary = emps.Any() ? emps.Average(e => e.BasicSalary) : 0;
        _byDept = emps.Where(e => e.Department != null).GroupBy(e => e.Department!).ToDictionary(g => g.Key, g => g.Count());

        var attendance = await Db.Attendances.Where(a => a.OrganizationId == org.Id && a.Date >= DateTime.Today.AddDays(-30)).ToListAsync();
        _avgAttendance = attendance.Any() ? attendance.Count(a => a.Status != AttendanceStatus.Absent) * 100.0 / attendance.Count : 0;

        var totalLeave = 21;
        var approvedLeaves = await Db.LeaveRequests
            .Where(l => l.OrganizationId == org.Id && l.Status == LeaveRequestStatus.Approved)
            .ToListAsync();
        var usedLeave = approvedLeaves.Where(l => l.StartDate.Year == DateTime.Now.Year).Sum(l => l.RequestedDays);
        _leaveUtil = totalLeave > 0 ? Math.Min(100, usedLeave * 100.0 / (totalLeave * _totalEmps)) : 0;
        }
        catch
        {
            // Fall back to empty data — page renders with defaults
        }
    }

    private string GetLinePath(int[] data, double w, double h, int padding, int max)
    {
        var pts = data.Select((v, i) => new {
            X = padding + (w - 2 * padding) * i / (data.Length - 1),
            Y = padding + (h - 2 * padding) * (1 - (double)v / max)
        }).ToList();
        return "M " + string.Join(" L ", pts.Select(p => $"{p.X:0.00} {p.Y:0.00}"));
    }

    private string GetAreaPath(int[] data, double w, double h, int padding, int max)
    {
        var pts = data.Select((v, i) => new {
            X = padding + (w - 2 * padding) * i / (data.Length - 1),
            Y = padding + (h - 2 * padding) * (1 - (double)v / max)
        }).ToList();
        return $"M {pts.First().X:0.00} {h - padding} L " + string.Join(" L ", pts.Select(p => $"{p.X:0.00} {p.Y:0.00}")) + $" L {pts.Last().X:0.00} {h - padding} Z";
    }
}
