@page "/dashboard"
@using Microsoft.EntityFrameworkCore
@inject EmployeeService EmployeeSvc
@inject AttendanceService AttendanceSvc
@inject LeaveService LeaveSvc
@inject PayrollService PayrollSvc
@inject UkuuHrDbContext Db

<div class="ukuu-fade-in">
    <div class="ukuu-section-header" style="display:flex;justify-content:space-between;align-items:flex-end;">
        <div>
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:6px;">
                <span style="font-size:13px;font-weight:600;color:var(--ukuu-accent-gold);text-transform:uppercase;letter-spacing:0.08em;">Good morning, Chungu</span>
                <span class="ukuu-status-pill ukuu-status-active" style="font-size:10px;">All systems operational</span>
            </div>
            <h1>Workspace Overview</h1>
            <p>Here's what's happening across UkuuHR Demo Ltd today.</p>
        </div>
        <div style="display:flex;gap:8px;">
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Download">Export Report</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="@(() => Nav.NavigateTo("/employees/add"))" Style="background:linear-gradient(135deg,#25163F 0%,#4A3C68 100%) !important;">Add Employee</MudButton>
        </div>
    </div>

    <!-- KPI ROW -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:20px;margin-bottom:32px;">
        <div class="ukuu-kpi-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;">
                <div style="width:44px;height:44px;border-radius:12px;background:var(--ukuu-info-bg);color:var(--ukuu-info);display:flex;align-items:center;justify-content:center;">
                    <span class="material-icons-round">groups</span>
                </div>
                <span class="ukuu-kpi-delta ukuu-kpi-delta-up">
                    <span class="material-icons-round" style="font-size:14px;">trending_up</span>
                    +12%
                </span>
            </div>
            <div class="ukuu-kpi-value">@_totalEmployees</div>
            <div class="ukuu-kpi-label">Total Employees</div>
            <div style="margin-top:8px;font-size:12px;color:var(--ukuu-text-subtle);">@_activeEmployees active · @_onProbation on probation</div>
        </div>

        <div class="ukuu-kpi-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;">
                <div style="width:44px;height:44px;border-radius:12px;background:var(--ukuu-success-bg);color:var(--ukuu-success);display:flex;align-items:center;justify-content:center;">
                    <span class="material-icons-round">check_circle</span>
                </div>
                <span class="ukuu-kpi-delta ukuu-kpi-delta-up">
                    <span class="material-icons-round" style="font-size:14px;">trending_up</span>
                    +4%
                </span>
            </div>
            <div class="ukuu-kpi-value">@_attendanceToday.ToString("0.0")%</div>
            <div class="ukuu-kpi-label">Attendance Today</div>
            <div style="margin-top:8px;font-size:12px;color:var(--ukuu-text-subtle);">@_presentToday present · @_onLeaveToday on leave</div>
        </div>

        <div class="ukuu-kpi-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;">
                <div style="width:44px;height:44px;border-radius:12px;background:var(--ukuu-warning-bg);color:var(--ukuu-warning);display:flex;align-items:center;justify-content:center;">
                    <span class="material-icons-round">event_available</span>
                </div>
                <span class="ukuu-kpi-delta ukuu-kpi-delta-down">
                    <span class="material-icons-round" style="font-size:14px;">trending_down</span>
                    -2
                </span>
            </div>
            <div class="ukuu-kpi-value">@_pendingLeave</div>
            <div class="ukuu-kpi-label">Pending Leave Requests</div>
            <div style="margin-top:8px;font-size:12px;color:var(--ukuu-text-subtle);">@_approvedThisMonth approved this month</div>
        </div>

        <div class="ukuu-kpi-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;">
                <div style="width:44px;height:44px;border-radius:12px;background:#EDE0FE;color:#7C3AED;display:flex;align-items:center;justify-content:center;">
                    <span class="material-icons-round">payments</span>
                </div>
                <span class="ukuu-kpi-delta ukuu-kpi-delta-up">
                    <span class="material-icons-round" style="font-size:14px;">trending_up</span>
                    +8%
                </span>
            </div>
            <div class="ukuu-kpi-value">ZMW @(_monthlyPayroll.ToString("N0"))</div>
            <div class="ukuu-kpi-label">Monthly Payroll</div>
            <div style="margin-top:8px;font-size:12px;color:var(--ukuu-text-subtle);">@_pendingPayroll pending approval</div>
        </div>
    </div>

    <!-- MAIN GRID -->
    <div style="display:grid;grid-template-columns:1fr 360px;gap:24px;margin-bottom:32px;">

        <!-- LEFT: Charts + tables -->
        <div style="display:flex;flex-direction:column;gap:24px;">

            <!-- Workforce by department -->
            <div class="mud-card">
                <div class="mud-card-header" style="display:flex;justify-content:space-between;align-items:center;">
                    <div>
                        <h3 style="font-size:16px;font-weight:700;margin-bottom:2px;">Workforce Distribution</h3>
                        <p style="font-size:12px;color:var(--ukuu-text-muted);margin:0;">Headcount by department</p>
                    </div>
                    <MudButton Variant="Variant.Text" Color="Color.Default" EndIcon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" OnClick="@(() => Nav.NavigateTo("/reports"))">View Report</MudButton>
                </div>
                <div class="mud-card-content">
                    @if (_deptCounts.Any())
                    {
                        <div style="display:flex;flex-direction:column;gap:14px;">
                            @{
                                var maxCount = _deptCounts.Values.Max();
                            }
                            @foreach (var dept in _deptCounts.OrderByDescending(d => d.Value))
                            {
                                var pct = (int)(dept.Value * 100.0 / maxCount);
                                <div>
                                    <div style="display:flex;justify-content:space-between;margin-bottom:6px;font-size:13px;">
                                        <span style="font-weight:600;color:var(--ukuu-text);">@dept.Key</span>
                                        <span style="font-weight:700;color:var(--ukuu-ink);">@dept.Value employees</span>
                                    </div>
                                    <div style="height:8px;background:var(--ukuu-surface-alt);border-radius:100px;overflow:hidden;">
                                        <div style="height:100%;width:@(pct)%;background:linear-gradient(90deg,#25163F 0%,#6E5F92 100%);border-radius:100px;transition:width 0.6s ease;"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="ukuu-empty">
                            <div class="ukuu-empty-icon"><span class="material-icons-round">groups</span></div>
                            <p>No employees yet.</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Recent employees -->
            <div class="mud-card">
                <div class="mud-card-header" style="display:flex;justify-content:space-between;align-items:center;">
                    <div>
                        <h3 style="font-size:16px;font-weight:700;margin-bottom:2px;">Recent Hires</h3>
                        <p style="font-size:12px;color:var(--ukuu-text-muted);margin:0;">Newest members of your team</p>
                    </div>
                    <MudButton Variant="Variant.Text" Color="Color.Default" EndIcon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" OnClick="@(() => Nav.NavigateTo("/employees"))">View All</MudButton>
                </div>
                <MudTable Items="@_recentEmployees" Hover="true" Elevation="0" Style="border-radius:0 0 16px 16px;overflow:hidden;">
                    <HeaderContent>
                        <MudTh>Employee</MudTh>
                        <MudTh>Role</MudTh>
                        <MudTh>Department</MudTh>
                        <MudTh>Joined</MudTh>
                        <MudTh>Status</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <div style="display:flex;align-items:center;gap:12px;">
                                <MudAvatar Color="Color.Primary" Size="Size.Medium" Style="background:linear-gradient(135deg,#25163F,#6E5F92);">@context.Initials</MudAvatar>
                                <div>
                                    <div style="font-weight:600;color:var(--ukuu-text);font-size:13px;">@context.FullName</div>
                                    <div style="font-size:11px;color:var(--ukuu-text-subtle);">@context.Email</div>
                                </div>
                            </div>
                        </MudTd>
                        <MudTd Style="font-weight:500;">@context.JobTitle</MudTd>
                        <MudTd>@context.Department</MudTd>
                        <MudTd Style="color:var(--ukuu-text-muted);font-size:12px;">@(context.JoiningDate?.ToString("dd MMM yyyy") ?? "—")</MudTd>
                        <MudTd>
                            <span class="ukuu-status-pill @(context.Status == EmploymentStatus.Active ? "ukuu-status-active" : context.Status == EmploymentStatus.Probation ? "ukuu-status-probation" : "ukuu-status-inactive")">
                                @context.StatusDisplay
                            </span>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </div>

            <!-- Payroll overview -->
            <div class="mud-card">
                <div class="mud-card-header" style="display:flex;justify-content:space-between;align-items:center;">
                    <div>
                        <h3 style="font-size:16px;font-weight:700;margin-bottom:2px;">Payroll Snapshot — @DateTime.Now.ToString("MMMM yyyy")</h3>
                        <p style="font-size:12px;color:var(--ukuu-text-muted);margin:0;">Gross-to-net summary for current pay period</p>
                    </div>
                    <MudButton Variant="Variant.Text" Color="Color.Default" EndIcon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" OnClick="@(() => Nav.NavigateTo("/payroll"))">Open Payroll</MudButton>
                </div>
                <div class="mud-card-content">
                    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;">
                        <div style="text-align:center;padding:16px;background:var(--ukuu-surface-alt);border-radius:12px;">
                            <div style="font-size:11px;color:var(--ukuu-text-muted);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">Gross</div>
                            <div style="font-size:20px;font-weight:800;color:var(--ukuu-ink);margin-top:4px;">@(_stats?.TotalGross.ToString("N0") ?? "0")</div>
                            <div style="font-size:11px;color:var(--ukuu-text-subtle);">ZMW</div>
                        </div>
                        <div style="text-align:center;padding:16px;background:var(--ukuu-surface-alt);border-radius:12px;">
                            <div style="font-size:11px;color:var(--ukuu-text-muted);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">PAYE</div>
                            <div style="font-size:20px;font-weight:800;color:var(--ukuu-error);margin-top:4px;">@(_stats?.TotalPaye.ToString("N0") ?? "0")</div>
                            <div style="font-size:11px;color:var(--ukuu-text-subtle);">ZMW</div>
                        </div>
                        <div style="text-align:center;padding:16px;background:var(--ukuu-surface-alt);border-radius:12px;">
                            <div style="font-size:11px;color:var(--ukuu-text-muted);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">NAPSA + NHIMA</div>
                            <div style="font-size:20px;font-weight:800;color:var(--ukuu-warning);margin-top:4px;">@(((_stats?.TotalNapsa ?? 0) + (_stats?.TotalNhima ?? 0)).ToString("N0"))</div>
                            <div style="font-size:11px;color:var(--ukuu-text-subtle);">ZMW</div>
                        </div>
                        <div style="text-align:center;padding:16px;background:linear-gradient(135deg,#25163F 0%,#4A3C68 100%);border-radius:12px;color:#FCFBFF;">
                            <div style="font-size:11px;color:rgba(252,251,255,0.6);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">Net Pay</div>
                            <div style="font-size:20px;font-weight:800;color:#FCFBFF;margin-top:4px;">@(_stats?.TotalNet.ToString("N0") ?? "0")</div>
                            <div style="font-size:11px;color:rgba(252,251,255,0.5);">ZMW</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT: Side widgets -->
        <div style="display:flex;flex-direction:column;gap:24px;">

            <!-- Today's attendance donut -->
            <div class="mud-card">
                <div class="mud-card-header">
                    <h3 style="font-size:16px;font-weight:700;margin-bottom:2px;">Today's Attendance</h3>
                    <p style="font-size:12px;color:var(--ukuu-text-muted);margin:0;">@DateTime.Now.ToString("dd MMMM yyyy")</p>
                </div>
                <div class="mud-card-content" style="text-align:center;">
                    <div style="position:relative;display:inline-block;">
                        <svg width="180" height="180" viewBox="0 0 180 180">
                            <circle cx="90" cy="90" r="70" fill="none" stroke="#E8E3EF" stroke-width="14"/>
                            @{
                                var total = _attendanceBreakdown.Values.Sum();
                                var present = _attendanceBreakdown.ContainsKey(AttendanceStatus.Present) ? _attendanceBreakdown[AttendanceStatus.Present] : 0;
                                var late = _attendanceBreakdown.ContainsKey(AttendanceStatus.Late) ? _attendanceBreakdown[AttendanceStatus.Late] : 0;
                                var absent = _attendanceBreakdown.ContainsKey(AttendanceStatus.Absent) ? _attendanceBreakdown[AttendanceStatus.Absent] : 0;
                                var onLeave = _attendanceBreakdown.ContainsKey(AttendanceStatus.OnLeave) ? _attendanceBreakdown[AttendanceStatus.OnLeave] : 0;
                                var circumference = 2 * Math.PI * 70;
                                var presentLen = total > 0 ? (present + late) * circumference / total : 0;
                                var leaveLen = total > 0 ? onLeave * circumference / total : 0;
                                var absentLen = total > 0 ? absent * circumference / total : 0;
                            }
                            <circle cx="90" cy="90" r="70" fill="none" stroke="#16A34A" stroke-width="14"
                                    stroke-dasharray="@($"{presentLen} {circumference}")" stroke-dashoffset="0" transform="rotate(-90 90 90)" stroke-linecap="round"/>
                            <circle cx="90" cy="90" r="70" fill="none" stroke="#F59E0B" stroke-width="14"
                                    stroke-dasharray="@($"{leaveLen} {circumference}")" stroke-dashoffset="@(-presentLen)" transform="rotate(-90 90 90)" stroke-linecap="round"/>
                            <circle cx="90" cy="90" r="70" fill="none" stroke="#DC2626" stroke-width="14"
                                    stroke-dasharray="@($"{absentLen} {circumference}")" stroke-dashoffset="@(-(presentLen + leaveLen))" transform="rotate(-90 90 90)" stroke-linecap="round"/>
                        </svg>
                        <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;">
                            <div style="font-size:28px;font-weight:800;color:var(--ukuu-ink);line-height:1;">@_attendancePct.ToString("0")%</div>
                            <div style="font-size:10px;color:var(--ukuu-text-muted);text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-top:4px;">Present</div>
                        </div>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:16px;text-align:left;">
                        <div style="display:flex;align-items:center;gap:8px;font-size:12px;">
                            <span style="width:8px;height:8px;border-radius:50%;background:#16A34A;"></span>
                            <span style="color:var(--ukuu-text-muted);">Present/Late</span>
                            <strong style="margin-left:auto;color:var(--ukuu-text);">@(present + late)</strong>
                        </div>
                        <div style="display:flex;align-items:center;gap:8px;font-size:12px;">
                            <span style="width:8px;height:8px;border-radius:50%;background:#F59E0B;"></span>
                            <span style="color:var(--ukuu-text-muted);">On Leave</span>
                            <strong style="margin-left:auto;color:var(--ukuu-text);">@onLeave</strong>
                        </div>
                        <div style="display:flex;align-items:center;gap:8px;font-size:12px;">
                            <span style="width:8px;height:8px;border-radius:50%;background:#DC2626;"></span>
                            <span style="color:var(--ukuu-text-muted);">Absent</span>
                            <strong style="margin-left:auto;color:var(--ukuu-text);">@absent</strong>
                        </div>
                        <div style="display:flex;align-items:center;gap:8px;font-size:12px;">
                            <span style="width:8px;height:8px;border-radius:50%;background:var(--ukuu-surface-strong);"></span>
                            <span style="color:var(--ukuu-text-muted);">Total</span>
                            <strong style="margin-left:auto;color:var(--ukuu-text);">@total</strong>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pending approvals -->
            <div class="mud-card">
                <div class="mud-card-header" style="display:flex;justify-content:space-between;align-items:center;">
                    <div>
                        <h3 style="font-size:16px;font-weight:700;margin-bottom:2px;">Pending Approvals</h3>
                        <p style="font-size:12px;color:var(--ukuu-text-muted);margin:0;">Awaiting your review</p>
                    </div>
                    <span class="ukuu-status-pill ukuu-status-pending">@(_pendingLeave + _pendingPayroll)</span>
                </div>
                <div class="mud-card-content" style="padding:8px;">
                    <a href="/leave" style="display:flex;align-items:center;gap:12px;padding:12px;text-decoration:none;color:inherit;border-radius:8px;transition:background 0.15s;" onmouseover="this.style.background='var(--ukuu-surface-alt)'" onmouseout="this.style.background='transparent'">
                        <div style="width:36px;height:36px;border-radius:10px;background:var(--ukuu-warning-bg);color:var(--ukuu-warning);display:flex;align-items:center;justify-content:center;">
                            <span class="material-icons-round" style="font-size:20px;">event_available</span>
                        </div>
                        <div style="flex:1;">
                            <div style="font-size:13px;font-weight:600;color:var(--ukuu-text);">Leave Requests</div>
                            <div style="font-size:11px;color:var(--ukuu-text-subtle);">@_pendingLeave awaiting approval</div>
                        </div>
                        <span class="material-icons-round" style="color:var(--ukuu-text-subtle);font-size:20px;">chevron_right</span>
                    </a>
                    <a href="/payroll" style="display:flex;align-items:center;gap:12px;padding:12px;text-decoration:none;color:inherit;border-radius:8px;transition:background 0.15s;" onmouseover="this.style.background='var(--ukuu-surface-alt)'" onmouseout="this.style.background='transparent'">
                        <div style="width:36px;height:36px;border-radius:10px;background:#EDE0FE;color:#7C3AED;display:flex;align-items:center;justify-content:center;">
                            <span class="material-icons-round" style="font-size:20px;">payments</span>
                        </div>
                        <div style="flex:1;">
                            <div style="font-size:13px;font-weight:600;color:var(--ukuu-text);">Payroll Runs</div>
                            <div style="font-size:11px;color:var(--ukuu-text-subtle);">@_pendingPayroll awaiting review</div>
                        </div>
                        <span class="material-icons-round" style="color:var(--ukuu-text-subtle);font-size:20px;">chevron_right</span>
                    </a>
                </div>
            </div>

            <!-- Quick actions -->
            <div class="mud-card">
                <div class="mud-card-header">
                    <h3 style="font-size:16px;font-weight:700;margin-bottom:2px;">Quick Actions</h3>
                    <p style="font-size:12px;color:var(--ukuu-text-muted);margin:0;">Frequently used shortcuts</p>
                </div>
                <div class="mud-card-content" style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="@(() => Nav.NavigateTo("/employees/add"))" Style="background:linear-gradient(135deg,#25163F,#4A3C68) !important;">Add Employee</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" StartIcon="@Icons.Material.Filled.Schedule" OnClick="@(() => Nav.NavigateTo("/attendance"))">Clock In</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" StartIcon="@Icons.Material.Filled.Event" OnClick="@(() => Nav.NavigateTo("/leave"))">Request Leave</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" StartIcon="@Icons.Material.Filled.Calculate" OnClick="@(() => Nav.NavigateTo("/payroll/calculator"))">Payroll Calc</MudButton>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int _totalEmployees;
    private int _activeEmployees;
    private int _onProbation;
    private int _presentToday;
    private int _onLeaveToday;
    private int _pendingLeave;
    private int _approvedThisMonth;
    private int _pendingPayroll;
    private double _monthlyPayroll;
    private double _attendanceToday;
    private double _attendancePct;
    private Dictionary<string, int> _deptCounts = new();
    private Dictionary<AttendanceStatus, int> _attendanceBreakdown = new();
    private List<Employee> _recentEmployees = new();
    private PayrollMonthlyStats? _stats;

    protected override async Task OnInitializedAsync()
    {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        var today = DateTime.Today;

        _totalEmployees = await EmployeeSvc.CountAsync(org.Id);
        _activeEmployees = await EmployeeSvc.CountByStatusAsync(org.Id, EmploymentStatus.Active);
        _onProbation = await EmployeeSvc.CountByStatusAsync(org.Id, EmploymentStatus.Probation);
        _monthlyPayroll = await EmployeeSvc.TotalPayrollAsync(org.Id);
        _deptCounts = await EmployeeSvc.ByDepartmentAsync(org.Id);

        _attendanceBreakdown = await AttendanceSvc.BreakdownAsync(org.Id, today);
        var total = _attendanceBreakdown.Values.Sum();
        var present = _attendanceBreakdown.GetValueOrDefault(AttendanceStatus.Present);
        var late = _attendanceBreakdown.GetValueOrDefault(AttendanceStatus.Late);
        _presentToday = present + late;
        _onLeaveToday = _attendanceBreakdown.GetValueOrDefault(AttendanceStatus.OnLeave);
        _attendanceToday = total > 0 ? (present + late) * 100.0 / total : 0;
        _attendancePct = _attendanceToday;

        var leaveReqs = await LeaveSvc.AllAsync(org.Id);
        _pendingLeave = leaveReqs.Count(l => l.Status == LeaveRequestStatus.Pending);
        _approvedThisMonth = leaveReqs.Count(l => l.Status == LeaveRequestStatus.Approved && l.ReviewedAt?.Month == today.Month && l.ReviewedAt?.Year == today.Year);

        var pendingPayroll = await PayrollSvc.PendingApprovalsAsync(org.Id);
        _pendingPayroll = pendingPayroll.Count;

        _stats = await PayrollSvc.GetMonthlyStatsAsync(org.Id, today.Month, today.Year);

        _recentEmployees = await Db.Employees
            .Where(e => e.OrganizationId == org.Id)
            .OrderByDescending(e => e.CreatedAt)
            .Take(5)
            .ToListAsync();
    }
}
