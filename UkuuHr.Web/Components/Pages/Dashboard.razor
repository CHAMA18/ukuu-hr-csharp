@page "/"
@attribute [Authorize]
@page "/dashboard"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@inject EmployeeService EmployeeSvc
@inject AttendanceService AttendanceSvc
@inject LeaveService LeaveSvc
@inject PayrollService PayrollSvc
@inject UkuuHrDbContext Db
@inject IHttpContextAccessor HttpAccessor

<div class="bk-admin-fade-in">
    @* ───── Mobile hero (visible only < 1024px) — replaces the desktop greeting ───── *@
    <div class="bk-mobile-hero bk-dashboard-mobile-hero">
        <div class="bk-mobile-hero-greeting">@GetGreeting() · @(_orgName ?? "No organization")</div>
        <div class="bk-mobile-hero-name">Welcome@(string.IsNullOrEmpty(_userFirstName) ? "" : $", {_userFirstName}")</div>
        <div class="bk-mobile-hero-sub">@_presentToday present today · @_pendingLeave leave requests pending · @_pendingPayroll payroll awaiting approval</div>
        <div class="bk-mobile-hero-stats">
            <div>
                <div class="bk-mobile-hero-stat-value">@_totalEmployees</div>
                <div class="bk-mobile-hero-stat-label">Employees</div>
            </div>
            <div>
                <div class="bk-mobile-hero-stat-value">@_attendancePct.ToString("0")%</div>
                <div class="bk-mobile-hero-stat-label">Attendance</div>
            </div>
            <div>
                <div class="bk-mobile-hero-stat-value">ZMW @(_monthlyPayroll / 1000).ToString("N0")K</div>
                <div class="bk-mobile-hero-stat-label">Payroll</div>
            </div>
        </div>
    </div>

    <div class="bk-admin-section-header bk-hide-on-mobile">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">@GetGreeting()@(string.IsNullOrEmpty(_userFirstName) ? "" : $", {_userFirstName}") · @(_hasOrg ? "All systems operational" : "Set up your organization to begin")</div>
            <h1 class="bk-admin-h1">Workspace Overview</h1>
            <p class="bk-admin-sub">@if (_hasOrg) { <text>Here's what's happening across @_orgName today.</text> } else { <text>Welcome to Ukuu HR. Add your organization in Settings to start managing employees.</text> }</p>
        </div>
        <div class="bk-admin-actions">
            <button class="bk-btn bk-btn-secondary" onclick="window.print()">
                <span class="material-icons-round" style="font-size:16px;">download</span>
                Export Report
            </button>
            <a href="/employees/add" class="bk-btn bk-btn-primary">
                <span class="material-icons-round" style="font-size:16px;">person_add</span>
                Add Employee
            </a>
        </div>
    </div>

    <!-- KPI ROW -->
    <div class="bk-admin-kpi-grid">
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon blue">
                    <span class="material-icons-round">groups</span>
                </div>
                <span class="bk-admin-kpi-delta up">
                    <span class="material-icons-round" style="font-size:14px;">trending_up</span>
                    +12%
                </span>
            </div>
            <div class="bk-admin-kpi-value">@_totalEmployees</div>
            <div class="bk-admin-kpi-label">Total Employees</div>
            <div class="bk-admin-kpi-sub">@_activeEmployees active · @_onProbation on probation</div>
        </div>

        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon green">
                    <span class="material-icons-round">check_circle</span>
                </div>
                <span class="bk-admin-kpi-delta up">
                    <span class="material-icons-round" style="font-size:14px;">trending_up</span>
                    +4%
                </span>
            </div>
            <div class="bk-admin-kpi-value">@_attendancePct.ToString("0.0")%</div>
            <div class="bk-admin-kpi-label">Attendance Today</div>
            <div class="bk-admin-kpi-sub">@_presentToday present · @_onLeaveToday on leave</div>
        </div>

        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon gold">
                    <span class="material-icons-round">event_available</span>
                </div>
                <span class="bk-admin-kpi-delta down">
                    <span class="material-icons-round" style="font-size:14px;">trending_down</span>
                    -2
                </span>
            </div>
            <div class="bk-admin-kpi-value">@_pendingLeave</div>
            <div class="bk-admin-kpi-label">Pending Leave Requests</div>
            <div class="bk-admin-kpi-sub">@_approvedThisMonth approved this month</div>
        </div>

        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon pink">
                    <span class="material-icons-round">payments</span>
                </div>
                <span class="bk-admin-kpi-delta up">
                    <span class="material-icons-round" style="font-size:14px;">trending_up</span>
                    +8%
                </span>
            </div>
            <div class="bk-admin-kpi-value">ZMW @(_monthlyPayroll.ToString("N0"))</div>
            <div class="bk-admin-kpi-label">Monthly Payroll</div>
            <div class="bk-admin-kpi-sub">@_pendingPayroll pending approval</div>
        </div>
    </div>

    <!-- MAIN GRID -->
    <div class="bk-admin-grid-2" style="margin-bottom:32px;">
        <!-- LEFT: Charts + tables -->
        <div style="display:flex;flex-direction:column;gap:24px;">

            <!-- Workforce by department -->
            <div class="bk-admin-card">
                <div class="bk-admin-card-header">
                    <div>
                        <h3>Workforce Distribution</h3>
                        <p>Headcount by department</p>
                    </div>
                    <a href="/reports" class="bk-btn-text" style="font-size:13px;font-weight:700;color:var(--bk-ink);text-decoration:none;">View Report →</a>
                </div>
                <div class="bk-admin-card-content">
                    @if (_deptCounts.Any())
                    {
                        <div style="display:flex;flex-direction:column;gap:14px;">
                            @{
                                var maxCount = _deptCounts.Values.Max();
                            }
                            @foreach (var dept in _deptCounts.OrderByDescending(d => d.Value))
                            {
                                var pct = (int)(dept.Value * 100.0 / maxCount);
                                <div>
                                    <div style="display:flex;justify-content:space-between;margin-bottom:6px;font-size:13px;">
                                        <span style="font-weight:600;color:var(--bk-ink);">@dept.Key</span>
                                        <span style="font-weight:700;color:var(--bk-ink);">@dept.Value employees</span>
                                    </div>
                                    <div class="bk-admin-progress">
                                        <div class="bk-admin-progress-fill" style="width:@(pct)%;"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Recent employees -->
            <div class="bk-admin-card">
                <div class="bk-admin-card-header">
                    <div>
                        <h3>Recent Hires</h3>
                        <p>Newest members of your team</p>
                    </div>
                    <a href="/employees" class="bk-btn-text" style="font-size:13px;font-weight:700;color:var(--bk-ink);text-decoration:none;">View All →</a>
                </div>
                <table class="bk-admin-table">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Role</th>
                            <th>Department</th>
                            <th>Joined</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var emp in _recentEmployees)
                        {
                            <tr>
                                <td>
                                    <div style="display:flex;align-items:center;gap:12px;">
                                        <div class="bk-admin-avatar gold">@emp.Initials</div>
                                        <div>
                                            <div style="font-weight:600;color:var(--bk-ink);font-size:13px;">@emp.FullName</div>
                                            <div style="font-size:11px;color:var(--bk-ink-3);">@emp.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="font-weight:500;">@emp.JobTitle</td>
                                <td>@emp.Department</td>
                                <td style="color:var(--bk-ink-3);font-size:12px;">@(emp.JoiningDate?.ToString("dd MMM yyyy") ?? "—")</td>
                                <td>
                                    <span class="bk-admin-pill @(emp.Status == EmploymentStatus.Active ? "active" : emp.Status == EmploymentStatus.Probation ? "probation" : "inactive")">
                                        @emp.StatusDisplay
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Payroll overview -->
            <div class="bk-admin-card">
                <div class="bk-admin-card-header">
                    <div>
                        <h3>Payroll Snapshot — @DateTime.Now.ToString("MMMM yyyy")</h3>
                        <p>Gross-to-net summary for current pay period</p>
                    </div>
                    <a href="/payroll" class="bk-btn-text" style="font-size:13px;font-weight:700;color:var(--bk-ink);text-decoration:none;">Open Payroll →</a>
                </div>
                <div class="bk-admin-card-content">
                    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;">
                        <div class="bk-admin-stat-box">
                            <div class="bk-admin-stat-box-label">Gross</div>
                            <div class="bk-admin-stat-box-value">@(_stats?.TotalGross.ToString("N0") ?? "0")</div>
                        </div>
                        <div class="bk-admin-stat-box">
                            <div class="bk-admin-stat-box-label">PAYE</div>
                            <div class="bk-admin-stat-box-value" style="color:var(--bk-accent-4);">@(_stats?.TotalPaye.ToString("N0") ?? "0")</div>
                        </div>
                        <div class="bk-admin-stat-box">
                            <div class="bk-admin-stat-box-label">NAPSA + NHIMA</div>
                            <div class="bk-admin-stat-box-value" style="color:var(--bk-accent);">@( ((_stats?.TotalNapsa ?? 0) + (_stats?.TotalNhima ?? 0)).ToString("N0") )</div>
                        </div>
                        <div class="bk-admin-stat-box dark">
                            <div class="bk-admin-stat-box-label">Net Pay</div>
                            <div class="bk-admin-stat-box-value">@(_stats?.TotalNet.ToString("N0") ?? "0")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT: Side widgets -->
        <div style="display:flex;flex-direction:column;gap:24px;">

            <!-- Today's attendance donut -->
            <div class="bk-admin-card">
                <div class="bk-admin-card-header">
                    <div>
                        <h3>Today's Attendance</h3>
                        <p>@DateTime.Now.ToString("dd MMMM yyyy")</p>
                    </div>
                </div>
                <div class="bk-admin-card-content" style="text-align:center;">
                    <div style="position:relative;display:inline-block;">
                        <svg width="180" height="180" viewBox="0 0 180 180">
                            <circle cx="90" cy="90" r="70" fill="none" stroke="#E8E3EF" stroke-width="14"/>
                            @{
                                var total = _attendanceBreakdown.Values.Sum();
                                var present = _attendanceBreakdown.GetValueOrDefault(AttendanceStatus.Present);
                                var late = _attendanceBreakdown.GetValueOrDefault(AttendanceStatus.Late);
                                var absent = _attendanceBreakdown.GetValueOrDefault(AttendanceStatus.Absent);
                                var onLeave = _attendanceBreakdown.GetValueOrDefault(AttendanceStatus.OnLeave);
                                var circumference = 2 * Math.PI * 70;
                                var presentLen = total > 0 ? (present + late) * circumference / total : 0;
                                var leaveLen = total > 0 ? onLeave * circumference / total : 0;
                                var absentLen = total > 0 ? absent * circumference / total : 0;
                            }
                            <circle cx="90" cy="90" r="70" fill="none" stroke="#14a37f" stroke-width="14"
                                    stroke-dasharray="@($"{presentLen} {circumference}")" stroke-dashoffset="0" transform="rotate(-90 90 90)" stroke-linecap="round"/>
                            <circle cx="90" cy="90" r="70" fill="none" stroke="#d89c11" stroke-width="14"
                                    stroke-dasharray="@($"{leaveLen} {circumference}")" stroke-dashoffset="@(-presentLen)" transform="rotate(-90 90 90)" stroke-linecap="round"/>
                            <circle cx="90" cy="90" r="70" fill="none" stroke="#e85d75" stroke-width="14"
                                    stroke-dasharray="@($"{absentLen} {circumference}")" stroke-dashoffset="@(-(presentLen + leaveLen))" transform="rotate(-90 90 90)" stroke-linecap="round"/>
                        </svg>
                        <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;">
                            <div style="font-size:28px;font-weight:800;color:var(--bk-ink);line-height:1;font-family:Geist,sans-serif;">@_attendancePct.ToString("0")%</div>
                            <div style="font-size:10px;color:var(--bk-ink-3);text-transform:uppercase;letter-spacing:0.06em;font-weight:700;margin-top:4px;">Present</div>
                        </div>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:16px;text-align:left;">
                        <div style="display:flex;align-items:center;gap:8px;font-size:12px;">
                            <span style="width:8px;height:8px;border-radius:50%;background:#14a37f;"></span>
                            <span style="color:var(--bk-ink-3);">Present/Late</span>
                            <strong style="margin-left:auto;color:var(--bk-ink);">@(present + late)</strong>
                        </div>
                        <div style="display:flex;align-items:center;gap:8px;font-size:12px;">
                            <span style="width:8px;height:8px;border-radius:50%;background:#d89c11;"></span>
                            <span style="color:var(--bk-ink-3);">On Leave</span>
                            <strong style="margin-left:auto;color:var(--bk-ink);">@onLeave</strong>
                        </div>
                        <div style="display:flex;align-items:center;gap:8px;font-size:12px;">
                            <span style="width:8px;height:8px;border-radius:50%;background:#e85d75;"></span>
                            <span style="color:var(--bk-ink-3);">Absent</span>
                            <strong style="margin-left:auto;color:var(--bk-ink);">@absent</strong>
                        </div>
                        <div style="display:flex;align-items:center;gap:8px;font-size:12px;">
                            <span style="width:8px;height:8px;border-radius:50%;background:var(--bk-muted-2);"></span>
                            <span style="color:var(--bk-ink-3);">Total</span>
                            <strong style="margin-left:auto;color:var(--bk-ink);">@total</strong>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pending approvals -->
            <div class="bk-admin-card">
                <div class="bk-admin-card-header">
                    <div>
                        <h3>Pending Approvals</h3>
                        <p>Awaiting your review</p>
                    </div>
                    <span class="bk-admin-pill pending">@(_pendingLeave + _pendingPayroll)</span>
                </div>
                <div class="bk-admin-card-content" style="padding:8px;">
                    <a href="/leave" style="display:flex;align-items:center;gap:12px;padding:12px;text-decoration:none;color:inherit;border-radius:8px;transition:background 0.15s;" onmouseover="this.style.background='var(--bk-muted)'" onmouseout="this.style.background='transparent'">
                        <div class="bk-admin-kpi-icon gold" style="width:36px;height:36px;">
                            <span class="material-icons-round" style="font-size:20px;">event_available</span>
                        </div>
                        <div style="flex:1;">
                            <div style="font-size:13px;font-weight:600;color:var(--bk-ink);">Leave Requests</div>
                            <div style="font-size:11px;color:var(--bk-ink-3);">@_pendingLeave awaiting approval</div>
                        </div>
                        <span class="material-icons-round" style="color:var(--bk-ink-3);font-size:20px;">chevron_right</span>
                    </a>
                    <a href="/payroll" style="display:flex;align-items:center;gap:12px;padding:12px;text-decoration:none;color:inherit;border-radius:8px;transition:background 0.15s;" onmouseover="this.style.background='var(--bk-muted)'" onmouseout="this.style.background='transparent'">
                        <div class="bk-admin-kpi-icon pink" style="width:36px;height:36px;">
                            <span class="material-icons-round" style="font-size:20px;">payments</span>
                        </div>
                        <div style="flex:1;">
                            <div style="font-size:13px;font-weight:600;color:var(--bk-ink);">Payroll Runs</div>
                            <div style="font-size:11px;color:var(--bk-ink-3);">@_pendingPayroll awaiting review</div>
                        </div>
                        <span class="material-icons-round" style="color:var(--bk-ink-3);font-size:20px;">chevron_right</span>
                    </a>
                </div>
            </div>

            <!-- Quick actions -->
            <div class="bk-admin-card">
                <div class="bk-admin-card-header">
                    <div>
                        <h3>Quick Actions</h3>
                        <p>Frequently used shortcuts</p>
                    </div>
                </div>
                <div class="bk-admin-card-content" style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                    <a href="/employees/add" class="bk-btn bk-btn-primary" style="font-size:12px;padding:10px 14px;min-height:40px;">
                        <span class="material-icons-round" style="font-size:16px;">person_add</span>
                        Add Employee
                    </a>
                    <a href="/attendance" class="bk-btn bk-btn-secondary" style="font-size:12px;padding:10px 14px;min-height:40px;">
                        <span class="material-icons-round" style="font-size:16px;">schedule</span>
                        Clock In
                    </a>
                    <a href="/leave" class="bk-btn bk-btn-secondary" style="font-size:12px;padding:10px 14px;min-height:40px;">
                        <span class="material-icons-round" style="font-size:16px;">event</span>
                        Request Leave
                    </a>
                    <a href="/payroll/calculator" class="bk-btn bk-btn-secondary" style="font-size:12px;padding:10px 14px;min-height:40px;">
                        <span class="material-icons-round" style="font-size:16px;">calculate</span>
                        Payroll Calc
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int _totalEmployees;
    private int _activeEmployees;
    private int _onProbation;
    private int _presentToday;
    private int _onLeaveToday;
    private int _pendingLeave;
    private int _approvedThisMonth;
    private int _pendingPayroll;
    private double _monthlyPayroll;
    private double _attendanceToday;
    private double _attendancePct;
    private Dictionary<string, int> _deptCounts = new();
    private Dictionary<AttendanceStatus, int> _attendanceBreakdown = new();
    private List<Employee> _recentEmployees = new();
    private PayrollMonthlyStats? _stats;
    private string? _orgName = null;
    private bool _hasOrg = false;
    private string? _userFirstName = null;

    protected override async Task OnInitializedAsync()
    {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        _hasOrg = org != null;
        _orgName = org?.Name;

        // Resolve the signed-in user's first name from the auth cookie.
        var nameClaim = HttpAccessor.HttpContext?.User?.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value;
        if (!string.IsNullOrWhiteSpace(nameClaim))
        {
            var parts = nameClaim.Split(' ', 2, StringSplitOptions.RemoveEmptyEntries);
            _userFirstName = parts.Length > 0 ? parts[0] : nameClaim;
        }

        if (org == null) return;
        var today = DateTime.Today;

        _totalEmployees = await EmployeeSvc.CountAsync(org.Id);
        _activeEmployees = await EmployeeSvc.CountByStatusAsync(org.Id, EmploymentStatus.Active);
        _onProbation = await EmployeeSvc.CountByStatusAsync(org.Id, EmploymentStatus.Probation);
        _monthlyPayroll = await EmployeeSvc.TotalPayrollAsync(org.Id);
        _deptCounts = await EmployeeSvc.ByDepartmentAsync(org.Id);

        _attendanceBreakdown = await AttendanceSvc.BreakdownAsync(org.Id, today);
        var total = _attendanceBreakdown.Values.Sum();
        var present = _attendanceBreakdown.GetValueOrDefault(AttendanceStatus.Present);
        var late = _attendanceBreakdown.GetValueOrDefault(AttendanceStatus.Late);
        _presentToday = present + late;
        _onLeaveToday = _attendanceBreakdown.GetValueOrDefault(AttendanceStatus.OnLeave);
        _attendanceToday = total > 0 ? (present + late) * 100.0 / total : 0;
        _attendancePct = _attendanceToday;

        var leaveReqs = await LeaveSvc.AllAsync(org.Id);
        _pendingLeave = leaveReqs.Count(l => l.Status == LeaveRequestStatus.Pending);
        _approvedThisMonth = leaveReqs.Count(l => l.Status == LeaveRequestStatus.Approved && l.ReviewedAt?.Month == today.Month && l.ReviewedAt?.Year == today.Year);

        var pendingPayroll = await PayrollSvc.PendingApprovalsAsync(org.Id);
        _pendingPayroll = pendingPayroll.Count;

        _stats = await PayrollSvc.GetMonthlyStatsAsync(org.Id, today.Month, today.Year);

        _recentEmployees = await Db.Employees
            .Where(e => e.OrganizationId == org.Id)
            .OrderByDescending(e => e.CreatedAt)
            .Take(5)
            .ToListAsync();
    }

    private static string GetGreeting()
    {
        var hour = DateTime.Now.Hour;
        if (hour < 12) return "Good morning";
        if (hour < 17) return "Good afternoon";
        return "Good evening";
    }
}
