@page "/shifts/tolerance"
@attribute [Authorize(Policy = "HrOrAdmin")]
@using Microsoft.EntityFrameworkCore
@inject ShiftService ShiftSvc
@inject UkuuHrDbContext Db
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<div class="bk-admin-fade-in">
    <div class="bk-admin-section-header">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">Shift Management · Attendance Tolerance Policy</div>
            <h1 class="bk-admin-h1">Attendance Tolerance Policy</h1>
            <p class="bk-admin-sub">
                Organization-wide thresholds that drive automatic attendance status computation.
                Configure late check-in, early check-out, early arrival allowances, absent thresholds,
                grace periods, and break-handling rules.
            </p>
        </div>
        <div class="bk-admin-actions">
            <a href="/shifts" class="bk-btn bk-btn-secondary">
                <span class="material-icons-round" style="font-size:16px;">arrow_back</span>
                All Shifts
            </a>
        </div>
    </div>

    @if (_loadError != null)
    {
        <div class="bk-admin-card" style="padding:24px;">
            <div style="padding:16px;background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.25);border-radius:8px;color:var(--bk-error);font-size:13px;">
                <span class="material-icons-round" style="font-size:18px;vertical-align:middle;margin-right:6px;">error_outline</span>
                @_loadError
            </div>
            <button class="bk-btn bk-btn-primary" style="margin-top:16px;" @onclick="LoadData">Retry</button>
        </div>
    }
    else if (_tolerance == null)
    {
        <div class="bk-admin-card" style="text-align:center;padding:48px 24px;">
            <span class="material-icons-round" style="font-size:48px;color:var(--bk-ink-3);opacity:0.5;">tune</span>
            <h3 style="margin-top:16px;">Loading tolerance policy…</h3>
            <p style="color:var(--bk-ink-3);font-size:13px;margin-top:8px;">If this takes too long, the Blazor connection may be slow. <a href="/shifts/tolerance" style="color:var(--bk-accent);">Click here to reload</a></p>
        </div>
    }
    else
    {
        <form method="post" action="/api/shifts/tolerance" class="bk-admin-card">
            <div class="bk-admin-card-content" style="padding-bottom:24px;">

                @* ───── Policy cards grid ───── *@
                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;">

                    @* Late check-in *@
                    <div style="padding:16px;border:1px solid var(--bk-line);border-radius:12px;background:rgba(245,158,11,0.04);">
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
                            <span class="material-icons-round" style="color:var(--bk-warning);font-size:20px;">schedule</span>
                            <h4 style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;color:var(--bk-warning);">Late Check-In</h4>
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Late tolerance (minutes)</label>
                            <input type="number" class="bk-input" name="LateCheckInToleranceMinutes" value="@_tolerance.LateCheckInToleranceMinutes" />
                        </div>
                        <div class="bk-field" style="margin-top:12px;">
                            <label class="bk-label">Very-late threshold (minutes)</label>
                            <input type="number" class="bk-input" name="VeryLateThresholdMinutes" value="@_tolerance.VeryLateThresholdMinutes" />
                        </div>
                    </div>

                    @* Early check-out *@
                    <div style="padding:16px;border:1px solid var(--bk-line);border-radius:12px;background:rgba(220,38,38,0.04);">
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
                            <span class="material-icons-round" style="color:var(--bk-error);font-size:20px;">logout</span>
                            <h4 style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;color:var(--bk-error);">Early Check-Out</h4>
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Early tolerance (minutes)</label>
                            <input type="number" class="bk-input" name="EarlyCheckOutToleranceMinutes" value="@_tolerance.EarlyCheckOutToleranceMinutes" />
                        </div>
                        <div class="bk-field" style="margin-top:12px;">
                            <label class="bk-label">Half-day threshold (minutes early)</label>
                            <input type="number" class="bk-input" name="HalfDayEarlyThresholdMinutes" value="@_tolerance.HalfDayEarlyThresholdMinutes" />
                        </div>
                    </div>

                    @* Early arrival *@
                    <div style="padding:16px;border:1px solid var(--bk-line);border-radius:12px;background:rgba(22,163,74,0.04);">
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
                            <span class="material-icons-round" style="color:var(--bk-success);font-size:20px;">login</span>
                            <h4 style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;color:var(--bk-success);">Early Arrival</h4>
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Allowance (minutes paid)</label>
                            <input type="number" class="bk-input" name="EarlyArrivalAllowanceMinutes" value="@_tolerance.EarlyArrivalAllowanceMinutes" />
                        </div>
                        <div class="bk-field" style="margin-top:12px;display:flex;align-items:center;gap:8px;">
                            <input type="checkbox" name="CapEarlyArrivalToAllowance" value="true" @(_tolerance.CapEarlyArrivalToAllowance ? "checked" : "") id="capEarly" />
                            <label for="capEarly" style="font-size:12px;color:var(--bk-ink-2);">Cap to allowance (don't pay beyond)</label>
                        </div>
                    </div>

                    @* Absent threshold *@
                    <div style="padding:16px;border:1px solid var(--bk-line);border-radius:12px;background:rgba(220,38,38,0.04);">
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
                            <span class="material-icons-round" style="color:var(--bk-error);font-size:20px;">cancel</span>
                            <h4 style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;color:var(--bk-error);">Absent Threshold</h4>
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Min present minutes (else absent)</label>
                            <input type="number" class="bk-input" name="MinPresentMinutesForAttendance" value="@_tolerance.MinPresentMinutesForAttendance" />
                        </div>
                        <div class="bk-field" style="margin-top:12px;display:flex;align-items:center;gap:8px;">
                            <input type="checkbox" name="AutoMarkAbsentWhenNoClockEvent" value="true" @(_tolerance.AutoMarkAbsentWhenNoClockEvent ? "checked" : "") id="autoAbsent" />
                            <label for="autoAbsent" style="font-size:12px;color:var(--bk-ink-2);">Auto-mark absent when no clock event</label>
                        </div>
                    </div>

                    @* Grace period *@
                    <div style="padding:16px;border:1px solid var(--bk-line);border-radius:12px;background:rgba(37,99,235,0.04);">
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
                            <span class="material-icons-round" style="color:var(--bk-info);font-size:20px;">timer</span>
                            <h4 style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;color:var(--bk-info);">Grace Period</h4>
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Grace minutes (added to tolerance)</label>
                            <input type="number" class="bk-input" name="GracePeriodMinutes" value="@_tolerance.GracePeriodMinutes" />
                        </div>
                        <input type="hidden" name="GracePeriodDaysMask" value="@_tolerance.GracePeriodDaysMask" />
                    </div>

                    @* Break handling *@
                    <div style="padding:16px;border:1px solid var(--bk-line);border-radius:12px;background:rgba(110,95,146,0.04);">
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
                            <span class="material-icons-round" style="color:var(--bk-accent-2);font-size:20px;">restaurant</span>
                            <h4 style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;color:var(--bk-accent-2);">Break & Half-Day</h4>
                        </div>
                        <div class="bk-field">
                            <label class="bk-label">Default break (minutes)</label>
                            <input type="number" class="bk-input" name="DefaultBreakMinutes" value="@_tolerance.DefaultBreakMinutes" />
                        </div>
                        <div class="bk-field" style="margin-top:12px;">
                            <label class="bk-label">Min worked minutes before break deducted</label>
                            <input type="number" class="bk-input" name="MinWorkedMinutesBeforeBreak" value="@_tolerance.MinWorkedMinutesBeforeBreak" />
                        </div>
                        <div class="bk-field" style="margin-top:12px;">
                            <label class="bk-label">Half-day worked minutes</label>
                            <input type="number" class="bk-input" name="HalfDayWorkedMinutes" value="@_tolerance.HalfDayWorkedMinutes" />
                        </div>
                    </div>
                </div>

                <div style="display:flex;justify-content:space-between;align-items:center;margin-top:24px;padding-top:16px;border-top:1px solid var(--bk-line);">
                    <div style="font-size:12px;color:var(--bk-ink-3);">
                        <span class="material-icons-round" style="font-size:14px;vertical-align:middle;">info</span>
                        Changes are audit-logged. The ShiftEngine re-evaluates all future attendance records against the new policy.
                    </div>
                    <button type="submit" class="bk-btn bk-btn-primary">
                        <span class="material-icons-round" style="font-size:16px;">save</span>
                        Save Tolerance Policy
                    </button>
                </div>
            </div>
        </form>
    }
</div>

@code {
    private AttendanceTolerance? _tolerance;
    private int _orgId;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loadError = null;
        try
        {
            var org = await Db.Organizations.FirstOrDefaultAsync();
            if (org == null)
            {
                _loadError = "No organization found. Please create an organization first in Settings.";
                return;
            }
            _orgId = org.Id;
            _tolerance = await ShiftSvc.GetOrCreateToleranceAsync(_orgId);
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load tolerance policy: {ex.Message}";
        }
    }
}
