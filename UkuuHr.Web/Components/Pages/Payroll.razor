@page "/payroll"
@attribute [Authorize(Policy = "FinanceOrAdmin")]
@using Microsoft.EntityFrameworkCore
@inject PayrollService PayrollSvc
@inject UkuuHrDbContext Db

<div class="bk-admin-fade-in">
    <div class="bk-admin-section-header">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">Payroll · @_periodLabel</div>
            <h1 class="bk-admin-h1">Payroll Management</h1>
            <p class="bk-admin-sub">Generate, review, and approve payroll runs. Current period: <strong>@_periodLabel</strong>.</p>
        </div>
        <div class="bk-admin-actions">
            <a href="/payroll/calculator" class="bk-btn bk-btn-secondary">
                <span class="material-icons-round" style="font-size:16px;">calculate</span>
                Payroll Calculator
            </a>
            <button class="bk-btn bk-btn-primary" @onclick="GenerateBatch">
                <span class="material-icons-round" style="font-size:16px;">autorenew</span>
                Generate Batch
            </button>
        </div>
    </div>

    <!-- KPI row -->
    <div class="bk-admin-kpi-grid">
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon pink">
                    <span class="material-icons-round">payments</span>
                </div>
            </div>
            <div class="bk-admin-kpi-value">ZMW @(_stats?.TotalGross.ToString("N0") ?? "0")</div>
            <div class="bk-admin-kpi-label">Gross Payroll — @_periodLabel</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon pink">
                    <span class="material-icons-round">receipt</span>
                </div>
            </div>
            <div class="bk-admin-kpi-value">ZMW @(_stats?.TotalPaye.ToString("N0") ?? "0")</div>
            <div class="bk-admin-kpi-label">Total PAYE Tax</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon gold">
                    <span class="material-icons-round">savings</span>
                </div>
            </div>
            <div class="bk-admin-kpi-value">ZMW @(((_stats?.TotalNapsa ?? 0) + (_stats?.TotalNhima ?? 0)).ToString("N0"))</div>
            <div class="bk-admin-kpi-label">NAPSA + NHIMA</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon green">
                    <span class="material-icons-round">account_balance_wallet</span>
                </div>
            </div>
            <div class="bk-admin-kpi-value">ZMW @(_stats?.TotalNet.ToString("N0") ?? "0")</div>
            <div class="bk-admin-kpi-label">Net Pay Disbursed</div>
        </div>
    </div>

    <!-- Tabs -->
    <div style="display:flex;gap:4px;border-bottom:1px solid var(--bk-line);margin-bottom:24px;overflow-x:auto;">
        <div class="ukuu-tab @(_tab == "current" ? "active" : "")" @onclick="@(() => _tab = "current")" style="padding:12px 16px;border-bottom:2px solid @(_tab == "current" ? "var(--bk-ink)" : "transparent");color:@(_tab == "current" ? "var(--bk-ink)" : "var(--bk-ink-3)");font-weight:600;font-size:13px;cursor:pointer;white-space:nowrap;">
            <span class="material-icons-round" style="font-size:18px;vertical-align:middle;margin-right:6px;">receipt_long</span>
            Current Period (@_current.Count)
        </div>
        <div class="ukuu-tab @(_tab == "pending" ? "active" : "")" @onclick="@(() => _tab = "pending")" style="padding:12px 16px;border-bottom:2px solid @(_tab == "pending" ? "var(--bk-ink)" : "transparent");color:@(_tab == "pending" ? "var(--bk-ink)" : "var(--bk-ink-3)");font-weight:600;font-size:13px;cursor:pointer;white-space:nowrap;">
            <span class="material-icons-round" style="font-size:18px;vertical-align:middle;margin-right:6px;">pending_actions</span>
            Pending Approval (@_pending.Count)
        </div>
        <div class="ukuu-tab @(_tab == "history" ? "active" : "")" @onclick="@(() => _tab = "history")" style="padding:12px 16px;border-bottom:2px solid @(_tab == "history" ? "var(--bk-ink)" : "transparent");color:@(_tab == "history" ? "var(--bk-ink)" : "var(--bk-ink-3)");font-weight:600;font-size:13px;cursor:pointer;white-space:nowrap;">
            <span class="material-icons-round" style="font-size:18px;vertical-align:middle;margin-right:6px;">history</span>
            History
        </div>
    </div>

    @if (_tab == "current")
    {
        <div class="bk-admin-card" style="overflow:hidden;">
            <table class="bk-admin-table bk-mobile-card-view">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Department</th>
                        <th>Gross</th>
                        <th>PAYE</th>
                        <th>NAPSA</th>
                        <th>NHIMA</th>
                        <th>Net Pay</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in _current)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <div class="bk-admin-avatar gold" style="width:32px;height:32px;font-size:12px;">@GetInitials(p.EmployeeName)</div>
                                    <div>
                                        <div style="font-weight:600;font-size:13px;">@p.EmployeeName</div>
                                        <div style="font-size:11px;color:var(--bk-ink-3);">@p.PeriodLabel</div>
                                    </div>
                                </div>
                            </td>
                            <td>@GetDept(p.EmployeeId)</td>
                            <td style="font-weight:600;color:var(--bk-ink);">@p.Currency @p.Gross.ToString("N0")</td>
                            <td style="color:var(--bk-accent-4);">@p.Paye.ToString("N0")</td>
                            <td style="color:var(--bk-accent);">@p.Napsa.ToString("N0")</td>
                            <td style="color:var(--bk-accent);">@p.Nhima.ToString("N0")</td>
                            <td style="font-weight:700;color:var(--bk-accent-3);">@p.Net.ToString("N0")</td>
                            <td>
                                <span class="bk-admin-pill @(p.ApprovalStatus == PayrollApprovalStatus.Approved ? "approved" : p.ApprovalStatus == PayrollApprovalStatus.Pending ? "pending" : "rejected")">
                                    @p.ApprovalStatus
                                </span>
                            </td>
                            <td>
                                <button class="bk-admin-topbar-icon-btn" style="width:32px;height:32px;border-radius:8px;" title="View payslip">
                                    <span class="material-icons-round" style="font-size:16px;">receipt</span>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (!_current.Any())
            {
                <div style="padding:48px 24px;text-align:center;color:var(--bk-ink-3);">
                    <div style="width:64px;height:64px;margin:0 auto 16px;background:var(--bk-muted);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                        <span class="material-icons-round" style="font-size:32px;color:var(--bk-ink-3);">receipt_long</span>
                    </div>
                    <h3 style="font-size:16px;margin-bottom:4px;color:var(--bk-ink);">No payroll runs for this period</h3>
                    <p style="font-size:13px;">Click "Generate Batch" to create payroll runs for all active employees.</p>
                </div>
            }
        </div>
    }
    else if (_tab == "pending")
    {
        <div class="bk-admin-card" style="overflow:hidden;">
            <table class="bk-admin-table bk-mobile-card-view">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Period</th>
                        <th>Net Pay</th>
                        <th>Submitted</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in _pending)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <div class="bk-admin-avatar gold" style="width:32px;height:32px;font-size:12px;">@GetInitials(p.EmployeeName)</div>
                                    <div style="font-weight:600;font-size:13px;">@p.EmployeeName</div>
                                </div>
                            </td>
                            <td>@p.PeriodLabel</td>
                            <td style="font-weight:700;color:var(--bk-accent-3);">@p.Currency @p.Net.ToString("N0")</td>
                            <td style="font-size:12px;color:var(--bk-ink-3);">@(p.SubmittedAt?.ToString("dd MMM yyyy") ?? "—")</td>
                            <td>
                                <div style="display:flex;gap:6px;">
                                    <button class="bk-btn bk-btn-primary" style="font-size:11px;padding:6px 12px;min-height:32px;background:linear-gradient(180deg,var(--bk-accent-3),#0d8061);box-shadow:none;" @onclick="@(() => Approve(p.Id))">
                                        <span class="material-icons-round" style="font-size:14px;">check</span>
                                        Approve
                                    </button>
                                    <button class="bk-btn bk-btn-secondary" style="font-size:11px;padding:6px 12px;min-height:32px;color:var(--bk-accent-4);border-color:var(--bk-accent-4);" @onclick="@(() => Reject(p.Id))">
                                        <span class="material-icons-round" style="font-size:14px;">close</span>
                                        Reject
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (!_pending.Any())
            {
                <div style="padding:48px 24px;text-align:center;color:var(--bk-ink-3);">
                    <div style="width:64px;height:64px;margin:0 auto 16px;background:var(--bk-muted);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                        <span class="material-icons-round" style="font-size:32px;color:var(--bk-accent-3);">check_circle</span>
                    </div>
                    <h3 style="font-size:16px;margin-bottom:4px;color:var(--bk-ink);">All caught up!</h3>
                    <p style="font-size:13px;">No payroll runs awaiting approval.</p>
                </div>
            }
        </div>
    }
    else
    {
        <div class="bk-admin-card" style="overflow:hidden;">
            <table class="bk-admin-table bk-mobile-card-view">
                <thead>
                    <tr>
                        <th>Batch ID</th>
                        <th>Period</th>
                        <th>Employees</th>
                        <th>Net Total</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in _history)
                    {
                        <tr>
                            <td style="font-family:'JetBrains Mono',monospace;font-size:12px;">@p.BatchId</td>
                            <td style="font-weight:600;">@p.PeriodLabel</td>
                            <td>@GetBatchCount(p.BatchId)</td>
                            <td style="font-weight:700;color:var(--bk-accent-3);">@p.Currency @GetBatchNet(p.BatchId).ToString("N0")</td>
                            <td>
                                <span class="bk-admin-pill approved">@p.Status</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private string _tab = "current";
    private List<PayrollRun> _current = new();
    private List<PayrollRun> _pending = new();
    private List<PayrollRun> _history = new();
    private List<Employee> _allEmployees = new();
    private PayrollMonthlyStats? _stats;
    private string _periodLabel = DateTime.Now.ToString("MMMM yyyy");
    private int _orgId;

    protected override async Task OnInitializedAsync()
    {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        _orgId = org.Id;
        var now = DateTime.Now;
        _stats = await PayrollSvc.GetMonthlyStatsAsync(_orgId, now.Month, now.Year);
        await LoadData();
    }

    private async Task LoadData()
    {
        var now = DateTime.Now;
        _current = await PayrollSvc.ForPeriodAsync(_orgId, now.Month, now.Year);
        _pending = await PayrollSvc.PendingApprovalsAsync(_orgId);
        var allRuns = await Db.PayrollRuns
            .Where(p => p.OrganizationId == _orgId && p.BatchId != null)
            .OrderByDescending(p => p.Year).ThenByDescending(p => p.Month)
            .ToListAsync();
        _history = allRuns
            .GroupBy(p => new { p.BatchId, p.Month, p.Year, p.Currency, p.Status })
            .Select(g => g.First())
            .ToList();
        _allEmployees = await Db.Employees.Where(e => e.OrganizationId == _orgId).ToListAsync();
    }

    private string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length < 2) return name.Length > 2 ? name[..2].ToUpper() : name.ToUpper();
        return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
    }

    private string GetDept(int empId) => _allEmployees.FirstOrDefault(e => e.Id == empId)?.Department ?? "—";

    private int GetBatchCount(string? batchId) =>
        batchId == null ? 0 : _current.Count(p => p.BatchId == batchId) + _history.Count(p => p.BatchId == batchId);

    private double GetBatchNet(string? batchId) =>
        batchId == null ? 0 : _current.Where(p => p.BatchId == batchId).Sum(p => p.Net);

    private async Task GenerateBatch()
    {
        var now = DateTime.Now;
        var runs = await PayrollSvc.GenerateBatchForPeriodAsync(_orgId, now.Month, now.Year, "admin@ukuuhr.demo");
        Snackbar.Add($"Generated {runs.Count} payroll runs for {_periodLabel}.", Severity.Success);
        await LoadData();
    }

    private async Task Approve(int id)
    {
        await PayrollSvc.ApproveAsync(_orgId, id, "admin@ukuuhr.demo", "Approved by admin.");
        Snackbar.Add("Payroll approved. Net pay ready for disbursement.", Severity.Success);
        await LoadData();
    }

    private async Task Reject(int id)
    {
        await PayrollSvc.RejectAsync(_orgId, id, "admin@ukuuhr.demo", "Rejected by admin — please review.");
        Snackbar.Add("Payroll rejected.", Severity.Warning);
        await LoadData();
    }
}
