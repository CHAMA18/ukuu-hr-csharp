@page "/payroll"
@using Microsoft.EntityFrameworkCore
@inject PayrollService PayrollSvc
@inject UkuuHrDbContext Db

<div class="ukuu-fade-in">
    <div class="ukuu-section-header" style="display:flex;justify-content:space-between;align-items:flex-end;">
        <div>
            <h1>Payroll Management</h1>
            <p>Generate, review, and approve payroll runs. Current period: <strong>@_periodLabel</strong>.</p>
        </div>
        <div style="display:flex;gap:8px;">
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Calculate" OnClick="@(() => Nav.NavigateTo("/payroll/calculator"))">Payroll Calculator</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Autorenew" OnClick="@GenerateBatch" Style="background:linear-gradient(135deg,#25163F 0%,#4A3C68 100%) !important;">Generate Batch</MudButton>
        </div>
    </div>

    <!-- KPI row -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;margin-bottom:24px;">
        <div class="ukuu-kpi-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
                <div style="width:44px;height:44px;border-radius:12px;background:#EDE0FE;color:#7C3AED;display:flex;align-items:center;justify-content:center;">
                    <span class="material-icons-round">payments</span>
                </div>
            </div>
            <div class="ukuu-kpi-value">ZMW @(_stats?.TotalGross.ToString("N0") ?? "0")</div>
            <div class="ukuu-kpi-label">Gross Payroll — @_periodLabel</div>
        </div>
        <div class="ukuu-kpi-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
                <div style="width:44px;height:44px;border-radius:12px;background:var(--ukuu-error-bg);color:var(--ukuu-error);display:flex;align-items:center;justify-content:center;">
                    <span class="material-icons-round">receipt</span>
                </div>
            </div>
            <div class="ukuu-kpi-value">ZMW @(_stats?.TotalPaye.ToString("N0") ?? "0")</div>
            <div class="ukuu-kpi-label">Total PAYE Tax</div>
        </div>
        <div class="ukuu-kpi-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
                <div style="width:44px;height:44px;border-radius:12px;background:var(--ukuu-warning-bg);color:var(--ukuu-warning);display:flex;align-items:center;justify-content:center;">
                    <span class="material-icons-round">savings</span>
                </div>
            </div>
            <div class="ukuu-kpi-value">ZMW @(((_stats?.TotalNapsa ?? 0) + (_stats?.TotalNhima ?? 0)).ToString("N0"))</div>
            <div class="ukuu-kpi-label">NAPSA + NHIMA</div>
        </div>
        <div class="ukuu-kpi-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
                <div style="width:44px;height:44px;border-radius:12px;background:var(--ukuu-success-bg);color:var(--ukuu-success);display:flex;align-items:center;justify-content:center;">
                    <span class="material-icons-round">account_balance_wallet</span>
                </div>
            </div>
            <div class="ukuu-kpi-value">ZMW @(_stats?.TotalNet.ToString("N0") ?? "0")</div>
            <div class="ukuu-kpi-label">Net Pay Disbursed</div>
        </div>
    </div>

    <!-- Tabs -->
    <div style="display:flex;gap:4px;border-bottom:1px solid var(--ukuu-border-soft);margin-bottom:24px;overflow-x:auto;">
        <div class="ukuu-tab @(_tab == "current" ? "active" : "")" @onclick="@(() => SetTab("current"))">
            <span class="material-icons-round" style="font-size:18px;">receipt_long</span>
            Current Period (@_current.Count)
        </div>
        <div class="ukuu-tab @(_tab == "pending" ? "active" : "")" @onclick="@(() => SetTab("pending"))">
            <span class="material-icons-round" style="font-size:18px;">pending_actions</span>
            Pending Approval (@_pending.Count)
            @if (_pending.Count > 0)
            {
                <span class="ukuu-sidebar-item-badge">@_pending.Count</span>
            }
        </div>
        <div class="ukuu-tab @(_tab == "history" ? "active" : "")" @onclick="@(() => SetTab("history"))">
            <span class="material-icons-round" style="font-size:18px;">history</span>
            History
        </div>
    </div>

    @if (_tab == "current")
    {
        <div class="mud-card" style="overflow:hidden;">
            <MudTable Items="@_current" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Employee</MudTh>
                    <MudTh>Department</MudTh>
                    <MudTh>Gross</MudTh>
                    <MudTh>PAYE</MudTh>
                    <MudTh>NAPSA</MudTh>
                    <MudTh>NHIMA</MudTh>
                    <MudTh>Net Pay</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <div style="display:flex;align-items:center;gap:10px;">
                            <MudAvatar Color="Color.Primary" Size="Size.Small" Style="background:linear-gradient(135deg,#25163F,#6E5F92);">@GetInitials(context.EmployeeName)</MudAvatar>
                            <div>
                                <div style="font-weight:600;font-size:13px;">@context.EmployeeName</div>
                                <div style="font-size:11px;color:var(--ukuu-text-subtle);">@context.PeriodLabel</div>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd>@GetDept(context.EmployeeId)</MudTd>
                    <MudTd Style="font-weight:600;color:var(--ukuu-ink);">@context.Currency @context.Gross.ToString("N0")</MudTd>
                    <MudTd Style="color:var(--ukuu-error);">@context.Paye.ToString("N0")</MudTd>
                    <MudTd Style="color:var(--ukuu-warning);">@context.Napsa.ToString("N0")</MudTd>
                    <MudTd Style="color:var(--ukuu-warning);">@context.Nhima.ToString("N0")</MudTd>
                    <MudTd Style="font-weight:700;color:var(--ukuu-success);">@context.Net.ToString("N0")</MudTd>
                    <MudTd>
                        <span class="ukuu-status-pill @(context.ApprovalStatus == PayrollApprovalStatus.Approved ? "ukuu-status-approved" : context.ApprovalStatus == PayrollApprovalStatus.Pending ? "ukuu-status-pending" : "ukuu-status-rejected")">
                            @context.ApprovalStatus
                        </span>
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" OnClick="@(() => ViewPayslip(context))" />
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="ukuu-empty">
                        <div class="ukuu-empty-icon"><span class="material-icons-round">receipt_long</span></div>
                        <h3 style="font-size:16px;margin-bottom:4px;">No payroll runs for this period</h3>
                        <p style="font-size:13px;">Click "Generate Batch" to create payroll runs for all active employees.</p>
                    </div>
                </NoRecordsContent>
            </MudTable>
        </div>
    }
    else if (_tab == "pending")
    {
        <div class="mud-card" style="overflow:hidden;">
            <MudTable Items="@_pending" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Employee</MudTh>
                    <MudTh>Period</MudTh>
                    <MudTh>Net Pay</MudTh>
                    <MudTh>Submitted</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <div style="display:flex;align-items:center;gap:10px;">
                            <MudAvatar Color="Color.Primary" Size="Size.Small" Style="background:linear-gradient(135deg,#25163F,#6E5F92);">@GetInitials(context.EmployeeName)</MudAvatar>
                            <div style="font-weight:600;font-size:13px;">@context.EmployeeName</div>
                        </div>
                    </MudTd>
                    <MudTd>@context.PeriodLabel</MudTd>
                    <MudTd Style="font-weight:700;color:var(--ukuu-success);">@context.Currency @context.Net.ToString("N0")</MudTd>
                    <MudTd Style="font-size:12px;color:var(--ukuu-text-muted);">@(context.SubmittedAt?.ToString("dd MMM yyyy") ?? "—")</MudTd>
                    <MudTd>
                        <div style="display:flex;gap:4px;">
                            <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" StartIcon="@Icons.Material.Filled.Check" OnClick="@(() => Approve(context.Id))">Approve</MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" StartIcon="@Icons.Material.Filled.Close" OnClick="@(() => Reject(context.Id))">Reject</MudButton>
                        </div>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="ukuu-empty">
                        <div class="ukuu-empty-icon"><span class="material-icons-round">check_circle</span></div>
                        <h3 style="font-size:16px;margin-bottom:4px;">All caught up!</h3>
                        <p style="font-size:13px;">No payroll runs awaiting approval.</p>
                    </div>
                </NoRecordsContent>
            </MudTable>
        </div>
    }
    else
    {
        <div class="mud-card" style="overflow:hidden;">
            <MudTable Items="@_history" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Batch ID</MudTh>
                    <MudTh>Period</MudTh>
                    <MudTh>Employees</MudTh>
                    <MudTh>Net Total</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd Style="font-family:var(--ukuu-font-mono);font-size:12px;">@context.BatchId</MudTd>
                    <MudTd Style="font-weight:600;">@context.PeriodLabel</MudTd>
                    <MudTd>@GetBatchCount(context.BatchId)</MudTd>
                    <MudTd Style="font-weight:700;color:var(--ukuu-success);">@context.Currency @GetBatchNet(context.BatchId).ToString("N0")</MudTd>
                    <MudTd>
                        <span class="ukuu-status-pill ukuu-status-approved">@context.Status</span>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </div>
    }
</div>

@code {
    private string _tab = "current";
    private List<PayrollRun> _current = new();
    private List<PayrollRun> _pending = new();
    private List<PayrollRun> _history = new();
    private List<Employee> _allEmployees = new();
    private PayrollMonthlyStats? _stats;
    private string _periodLabel = DateTime.Now.ToString("MMMM yyyy");
    private int _orgId;

    protected override async Task OnInitializedAsync()
    {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        _orgId = org.Id;
        var now = DateTime.Now;
        _stats = await PayrollSvc.GetMonthlyStatsAsync(_orgId, now.Month, now.Year);
        await LoadData();
    }

    private async Task LoadData()
    {
        var now = DateTime.Now;
        _current = await PayrollSvc.ForPeriodAsync(_orgId, now.Month, now.Year);
        _pending = await PayrollSvc.PendingApprovalsAsync(_orgId);
        var allRuns = await Db.PayrollRuns
            .Where(p => p.OrganizationId == _orgId && p.BatchId != null)
            .OrderByDescending(p => p.Year).ThenByDescending(p => p.Month)
            .ToListAsync();
        _history = allRuns
            .GroupBy(p => new { p.BatchId, p.Month, p.Year, p.Currency, p.Status })
            .Select(g => g.First())
            .ToList();
        _allEmployees = await Db.Employees.Where(e => e.OrganizationId == _orgId).ToListAsync();
    }

    private void SetTab(string t) => _tab = t;

    private string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length < 2) return name.Length > 2 ? name[..2].ToUpper() : name.ToUpper();
        return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
    }

    private string GetDept(int empId) => _allEmployees.FirstOrDefault(e => e.Id == empId)?.Department ?? "—";

    private int GetBatchCount(string? batchId) =>
        batchId == null ? 0 : _current.Count(p => p.BatchId == batchId) + _history.Count(p => p.BatchId == batchId);

    private double GetBatchNet(string? batchId) =>
        batchId == null ? 0 : _current.Where(p => p.BatchId == batchId).Sum(p => p.Net);

    private async Task GenerateBatch()
    {
        var now = DateTime.Now;
        var runs = await PayrollSvc.GenerateBatchForPeriodAsync(_orgId, now.Month, now.Year, "admin@ukuuhr.demo");
        Snackbar.Add($"Generated {runs.Count} payroll runs for {_periodLabel}.", Severity.Success);
        await LoadData();
    }

    private async Task Approve(int id)
    {
        await PayrollSvc.ApproveAsync(_orgId, id, "admin@ukuuhr.demo", "Approved by admin.");
        Snackbar.Add("Payroll approved. Net pay ready for disbursement.", Severity.Success);
        await LoadData();
    }

    private async Task Reject(int id)
    {
        await PayrollSvc.RejectAsync(_orgId, id, "admin@ukuuhr.demo", "Rejected by admin — please review.");
        Snackbar.Add("Payroll rejected.", Severity.Warning);
        await LoadData();
    }

    private void ViewPayslip(PayrollRun run)
    {
        Snackbar.Add($"Payslip for {run.EmployeeName} — {run.PeriodLabel}", Severity.Info);
    }
}
