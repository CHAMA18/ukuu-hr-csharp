@page "/hikvision"
@using Microsoft.EntityFrameworkCore
@inject HikvisionSyncService HikvisionSvc
@inject UkuuHrDbContext Db

<div class="bk-admin-fade-in">
    <div class="bk-admin-section-header">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">Hikvision Integration · @_stats.ActiveDevices active devices · @_stats.TotalEvents events synced</div>
            <h1 class="bk-admin-h1">Hikvision Time & Attendance</h1>
            <p class="bk-admin-sub">Connect Hikvision devices, sync clock events, and auto-process attendance records.</p>
        </div>
        <div class="bk-admin-actions">
            <button class="bk-btn bk-btn-secondary" @onclick="SyncAll">
                <span class="material-icons-round" style="font-size:16px;">sync</span>
                Sync All Devices
            </button>
            <button class="bk-btn bk-btn-primary" @onclick="ShowAddDevice">
                <span class="material-icons-round" style="font-size:16px;">add</span>
                Add Device
            </button>
        </div>
    </div>

    <!-- Stats -->
    <div class="bk-admin-kpi-grid">
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon blue"><span class="material-icons-round">devices</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_stats.TotalDevices</div>
            <div class="bk-admin-kpi-label">Total Devices</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon green"><span class="material-icons-round">wifi</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_stats.ActiveDevices</div>
            <div class="bk-admin-kpi-label">Active Devices</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon gold"><span class="material-icons-round">badge</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_stats.TotalEvents</div>
            <div class="bk-admin-kpi-label">Total Events Synced</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon pink"><span class="material-icons-round">pending</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_stats.UnprocessedEvents</div>
            <div class="bk-admin-kpi-label">Unprocessed Events</div>
        </div>
    </div>

    <!-- Devices -->
    <div class="bk-admin-card" style="margin-bottom:24px;overflow:hidden;">
        <div class="bk-admin-card-header">
            <div>
                <h3>Connected Devices</h3>
                <p>Hikvision DS-K1T804 series — ISAPI integration</p>
            </div>
        </div>
        <table class="bk-admin-table">
            <thead>
                <tr>
                    <th>Device Name</th>
                    <th>IP Address</th>
                    <th>Location</th>
                    <th>Serial</th>
                    <th>Last Sync</th>
                    <th>Events</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var device in _devices)
                {
                    <tr>
                        <td style="font-weight:600;">@device.Name</td>
                        <td style="font-family:'JetBrains Mono',monospace;font-size:12px;">@device.IpAddress:@device.Port</td>
                        <td>@(device.Location ?? "—")</td>
                        <td style="font-size:11px;color:var(--bk-ink-3);">@(device.DeviceSerial ?? "—")</td>
                        <td style="font-size:12px;color:var(--bk-ink-3);">@device.LastSuccessfulSyncDisplay</td>
                        <td style="font-weight:600;">@device.TotalEventsSynced</td>
                        <td>
                            <span class="bk-admin-pill @(device.IsActive ? "active" : "inactive")">
                                @device.StatusDisplay
                            </span>
                        </td>
                        <td>
                            <div style="display:flex;gap:4px;">
                                <button class="bk-admin-topbar-icon-btn" style="width:32px;height:32px;border-radius:8px;" @onclick="@(() => SyncDevice(device.Id))" title="Sync now">
                                    <span class="material-icons-round" style="font-size:16px;">sync</span>
                                </button>
                                <button class="bk-admin-topbar-icon-btn" style="width:32px;height:32px;border-radius:8px;color:var(--bk-accent-4);border-color:var(--bk-accent-4);" @onclick="@(() => DeleteDevice(device.Id))" title="Delete">
                                    <span class="material-icons-round" style="font-size:16px;">delete</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!_devices.Any())
        {
            <div style="padding:48px 24px;text-align:center;color:var(--bk-ink-3);">
                <div style="width:64px;height:64px;margin:0 auto 16px;background:var(--bk-muted);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                    <span class="material-icons-round" style="font-size:32px;color:var(--bk-ink-3);">devices_off</span>
                </div>
                <h3 style="font-size:16px;margin-bottom:4px;color:var(--bk-ink);">No devices connected</h3>
                <p style="font-size:13px;">Click "Add Device" to connect a Hikvision time & attendance device.</p>
            </div>
        }
    </div>

    <!-- Recent clock events -->
    <div class="bk-admin-card" style="overflow:hidden;">
        <div class="bk-admin-card-header">
            <div>
                <h3>Recent Clock Events</h3>
                <p>Latest sync events from all devices</p>
            </div>
        </div>
        <table class="bk-admin-table">
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>Device</th>
                    <th>Event Time</th>
                    <th>Type</th>
                    <th>Verify Mode</th>
                    <th>Processed</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var evt in _events)
                {
                    <tr>
                        <td style="font-weight:600;">@(evt.Employee?.FullName ?? evt.EmployeeCode)</td>
                        <td style="font-size:12px;">@(evt.Device?.Name ?? "—")</td>
                        <td style="font-family:'JetBrains Mono',monospace;font-size:12px;">@evt.EventTimeDisplay</td>
                        <td>
                            <span class="bk-admin-pill @(evt.EventType == ClockEventType.CheckIn ? "approved" : "pending")">
                                @evt.EventTypeDisplay
                            </span>
                        </td>
                        <td style="font-size:12px;color:var(--bk-ink-3);">@(evt.VerifyMode ?? "—")</td>
                        <td>
                            @if (evt.IsProcessed)
                            {
                                <span class="bk-admin-pill active">Processed</span>
                            }
                            else
                            {
                                <span class="bk-admin-pill pending">Pending</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!_events.Any())
        {
            <div style="padding:48px 24px;text-align:center;color:var(--bk-ink-3);">
                <p style="font-size:13px;">No clock events yet. Sync a device to fetch events.</p>
            </div>
        }
    </div>
</div>

@code {
    private List<HikvisionDevice> _devices = new();
    private List<HikvisionClockEvent> _events = new();
    private HikvisionStats _stats = new();
    private int _orgId;

    protected override async Task OnInitializedAsync()
    {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        _orgId = org.Id;
        await LoadData();
    }

    private async Task LoadData()
    {
        _devices = await HikvisionSvc.GetDevicesAsync(_orgId);
        _events = await HikvisionSvc.GetRecentEventsAsync(_orgId, 30);
        _stats = await HikvisionSvc.GetStatsAsync(_orgId);
    }

    private async Task SyncDevice(int deviceId)
    {
        Snackbar.Add("Syncing device...", Severity.Info);
        var result = await HikvisionSvc.SyncDeviceAsync(_orgId, deviceId);
        if (result.Success)
        {
            Snackbar.Add($"Sync complete: {result.EventsAdded} events, {result.AttendanceRecordsCreated} attendance records.", Severity.Success);
        }
        else
        {
            Snackbar.Add($"Sync failed: {result.ErrorMessage}", Severity.Error);
        }
        await LoadData();
    }

    private async Task SyncAll()
    {
        Snackbar.Add($"Syncing {_devices.Count} devices...", Severity.Info);
        var totalEvents = 0;
        var totalAttendance = 0;
        foreach (var device in _devices.Where(d => d.IsActive))
        {
            var result = await HikvisionSvc.SyncDeviceAsync(_orgId, device.Id);
            if (result.Success)
            {
                totalEvents += result.EventsAdded;
                totalAttendance += result.AttendanceRecordsCreated;
            }
        }
        Snackbar.Add($"All devices synced: {totalEvents} events, {totalAttendance} attendance records.", Severity.Success);
        await LoadData();
    }

    private async Task DeleteDevice(int deviceId)
    {
        await HikvisionSvc.DeleteDeviceAsync(_orgId, deviceId);
        Snackbar.Add("Device deleted.", Severity.Warning);
        await LoadData();
    }

    private void ShowAddDevice()
    {
        Snackbar.Add("Device configuration — add via the Settings > Hikvision tab.", Severity.Info);
    }
}
