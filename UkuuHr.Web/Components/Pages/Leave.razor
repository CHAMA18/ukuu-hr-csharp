@page "/leave"
@using Microsoft.EntityFrameworkCore
@inject LeaveService LeaveSvc
@inject UkuuHrDbContext Db

<div class="ukuu-fade-in">
    <div class="ukuu-section-header" style="display:flex;justify-content:space-between;align-items:flex-end;">
        <div>
            <h1>Leave Management</h1>
            <p>Review and approve leave requests. Configure leave types and public holidays.</p>
        </div>
        <div style="display:flex;gap:8px;">
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Event" OnClick="@(() => Nav.NavigateTo("/leave/new"))">Request Leave</MudButton>
        </div>
    </div>

    <!-- KPIs -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;margin-bottom:24px;">
        <div class="ukuu-kpi-card" style="padding:20px;">
            <div class="ukuu-kpi-label" style="margin-bottom:8px;">Pending Approvals</div>
            <div class="ukuu-kpi-value" style="color:var(--ukuu-warning);">@_pending</div>
        </div>
        <div class="ukuu-kpi-card" style="padding:20px;">
            <div class="ukuu-kpi-label" style="margin-bottom:8px;">Approved (This Month)</div>
            <div class="ukuu-kpi-value" style="color:var(--ukuu-success);">@_approvedThisMonth</div>
        </div>
        <div class="ukuu-kpi-card" style="padding:20px;">
            <div class="ukuu-kpi-label" style="margin-bottom:8px;">Total Requests</div>
            <div class="ukuu-kpi-value">@_all.Count</div>
        </div>
        <div class="ukuu-kpi-card" style="padding:20px;">
            <div class="ukuu-kpi-label" style="margin-bottom:8px;">Active Leave Days</div>
            <div class="ukuu-kpi-value">@_activeLeaveDays</div>
        </div>
    </div>

    <!-- Tabs -->
    <div style="display:flex;gap:4px;border-bottom:1px solid var(--ukuu-border-soft);margin-bottom:24px;">
        <div class="ukuu-tab @(_tab == "pending" ? "active" : "")" @onclick="@(() => _tab = "pending")">
            <span class="material-icons-round" style="font-size:18px;">pending_actions</span>
            Pending (@_pending)
        </div>
        <div class="ukuu-tab @(_tab == "approved" ? "active" : "")" @onclick="@(() => _tab = "approved")">
            <span class="material-icons-round" style="font-size:18px;">check_circle</span>
            Approved (@_all.Count(l => l.Status == LeaveRequestStatus.Approved))
        </div>
        <div class="ukuu-tab @(_tab == "rejected" ? "active" : "")" @onclick="@(() => _tab = "rejected")">
            <span class="material-icons-round" style="font-size:18px;">cancel</span>
            Rejected (@_all.Count(l => l.Status == LeaveRequestStatus.Rejected))
        </div>
        <div class="ukuu-tab @(_tab == "holidays" ? "active" : "")" @onclick="@(() => _tab = "holidays")">
            <span class="material-icons-round" style="font-size:18px;">celebration</span>
            Public Holidays
        </div>
    </div>

    @if (_tab == "holidays")
    {
        <div class="mud-card" style="overflow:hidden;">
            <div class="mud-card-header" style="display:flex;justify-content:space-between;align-items:center;">
                <div>
                    <h3 style="font-size:18px;font-weight:700;margin-bottom:2px;">Public Holidays — @DateTime.Now.Year</h3>
                    <p style="font-size:13px;color:var(--ukuu-text-muted);margin:0;">Non-working days automatically excluded from leave day counts.</p>
                </div>
            </div>
            <MudTable Items="@_holidays" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Holiday</MudTh>
                    <MudTh>Date</MudTh>
                    <MudTh>Day of Week</MudTh>
                    <MudTh>Country</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd Style="font-weight:600;">@context.Name</MudTd>
                    <MudTd>@context.Date.ToString("dd MMM yyyy")</MudTd>
                    <MudTd Style="color:var(--ukuu-text-muted);">@context.Date.DayOfWeek</MudTd>
                    <MudTd>@context.Country</MudTd>
                </RowTemplate>
            </MudTable>
        </div>
    }
    else
    {
        <div class="mud-card" style="overflow:hidden;">
            <MudTable Items="@_filtered" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Employee</MudTh>
                    <MudTh>Leave Type</MudTh>
                    <MudTh>Period</MudTh>
                    <MudTh>Days</MudTh>
                    <MudTh>Reason</MudTh>
                    <MudTh>Status</MudTh>
                    @if (_tab == "pending")
                    {
                        <MudTh></MudTh>
                    }
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <div style="display:flex;align-items:center;gap:10px;">
                            <MudAvatar Color="Color.Primary" Size="Size.Small" Style="background:linear-gradient(135deg,#25163F,#6E5F92);">@GetInitials(context.EmployeeName)</MudAvatar>
                            <div style="font-weight:600;font-size:13px;">@context.EmployeeName</div>
                        </div>
                    </MudTd>
                    <MudTd>
                        <span class="ukuu-status-pill ukuu-status-active" style="background:#EDE0FE;color:#7C3AED;">@context.LeaveTypeName</span>
                    </MudTd>
                    <MudTd Style="font-size:12px;color:var(--ukuu-text-muted);">@context.PeriodLabel</MudTd>
                    <MudTd Style="font-weight:600;">@context.RequestedDays days</MudTd>
                    <MudTd Style="font-size:12px;color:var(--ukuu-text-muted);max-width:300px;">@(context.Reason?.Length > 80 ? context.Reason[..80] + "..." : context.Reason)</MudTd>
                    <MudTd>
                        <span class="ukuu-status-pill @(context.Status == LeaveRequestStatus.Approved ? "ukuu-status-approved" : context.Status == LeaveRequestStatus.Rejected ? "ukuu-status-rejected" : "ukuu-status-pending")">
                            @context.Status
                        </span>
                    </MudTd>
                    @if (_tab == "pending")
                    {
                        <MudTd>
                            <div style="display:flex;gap:4px;">
                                <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small" OnClick="@(() => Approve(context.Id))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small" OnClick="@(() => Reject(context.Id))" />
                            </div>
                        </MudTd>
                    }
                </RowTemplate>
                <NoRecordsContent>
                    <div class="ukuu-empty">
                        <div class="ukuu-empty-icon"><span class="material-icons-round">event_available</span></div>
                        <p style="font-size:13px;">No @(_tab) leave requests.</p>
                    </div>
                </NoRecordsContent>
            </MudTable>
        </div>
    }
</div>

@code {
    private string _tab = "pending";
    private List<LeaveRequest> _all = new();
    private List<LeaveHoliday> _holidays = new();
    private int _pending, _approvedThisMonth, _activeLeaveDays;
    private int _orgId;

    private IEnumerable<LeaveRequest> _filtered => _tab switch
    {
        "pending" => _all.Where(l => l.Status == LeaveRequestStatus.Pending),
        "approved" => _all.Where(l => l.Status == LeaveRequestStatus.Approved),
        "rejected" => _all.Where(l => l.Status == LeaveRequestStatus.Rejected),
        _ => _all
    };

    protected override async Task OnInitializedAsync()
    {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        _orgId = org.Id;
        await Load();
    }

    private async Task Load()
    {
        _all = await LeaveSvc.AllAsync(_orgId);
        _holidays = await Db.LeaveHolidays.Where(h => h.OrganizationId == _orgId).OrderBy(h => h.Date).ToListAsync();
        _pending = _all.Count(l => l.Status == LeaveRequestStatus.Pending);
        _approvedThisMonth = _all.Count(l => l.Status == LeaveRequestStatus.Approved && l.ReviewedAt?.Month == DateTime.Now.Month);
        _activeLeaveDays = _all.Count(l => l.Status == LeaveRequestStatus.Approved && l.StartDate <= DateTime.Today && l.EndDate >= DateTime.Today);
    }

    private async Task Approve(int id)
    {
        await LeaveSvc.ReviewAsync(_orgId, id, true, "admin@ukuuhr.demo", "Approved.");
        Snackbar.Add("Leave request approved.", Severity.Success);
        await Load();
    }

    private async Task Reject(int id)
    {
        await LeaveSvc.ReviewAsync(_orgId, id, false, "admin@ukuuhr.demo", "Not feasible at this time.");
        Snackbar.Add("Leave request rejected.", Severity.Warning);
        await Load();
    }

    private string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length < 2 ? (name.Length > 2 ? name[..2].ToUpper() : name.ToUpper()) : $"{parts[0][0]}{parts[^1][0]}".ToUpper();
    }
}
