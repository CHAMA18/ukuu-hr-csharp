@page "/leave"
@using Microsoft.EntityFrameworkCore
@inject LeaveService LeaveSvc
@inject UkuuHrDbContext Db

<div class="bk-admin-fade-in">
    <div class="bk-admin-section-header">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">Leave Management · @_pending pending requests</div>
            <h1 class="bk-admin-h1">Leave Management</h1>
            <p class="bk-admin-sub">Review and approve leave requests. Configure leave types and public holidays.</p>
        </div>
        <div class="bk-admin-actions">
            <button class="bk-btn bk-btn-secondary">
                <span class="material-icons-round" style="font-size:16px;">event</span>
                Request Leave
            </button>
        </div>
    </div>

    <!-- KPIs -->
    <div class="bk-admin-kpi-grid">
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon gold"><span class="material-icons-round">pending_actions</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_pending</div>
            <div class="bk-admin-kpi-label">Pending Approvals</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon green"><span class="material-icons-round">check_circle</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_approvedThisMonth</div>
            <div class="bk-admin-kpi-label">Approved (This Month)</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon ink"><span class="material-icons-round">list_alt</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_all.Count</div>
            <div class="bk-admin-kpi-label">Total Requests</div>
        </div>
        <div class="bk-admin-kpi-card">
            <div class="bk-admin-kpi-card-top">
                <div class="bk-admin-kpi-icon purple"><span class="material-icons-round">today</span></div>
            </div>
            <div class="bk-admin-kpi-value">@_activeLeaveDays</div>
            <div class="bk-admin-kpi-label">Active Leave Days</div>
        </div>
    </div>

    <!-- Tabs -->
    <div style="display:flex;gap:4px;border-bottom:1px solid var(--bk-line);margin-bottom:24px;overflow-x:auto;">
        <div @onclick="@(() => _tab = "pending")" style="padding:12px 16px;border-bottom:2px solid @(_tab == "pending" ? "var(--bk-ink)" : "transparent");color:@(_tab == "pending" ? "var(--bk-ink)" : "var(--bk-ink-3)");font-weight:600;font-size:13px;cursor:pointer;white-space:nowrap;">
            <span class="material-icons-round" style="font-size:18px;vertical-align:middle;margin-right:6px;">pending_actions</span>
            Pending (@_pending)
        </div>
        <div @onclick="@(() => _tab = "approved")" style="padding:12px 16px;border-bottom:2px solid @(_tab == "approved" ? "var(--bk-ink)" : "transparent");color:@(_tab == "approved" ? "var(--bk-ink)" : "var(--bk-ink-3)");font-weight:600;font-size:13px;cursor:pointer;white-space:nowrap;">
            <span class="material-icons-round" style="font-size:18px;vertical-align:middle;margin-right:6px;">check_circle</span>
            Approved (@_all.Count(l => l.Status == LeaveRequestStatus.Approved))
        </div>
        <div @onclick="@(() => _tab = "rejected")" style="padding:12px 16px;border-bottom:2px solid @(_tab == "rejected" ? "var(--bk-ink)" : "transparent");color:@(_tab == "rejected" ? "var(--bk-ink)" : "var(--bk-ink-3)");font-weight:600;font-size:13px;cursor:pointer;white-space:nowrap;">
            <span class="material-icons-round" style="font-size:18px;vertical-align:middle;margin-right:6px;">cancel</span>
            Rejected (@_all.Count(l => l.Status == LeaveRequestStatus.Rejected))
        </div>
        <div @onclick="@(() => _tab = "holidays")" style="padding:12px 16px;border-bottom:2px solid @(_tab == "holidays" ? "var(--bk-ink)" : "transparent");color:@(_tab == "holidays" ? "var(--bk-ink)" : "var(--bk-ink-3)");font-weight:600;font-size:13px;cursor:pointer;white-space:nowrap;">
            <span class="material-icons-round" style="font-size:18px;vertical-align:middle;margin-right:6px;">celebration</span>
            Public Holidays
        </div>
    </div>

    @if (_tab == "holidays")
    {
        <div class="bk-admin-card" style="overflow:hidden;">
            <div class="bk-admin-card-header">
                <div>
                    <h3>Public Holidays — @DateTime.Now.Year</h3>
                    <p>Non-working days automatically excluded from leave day counts.</p>
                </div>
            </div>
            <table class="bk-admin-table">
                <thead>
                    <tr><th>Holiday</th><th>Date</th><th>Day of Week</th><th>Country</th></tr>
                </thead>
                <tbody>
                    @foreach (var h in _holidays)
                    {
                        <tr>
                            <td style="font-weight:600;">@h.Name</td>
                            <td>@h.Date.ToString("dd MMM yyyy")</td>
                            <td style="color:var(--bk-ink-3);">@h.Date.DayOfWeek</td>
                            <td>@h.Country</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="bk-admin-card" style="overflow:hidden;">
            <table class="bk-admin-table">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Leave Type</th>
                        <th>Period</th>
                        <th>Days</th>
                        <th>Reason</th>
                        <th>Status</th>
                        @if (_tab == "pending") { <th>Actions</th> }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var l in _filtered)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <div class="bk-admin-avatar purple" style="width:32px;height:32px;font-size:12px;">@GetInitials(l.EmployeeName)</div>
                                    <div style="font-weight:600;font-size:13px;">@l.EmployeeName</div>
                                </div>
                            </td>
                            <td>
                                <span class="bk-admin-pill pending" style="background:rgba(108,99,255,0.12);color:var(--bk-accent-2);">@l.LeaveTypeName</span>
                            </td>
                            <td style="font-size:12px;color:var(--bk-ink-3);">@l.PeriodLabel</td>
                            <td style="font-weight:600;">@l.RequestedDays days</td>
                            <td style="font-size:12px;color:var(--bk-ink-3);max-width:300px;">@(l.Reason?.Length > 80 ? l.Reason[..80] + "..." : l.Reason)</td>
                            <td>
                                <span class="bk-admin-pill @(l.Status == LeaveRequestStatus.Approved ? "approved" : l.Status == LeaveRequestStatus.Rejected ? "rejected" : "pending")">
                                    @l.Status
                                </span>
                            </td>
                            @if (_tab == "pending")
                            {
                                <td>
                                    <div style="display:flex;gap:4px;">
                                        <button class="bk-admin-topbar-icon-btn" style="width:32px;height:32px;border-radius:8px;color:var(--bk-accent-3);border-color:var(--bk-accent-3);" @onclick="@(() => Approve(l.Id))" title="Approve">
                                            <span class="material-icons-round" style="font-size:16px;">check</span>
                                        </button>
                                        <button class="bk-admin-topbar-icon-btn" style="width:32px;height:32px;border-radius:8px;color:var(--bk-accent-4);border-color:var(--bk-accent-4);" @onclick="@(() => Reject(l.Id))" title="Reject">
                                            <span class="material-icons-round" style="font-size:16px;">close</span>
                                        </button>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
            @if (!_filtered.Any())
            {
                <div style="padding:48px 24px;text-align:center;color:var(--bk-ink-3);">
                    <p style="font-size:13px;">No @(_tab) leave requests.</p>
                </div>
            }
        </div>
    }
</div>

@code {
    private string _tab = "pending";
    private List<LeaveRequest> _all = new();
    private List<LeaveHoliday> _holidays = new();
    private int _pending, _approvedThisMonth, _activeLeaveDays;
    private int _orgId;

    private IEnumerable<LeaveRequest> _filtered => _tab switch
    {
        "pending" => _all.Where(l => l.Status == LeaveRequestStatus.Pending),
        "approved" => _all.Where(l => l.Status == LeaveRequestStatus.Approved),
        "rejected" => _all.Where(l => l.Status == LeaveRequestStatus.Rejected),
        _ => _all
    };

    protected override async Task OnInitializedAsync()
    {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        _orgId = org.Id;
        await Load();
    }

    private async Task Load()
    {
        _all = await LeaveSvc.AllAsync(_orgId);
        _holidays = await Db.LeaveHolidays.Where(h => h.OrganizationId == _orgId).OrderBy(h => h.Date).ToListAsync();
        _pending = _all.Count(l => l.Status == LeaveRequestStatus.Pending);
        _approvedThisMonth = _all.Count(l => l.Status == LeaveRequestStatus.Approved && l.ReviewedAt?.Month == DateTime.Now.Month);
        _activeLeaveDays = _all.Count(l => l.Status == LeaveRequestStatus.Approved && l.StartDate <= DateTime.Today && l.EndDate >= DateTime.Today);
    }

    private async Task Approve(int id)
    {
        await LeaveSvc.ReviewAsync(_orgId, id, true, "admin@ukuuhr.demo", "Approved.");
        Snackbar.Add("Leave request approved.", Severity.Success);
        await Load();
    }

    private async Task Reject(int id)
    {
        await LeaveSvc.ReviewAsync(_orgId, id, false, "admin@ukuuhr.demo", "Not feasible at this time.");
        Snackbar.Add("Leave request rejected.", Severity.Warning);
        await Load();
    }

    private string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length < 2 ? (name.Length > 2 ? name[..2].ToUpper() : name.ToUpper()) : $"{parts[0][0]}{parts[^1][0]}".ToUpper();
    }
}
