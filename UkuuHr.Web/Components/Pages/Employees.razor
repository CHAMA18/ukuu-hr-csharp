@page "/employees"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@inject EmployeeService EmployeeSvc
@inject UkuuHrDbContext Db

<div class="bk-admin-fade-in">
    <div class="bk-admin-section-header">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">Workforce · @_employees.Count total employees</div>
            <h1 class="bk-admin-h1">Employee Directory</h1>
            <p class="bk-admin-sub">Manage your workforce — @_filtered.Count() active employees across @_departments.Count departments.</p>
        </div>
        <div class="bk-admin-actions">
            <button class="bk-btn bk-btn-secondary">
                <span class="material-icons-round" style="font-size:16px;">upload</span>
                Import CSV
            </button>
            <button class="bk-btn bk-btn-secondary">
                <span class="material-icons-round" style="font-size:16px;">download</span>
                Export
            </button>
            <a href="/employees/add" class="bk-btn bk-btn-primary">
                <span class="material-icons-round" style="font-size:16px;">person_add</span>
                Add Employee
            </a>
        </div>
    </div>

    <!-- Filter bar -->
    <div class="bk-admin-card" style="margin-bottom:24px;">
        <div style="display:flex;gap:16px;flex-wrap:wrap;align-items:center;padding:16px 24px;">
            <div style="flex:1;min-width:260px;position:relative;">
                <span class="material-icons-round" style="position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--bk-ink-3);font-size:20px;">search</span>
                <input type="text" @bind="_search" @bind:event="oninput" placeholder="Search by name, email, code or job title..." style="width:100%;height:40px;border:1px solid var(--bk-line);border-radius:999px;background:rgba(255,255,255,0.74);padding:0 16px 0 40px;font-family:inherit;font-size:13px;color:var(--bk-ink);outline:none;" />
            </div>
            <select @bind="_filterDept" style="height:40px;border:1px solid var(--bk-line);border-radius:999px;background:rgba(255,255,255,0.74);padding:0 16px;font-family:inherit;font-size:13px;color:var(--bk-ink);outline:none;min-width:160px;">
                <option value="All">All Departments</option>
                @foreach (var d in _departments)
                {
                    <option value="@d">@d</option>
                }
            </select>
            <select @bind="_filterStatus" style="height:40px;border:1px solid var(--bk-line);border-radius:999px;background:rgba(255,255,255,0.74);padding:0 16px;font-family:inherit;font-size:13px;color:var(--bk-ink);outline:none;min-width:140px;">
                <option value="All">All Status</option>
                <option value="Active">Active</option>
                <option value="Probation">Probation</option>
                <option value="Inactive">Inactive</option>
            </select>
        </div>
    </div>

    @if (_loading)
    {
        <div style="display:flex;justify-content:center;padding:60px;">
            <div class="ukuu-loader"></div>
        </div>
    }
    else
    {
        <div class="bk-admin-card" style="overflow:hidden;">
            <table class="bk-admin-table bk-mobile-card-view">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Department</th>
                        <th>Job Title</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in _filtered)
                    {
                        <tr>
                            <td data-label="Employee">
                                <div style="display:flex;align-items:center;gap:12px;">
                                    <div class="bk-admin-avatar @GetAvatarColor(emp.Id)">@emp.Initials</div>
                                    <div>
                                        <div style="font-weight:600;color:var(--bk-ink);font-size:13px;">@emp.FullName</div>
                                        <div style="font-size:11px;color:var(--bk-ink-3);">@emp.Email · @emp.EmployeeCode</div>
                                    </div>
                                </div>
                            </td>
                            <td data-label="Department" style="font-weight:500;">@emp.Department</td>
                            <td data-label="Job Title">@emp.JobTitle</td>
                            <td data-label="Type">
                                <span style="font-size:12px;color:var(--bk-ink-3);">@emp.ContractType</span>
                            </td>
                            <td data-label="Status">
                                <span class="bk-admin-pill @(emp.Status == EmploymentStatus.Active ? "active" : emp.Status == EmploymentStatus.Probation ? "probation" : "inactive")">
                                    @emp.StatusDisplay
                                </span>
                            </td>
                            <td data-label="Actions" style="text-align:right;">
                                <a href="/employees/@emp.Id" class="bk-admin-topbar-icon-btn" style="display:inline-flex;width:36px;height:36px;border-radius:8px;" title="View" aria-label="View">
                                    <span class="material-icons-round" style="font-size:18px;">visibility</span>
                                </a>
                                <a href="/employees/@emp.Id/edit" class="bk-admin-topbar-icon-btn" style="display:inline-flex;width:36px;height:36px;border-radius:8px;margin-left:4px;" title="Edit" aria-label="Edit">
                                    <span class="material-icons-round" style="font-size:18px;">edit</span>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (!_filtered.Any())
            {
                <div style="padding:48px 24px;text-align:center;color:var(--bk-ink-3);">
                    <div style="width:64px;height:64px;margin:0 auto 16px;background:var(--bk-muted);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                        <span class="material-icons-round" style="font-size:32px;color:var(--bk-ink-3);">person_off</span>
                    </div>
                    <h3 style="font-size:16px;margin-bottom:4px;color:var(--bk-ink);">No employees found</h3>
                    <p style="font-size:13px;">Try adjusting your search or filters, or add a new employee.</p>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Employee> _employees = new();
    private List<string> _departments = new();
    private bool _loading = true;
    private string _search = string.Empty;
    private string _filterDept = "All";
    private string _filterStatus = "All";

    private IEnumerable<Employee> _filtered => _employees.Where(e =>
        (string.IsNullOrWhiteSpace(_search) ||
         e.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
         (e.Email ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase) ||
         (e.EmployeeCode ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase) ||
         (e.JobTitle ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (_filterDept == "All" || e.Department == _filterDept) &&
        (_filterStatus == "All" || e.StatusDisplay == _filterStatus));

    protected override async Task OnInitializedAsync()
    {
        try { await LoadAsync(); }
        catch { /* fall back to empty */ }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org != null)
        {
            _employees = await EmployeeSvc.GetAllAsync(org.Id);
            _departments = await EmployeeSvc.GetDepartmentsAsync(org.Id);
        }
        _loading = false;
    }

    private string GetAvatarColor(int id) => (id % 4) switch
    {
        0 => "gold",
        1 => "green",
        2 => "purple",
        _ => "pink"
    };
}
