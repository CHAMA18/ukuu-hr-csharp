@code {
    private SignUpForm _form = new();
    private bool _agreed;
    private bool _showTermsError;
    private bool _isSubmitting;
    private bool _showPassword;
    private string _error = "";

    private int _passwordStrength;
    private string _passwordStrengthColor = "#6B7280";
    private string _passwordLabel = "";
    private string _passwordHint = "Use at least 8 characters with uppercase, lowercase, and numbers";

    private void TogglePasswordVisibility() => _showPassword = !_showPassword;

    private void ShowGoogleComingSoon() => Snackbar.Add("Google sign-up coming soon.", Severity.Info);
    private void ShowMicrosoftComingSoon() => Snackbar.Add("Microsoft sign-up coming soon.", Severity.Info);
    private void ShowGitHubComingSoon() => Snackbar.Add("GitHub sign-up coming soon.", Severity.Info);

    private void ComputePasswordStrength()
    {
        var pw = _form.Password ?? "";
        int score = 0;
        if (pw.Length >= 8) score++;
        if (pw.Length >= 12) score++;
        if (Regex.IsMatch(pw, @"[A-Z]") && Regex.IsMatch(pw, @"[a-z]")) score++;
        if (Regex.IsMatch(pw, @"[0-9]") && Regex.IsMatch(pw, @"[^a-zA-Z0-9]")) score++;

        _passwordStrength = score > 4 ? 4 : score;

        _passwordStrengthColor = score switch
        {
            0 => "#6B7280",
            1 => "#DC2626",
            2 => "#F59E0B",
            3 => "#10B981",
            4 => "#059669",
            _ => "#6B7280"
        };

        _passwordLabel = score switch
        {
            0 => "",
            1 => "Weak",
            2 => "Fair",
            3 => "Good",
            4 => "Strong",
            _ => ""
        };

        _passwordHint = score switch
        {
            0 => "Use at least 8 characters with uppercase, lowercase, and numbers",
            1 => "Try adding uppercase, lowercase, and numbers",
            2 => "Getting better — add a special character",
            3 => "Almost there",
            4 => "Strong password",
            _ => ""
        };
    }

    protected override void OnInitialized()
    {
        // Check if user came from a successful registration
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (query["registered"] == "1")
        {
            _error = "";
            Snackbar.Add("Account created! Please sign in.", Severity.Success);
        }
    }

    private async Task HandleSignUp()
    {
        _error = "";

        if (!_agreed)
        {
            _showTermsError = true;
            return;
        }
        _showTermsError = false;

        if (_form.Password != _form.ConfirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }

        if (_form.Password.Length < 8)
        {
            _error = "Password must be at least 8 characters.";
            return;
        }

        _isSubmitting = true;

        try
        {
            // In production, this would call a registration endpoint.
            // For now, we simulate registration and redirect to login.
            await Task.Delay(500); // Simulate network delay
            Nav.NavigateTo("/login?registered=1", forceLoad: true);
        }
        catch (Exception ex)
        {
            _error = $"Registration failed: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    public class SignUpForm
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "First name is required")]
        public string FirstName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Last name is required")]
        public string LastName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Enter a valid email address")]
        public string Email { get; set; } = "";

        public string Phone { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Organization name is required")]
        public string OrganizationName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Country is required")]
        public string Country { get; set; } = "Zambia";

        public string Industry { get; set; } = "";

        public string EmployeeCount { get; set; } = "1-10";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required")]
        [System.ComponentModel.DataAnnotations.MinLength(8, ErrorMessage = "Password must be at least 8 characters")]
        public string Password { get; set; } = "";

        public string ConfirmPassword { get; set; } = "";
    }
}
