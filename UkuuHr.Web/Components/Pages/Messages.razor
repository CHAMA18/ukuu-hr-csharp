@page "/messages"
@using Microsoft.EntityFrameworkCore
@inject UkuuHrDbContext Db

<div class="bk-admin-fade-in">
    <div class="bk-admin-section-header">
        <div class="bk-admin-section-header-left">
            <div class="bk-admin-greeting">HR Messages · @_conversations.Count conversations</div>
            <h1 class="bk-admin-h1">HR Messages</h1>
            <p class="bk-admin-sub">Internal messaging across your organization — announcements, 1:1s, and team chats.</p>
        </div>
        <div class="bk-admin-actions">
            <button class="bk-btn bk-btn-primary">
                <span class="material-icons-round" style="font-size:16px;">add</span>
                New Conversation
            </button>
        </div>
    </div>

    <div class="bk-admin-card" style="display:grid;grid-template-columns:340px 1fr;gap:0;height:calc(100vh - 220px);overflow:hidden;">
        <!-- Conversation list -->
        <div style="display:flex;flex-direction:column;overflow:hidden;border-right:1px solid var(--bk-line);">
            <div style="padding:16px;border-bottom:1px solid var(--bk-line);">
                <div style="position:relative;">
                    <input type="text" placeholder="Search conversations..." style="width:100%;height:36px;border:1px solid var(--bk-line);border-radius:999px;background:rgba(255,255,255,0.74);padding:0 12px 0 36px;font-family:inherit;font-size:13px;outline:none;" />
                    <span class="material-icons-round" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--bk-ink-3);font-size:18px;">search</span>
                </div>
            </div>
            <div style="flex:1;overflow-y:auto;padding:8px;">
                @foreach (var conv in _conversations)
                {
                    <div @onclick="() => Select(conv)" style="padding:12px;border-radius:10px;cursor:pointer;margin-bottom:4px;background:@(conv.Id == _selected?.Id ? "var(--bk-muted)" : "transparent");border-left:@(conv.Id == _selected?.Id ? "3px solid var(--bk-accent)" : "3px solid transparent");transition:background 0.15s ease;">
                        <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;">
                            <div class="bk-admin-avatar gold" style="width:32px;height:32px;font-size:12px;">@GetInitials(conv.Subject)</div>
                            <div style="flex:1;min-width:0;">
                                <div style="font-size:13px;font-weight:600;color:var(--bk-ink);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@conv.Subject</div>
                                <div style="font-size:11px;color:var(--bk-ink-3);">@(conv.LastMessageTime?.ToString("HH:mm") ?? "—")</div>
                            </div>
                        </div>
                        <div style="font-size:12px;color:var(--bk-ink-3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@(conv.LastMessage ?? "No messages yet")</div>
                    </div>
                }
            </div>
        </div>

        <!-- Conversation thread -->
        @if (_selected != null)
        {
            <div style="display:flex;flex-direction:column;overflow:hidden;">
                <div style="padding:16px 24px;border-bottom:1px solid var(--bk-line);display:flex;justify-content:space-between;align-items:center;">
                    <div>
                        <h3 style="font-size:16px;font-weight:700;margin:0;">@_selected.Subject</h3>
                        <p style="font-size:11px;color:var(--bk-ink-3);margin:2px 0 0 0;">@_messages.Count messages</p>
                    </div>
                </div>
                <div style="flex:1;overflow-y:auto;padding:24px;background:var(--bk-muted);display:flex;flex-direction:column;gap:12px;">
                    @foreach (var msg in _messages)
                    {
                        var isMe = msg.SenderId == "admin-001";
                        <div style="display:flex;flex-direction:column;align-items:@(isMe ? "flex-end" : "flex-start");max-width:70%;align-self:@(isMe ? "flex-end" : "flex-start");">
                            <div style="background:@(isMe ? "linear-gradient(135deg,var(--bk-ink),#262626)" : "var(--bk-bg-strong)");color:@(isMe ? "#FCFBFF" : "var(--bk-ink)");padding:10px 14px;border-radius:@(isMe ? "16px 4px 16px 16px" : "4px 16px 16px 16px");border:1px solid @(isMe ? "transparent" : "var(--bk-line)");font-size:13px;line-height:1.5;">
                                @msg.Content
                            </div>
                            <div style="font-size:10px;color:var(--bk-ink-3);margin-top:4px;">@msg.SenderName · @msg.SentAt.ToString("HH:mm")</div>
                        </div>
                    }
                </div>
                <div style="padding:16px;border-top:1px solid var(--bk-line);display:flex;gap:8px;">
                    <input type="text" @bind="_newMessage" placeholder="Type a message..." style="flex:1;height:42px;border:1px solid var(--bk-line);border-radius:999px;background:rgba(255,255,255,0.74);padding:0 16px;font-family:inherit;font-size:13px;outline:none;" />
                    <button class="bk-btn bk-btn-primary" @onclick="Send" style="padding:0 16px;min-height:42px;">
                        <span class="material-icons-round" style="font-size:18px;">send</span>
                    </button>
                </div>
            </div>
        }
        else
        {
            <div style="display:flex;align-items:center;justify-content:center;background:var(--bk-muted);">
                <div style="text-align:center;color:var(--bk-ink-3);">
                    <div style="width:64px;height:64px;margin:0 auto 16px;background:var(--bk-bg-strong);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                        <span class="material-icons-round" style="font-size:32px;color:var(--bk-ink-3);">forum</span>
                    </div>
                    <h3 style="font-size:16px;margin-bottom:4px;color:var(--bk-ink);">Select a conversation</h3>
                    <p style="font-size:13px;">Choose a conversation from the list to view messages.</p>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private List<HrConversation> _conversations = new();
    private HrConversation? _selected;
    private List<HrMessage> _messages = new();
    private string _newMessage = string.Empty;
    private int _orgId;

    protected override async Task OnInitializedAsync()
    {
        var org = await Db.Organizations.FirstOrDefaultAsync();
        if (org == null) return;
        _orgId = org.Id;
        _conversations = await Db.HrConversations
            .Where(c => c.OrganizationId == _orgId)
            .OrderByDescending(c => c.LastMessageTime ?? c.CreatedAt)
            .ToListAsync();
        if (_conversations.Any()) await Select(_conversations.First());
    }

    private async Task Select(HrConversation conv)
    {
        _selected = conv;
        _messages = await Db.HrMessages
            .Where(m => m.ConversationId == conv.Id)
            .OrderBy(m => m.SentAt)
            .ToListAsync();
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(_newMessage) || _selected == null) return;
        var msg = new HrMessage
        {
            ConversationId = _selected.Id,
            SenderId = "admin-001",
            SenderName = "Chungu Chama",
            SenderRole = UserRole.SuperAdmin,
            SenderInitials = "CC",
            Content = _newMessage,
            SentAt = DateTime.UtcNow
        };
        Db.HrMessages.Add(msg);
        _selected.LastMessage = _newMessage;
        _selected.LastMessageTime = DateTime.UtcNow;
        _selected.LastSenderId = "admin-001";
        await Db.SaveChangesAsync();
        _newMessage = string.Empty;
        await Select(_selected);
    }

    private string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length < 2 ? (name.Length > 2 ? name[..2].ToUpper() : name.ToUpper()) : $"{parts[0][0]}{parts[^1][0]}".ToUpper();
    }
}
