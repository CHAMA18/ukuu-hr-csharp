<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#25163F" />
    <title>Ukuu HR — Modern HRMS for Africa</title>
    <meta name="description" content="Ukuu HR — a world-class HR management system for the African market. Employees, attendance, leave, scheduling, and more." />
    <link rel="icon" type="image/png" href="favicon.png" />
    <link rel="manifest" href="manifest.json" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&family=Geist+Mono:wght@100..900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons|Material+Icons+Outlined|Material+Icons+Round" rel="stylesheet" />
    @{
        // Phase 17: Comprehensive cache-busting.
        // Uses build timestamp (not assembly version) so every deployment
        // generates a unique URL → browser always fetches fresh assets.
        // This fixes the "button does nothing" issue caused by stale
        // blazor.web.js being served from browser cache.
        var _cacheVersion = System.IO.File.GetLastWriteTime(typeof(Program).Assembly.Location).ToString("yyyyMMddHHmmss");
    }
    <link href="_content/MudBlazor/MudBlazor.min.css?v=@_cacheVersion" rel="stylesheet" />
    <link href="css/app.css?v=@_cacheVersion" rel="stylesheet" />
    <link href="css/ukuu.css?v=@_cacheVersion" rel="stylesheet" />
    <script>
        // Apply saved theme before page renders to avoid flash
        (function() {
            var t = localStorage.getItem('ukuu-theme') || 'dark';
            document.documentElement.setAttribute('data-theme', t);
            // Sync cookie with localStorage (in case localStorage was set but cookie wasn't)
            document.cookie = 'ukuu-theme=' + t + ';path=/;max-age=31536000;samesite=lax';
        })();

        // Phase 17: Auto-reload if stale cached version detected.
        // On each page load, check if the build version in localStorage
        // matches the current build version. If not, clear all caches
        // and reload to pick up fresh assets.
        (function() {
            var currentVersion = '@_cacheVersion';
            var cachedVersion = localStorage.getItem('ukuu-build-version');
            if (cachedVersion && cachedVersion !== currentVersion) {
                console.log('[Cache] Build version changed: ' + cachedVersion + ' → ' + currentVersion + '. Clearing caches + reloading.');
                localStorage.setItem('ukuu-build-version', currentVersion);
                // Unregister all service workers
                if ('serviceWorker' in navigator) {
                    navigator.serviceWorker.getRegistrations().then(function(regs) {
                        regs.forEach(function(r) { r.unregister(); });
                    });
                }
                // Clear all caches
                if ('caches' in window) {
                    caches.keys().then(function(keys) {
                        keys.forEach(function(k) { caches.delete(k); });
                    });
                }
                // Hard reload
                window.location.reload();
            } else {
                localStorage.setItem('ukuu-build-version', currentVersion);
            }
        })();
    </script>
</head>
<body>
    <Routes />
    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>
    <script src="_framework/blazor.web.js?v=@_cacheVersion"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js?v=@_cacheVersion"></script>
    <script>
        // Theme toggle function — callable from Blazor via JS interop
        window.ukuuToggleTheme = function() {
            var current = document.documentElement.getAttribute('data-theme') || 'light';
            var next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('ukuu-theme', next);
            // Also set a cookie so the server (SSR) can read the theme on next page load
            document.cookie = 'ukuu-theme=' + next + ';path=/;max-age=31536000;samesite=lax';
            return next;
        };
        window.ukuuGetTheme = function() {
            return document.documentElement.getAttribute('data-theme') || 'light';
        };

        // Phase 24: Plain-JS theme toggle that works WITHOUT Blazor circuit.
        // Updates the button UI (icon + label) + toggles the data-theme attribute.
        // This is called via onclick= (native HTML), not @@onclick (Blazor), so it
        // works even when the Blazor SignalR circuit fails on Render free tier.
        window.ukuuToggleThemeAndUpdate = function(btn) {
            var next = window.ukuuToggleTheme();
            var isDark = next === 'dark';

            // Update all theme toggle buttons on the page
            document.querySelectorAll('.bk-theme-toggle').forEach(function(el) {
                if (isDark) el.classList.add('dark');
                else el.classList.remove('dark');
                el.setAttribute('data-is-dark', isDark);
            });

            // Update admin sidebar icon + label
            var icon = document.getElementById('ukuu-theme-icon');
            if (icon) icon.textContent = isDark ? 'dark_mode' : 'light_mode';
            var label = document.getElementById('ukuu-theme-label');
            if (label) label.textContent = isDark ? 'Dark Mode' : 'Light Mode';

            // Update public (floating) toggle icon
            var publicIcon = document.getElementById('ukuu-public-theme-icon');
            if (publicIcon) publicIcon.textContent = isDark ? 'dark_mode' : 'light_mode';
        };

        // On page load, sync all toggle button states with the current theme
        (function() {
            var theme = localStorage.getItem('ukuu-theme') || 'dark';
            var isDark = theme === 'dark';
            function syncThemeUI() {
                document.querySelectorAll('.bk-theme-toggle').forEach(function(el) {
                    if (isDark) el.classList.add('dark');
                    else el.classList.remove('dark');
                });
                var icon = document.getElementById('ukuu-theme-icon');
                if (icon) icon.textContent = isDark ? 'dark_mode' : 'light_mode';
                var label = document.getElementById('ukuu-theme-label');
                if (label) label.textContent = isDark ? 'Dark Mode' : 'Light Mode';
                var publicIcon = document.getElementById('ukuu-public-theme-icon');
                if (publicIcon) publicIcon.textContent = isDark ? 'dark_mode' : 'light_mode';
            }
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', syncThemeUI);
            } else {
                syncThemeUI();
            }
        })();


        // Phase 28: Save employee via JS (works without Blazor circuit)
        // Collects all form inputs and POSTs to /api/employees/save
        window.ukuuSaveEmployee = async function(btn, isEdit, empId) {
            btn.disabled = true;
            btn.innerHTML = '<span class="material-icons-round" style="font-size:16px;">sync</span> Saving…';
            
            try {
                // Find the EditForm (Blazor renders it as <form>)
                var form = btn.closest('form');
                if (!form) { alert('Form not found'); return; }
                
                // Collect ALL form data
                var formData = new FormData(form);
                formData.set('isEdit', isEdit);
                formData.set('employeeId', empId);
                
                var response = await fetch('/api/employees/save', {
                    method: 'POST',
                    body: formData
                });
                
                if (response.ok) {
                    var result = await response.json();
                    window.location.href = '/employees?saved=1&name=' + encodeURIComponent(result.name || '');
                } else {
                    var error = await response.text();
                    btn.disabled = false;
                    btn.innerHTML = '<span class="material-icons-round" style="font-size:16px;">check</span>' + (isEdit === 'true' ? 'Save Changes' : 'Create Employee');
                    alert('Failed to save: ' + error);
                }
            } catch (e) {
                btn.disabled = false;
                btn.innerHTML = '<span class="material-icons-round" style="font-size:16px;">check</span>' + (isEdit === 'true' ? 'Save Changes' : 'Create Employee');
                alert('Error: ' + e.message);
            }
        };

        // PWA: Register service worker with cache-busting version.
        // The service worker URL includes the build timestamp so the browser
        // re-registers a new SW on every deployment (bypassing the 24h cache).
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function() {
                navigator.serviceWorker.register('/service-worker.js?v=@_cacheVersion').then(function(reg) {
                    // Force the new service worker to activate immediately
                    // (skips the waiting state that normally requires all tabs to close)
                    if (reg.waiting) { reg.waiting.postMessage('skipWaiting'); }
                    if (reg.installing) { reg.installing.postMessage('skipWaiting'); }
                    reg.addEventListener('updatefound', function() {
                        var newWorker = reg.installing;
                        newWorker.addEventListener('statechange', function() {
                            if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
                                // New content available — reload to pick up new assets
                                console.log('[SW] New content available, reloading...');
                                window.location.reload();
                            }
                        });
                    });
                }).catch(function(err) {
                    console.log('ServiceWorker registration failed: ', err);
                });
            });
        }

        // ───── Page transition animation ─────
        // Intercepts clicks on internal links, plays a quick fade-out animation
        // on the main content, then navigates. The new page plays a fade-in
        // animation via the .bk-admin-fade-in CSS class.
        // Theme state (dark/light) is preserved automatically via localStorage
        // + the inline script in <head> that applies it before paint.
        (function() {
            var isNavigating = false;

            function findMainContent() {
                return document.querySelector('.bk-admin-fade-in') ||
                       document.querySelector('.bk-admin-main') ||
                       document.querySelector('.bk-auth') ||
                       document.body;
            }

            function playExitAnimation(targetUrl) {
                if (isNavigating) return;
                isNavigating = true;
                var main = findMainContent();
                if (main && !main.classList.contains('bk-page-leaving')) {
                    main.classList.add('bk-page-leaving');
                    // Wait for animation to finish, then navigate
                    setTimeout(function() {
                        window.location.href = targetUrl;
                    }, 180);
                } else {
                    // Fallback — navigate immediately
                    window.location.href = targetUrl;
                }
            }

            // Intercept link clicks for internal navigation
            document.addEventListener('click', function(e) {
                // Skip if already navigating, or if it's not a left-click
                if (isNavigating) return;
                if (e.button !== 0) return;
                // Skip if modifier keys pressed (ctrl/cmd+click = new tab)
                if (e.ctrlKey || e.metaKey || e.shiftKey || e.altKey) return;

                // Find the closest anchor element
                var link = e.target.closest('a');
                if (!link) return;

                var href = link.getAttribute('href');
                if (!href) return;

                // Skip external links, mailto, tel, hash-only links, and downloads
                if (href.startsWith('http://') || href.startsWith('https://')) {
                    // Allow same-origin links to animate
                    try {
                        var url = new URL(href, window.location.origin);
                        if (url.origin !== window.location.origin) return;
                    } catch (e) { return; }
                }
                if (href.startsWith('mailto:') || href.startsWith('tel:')) return;
                if (href.startsWith('#')) return;
                if (link.hasAttribute('download')) return;
                // Skip links with target="_blank"
                if (link.target === '_blank') return;

                // Skip form-submit buttons (they have onclick handlers, not navigation)
                if (link.classList.contains('bk-btn') && link.tagName !== 'A') return;

                // Play exit animation + navigate
                e.preventDefault();
                playExitAnimation(href);
            }, true); // Use capture phase to intercept before Blazor's handler

            // Reset navigation flag on page show (handles back/forward navigation)
            window.addEventListener('pageshow', function() {
                isNavigating = false;
            });
        })();
    </script>
</body>
</html>
